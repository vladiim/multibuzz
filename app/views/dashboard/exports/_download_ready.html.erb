<div class="space-y-4">
  <svg class="h-8 w-8 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
  </svg>
  <h2 class="text-lg font-semibold text-gray-900">Export ready</h2>
  <p class="text-sm text-gray-500"><%= export.filename %></p>
  <%= link_to dashboard_export_download_path(id: export.prefix_id),
      class: "inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
    </svg>
    Download
  <% end %>
  <%= link_to "Back to dashboard", dashboard_path, class: "block text-sm text-gray-500 hover:text-gray-700 mt-2" %>
</div>
