<%
  by_conversion_name = data[:by_conversion_name] || []
  breakdown_dimension = @filter_params[:breakdown_dimension] || "conversion_type"
  dimensions = Dashboard::ConversionDimensionsService.new(current_account).call[:dimensions]
  current_dimension = dimensions.find { |d| d[:key] == breakdown_dimension } || dimensions.first
  selected_metric = @filter_params[:metric]

  chart_metric = case selected_metric
    when "revenue", "aov" then "revenue"
    when "avg_channels" then "avg_channels"
    when "avg_visits" then "avg_visits"
    when "avg_days" then "avg_days"
    else "credits"
    end

  chart_titles = {
    "conversions" => "Conversions",
    "revenue" => "Revenue",
    "aov" => "Revenue",
    "avg_channels" => "Avg Channels",
    "avg_visits" => "Avg Visits",
    "avg_days" => "Avg Days"
  }
  chart_title = chart_titles[selected_metric] || "Conversions"
%>
<div class="bg-white p-6 rounded-lg shadow mb-6">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <h3 class="text-lg font-medium text-gray-900"><%= chart_title %> by</h3>
      <form action="<%= dashboard_path %>" method="get" data-turbo-frame="_top">
        <%= hidden_filter_params(except: :breakdown_dimension) %>
        <select name="breakdown_dimension"
          onchange="this.form.submit()"
          class="text-lg font-medium text-indigo-600 bg-transparent border-none cursor-pointer focus:ring-0 pr-8">
          <% dimensions.each do |dim| %>
            <option value="<%= dim[:key] %>" <%= "selected" if dim[:key] == breakdown_dimension %>>
              <%= dim[:label] %>
            </option>
          <% end %>
        </select>
      </form>
    </div>
    <div class="group relative">
      <svg class="w-4 h-4 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div class="hidden group-hover:block absolute z-10 w-56 p-2 text-xs text-gray-600 bg-white border border-gray-200 rounded shadow-lg right-0 top-6">
        Shows conversion attribution credits grouped by <%= current_dimension&.dig(:label)&.downcase || "conversion type" %>.
      </div>
    </div>
  </div>

  <%= chart_or_empty(data: by_conversion_name, empty_message: "No conversion data for the selected period") do %>
    <div id="conversion-name-chart"
      data-controller="chart"
      data-chart-type-value="stacked-bar"
      data-chart-metric-value="<%= chart_metric %>"
      data-chart-data-value="<%= by_conversion_name.to_json %>"
      class="h-64">
    </div>
  <% end %>
</div>
