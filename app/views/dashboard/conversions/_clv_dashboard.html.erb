<% if @clv_data&.dig(:has_data) %>
  <%= render "dashboard/conversions/clv_kpi_cards", totals: @clv_data[:totals], coverage: @clv_data[:coverage] %>

  <!-- CLV by Channel Chart -->
  <div class="bg-white p-6 rounded-lg shadow mb-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-medium text-gray-900">CLV by Acquisition Channel</h3>
      <div class="group relative">
        <svg class="w-4 h-4 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="hidden group-hover:block absolute z-10 w-64 p-2 text-xs text-gray-600 bg-white border border-gray-200 rounded shadow-lg right-0 top-6">
          Average lifetime value per customer, grouped by the channel that acquired them.
        </div>
      </div>
    </div>
    <div id="clv-by-channel-chart"
      data-controller="chart"
      data-chart-type-value="bar"
      data-chart-metric-value="clv"
      data-chart-data-value="<%= @clv_data[:by_channel].to_json %>"
      class="h-80">
    </div>
  </div>

  <!-- Smiling Curve Chart -->
  <% if @clv_data[:smiling_curve].present? %>
    <div class="bg-white p-6 rounded-lg shadow mb-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-medium text-gray-900">Revenue per Customer by Lifecycle Month</h3>
        <div class="group relative">
          <svg class="w-4 h-4 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div class="hidden group-hover:block absolute z-10 w-72 p-2 text-xs text-gray-600 bg-white border border-gray-200 rounded shadow-lg right-0 top-6">
            <p class="mb-2"><strong>The "Smiling Curve"</strong></p>
            <p>Shows average revenue per customer for each month of their lifecycle. The curve typically "smiles" because:</p>
            <ul class="list-disc ml-4 mt-1">
              <li>Month 1: High (first purchase)</li>
              <li>Months 2-6: Dip (churn)</li>
              <li>Months 12+: Rise (loyal customers become more valuable)</li>
            </ul>
          </div>
        </div>
      </div>
      <div id="smiling-curve-chart"
        data-controller="chart"
        data-chart-type-value="line"
        data-chart-data-value="<%= @clv_data[:smiling_curve].to_json %>"
        class="h-72">
      </div>
    </div>
  <% end %>

  <!-- Cohort Analysis -->
  <% if @clv_data[:cohort_analysis].present? %>
    <div class="bg-white p-6 rounded-lg shadow">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-medium text-gray-900">Cohort Analysis</h3>
        <div class="group relative">
          <svg class="w-4 h-4 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div class="hidden group-hover:block absolute z-10 w-64 p-2 text-xs text-gray-600 bg-white border border-gray-200 rounded shadow-lg right-0 top-6">
            Cumulative LTV progression by acquisition month cohort. Helps identify which cohorts are most valuable over time.
          </div>
        </div>
      </div>
      <%= render "dashboard/conversions/cohort_table", cohorts: @clv_data[:cohort_analysis] %>
    </div>
  <% end %>
<% else %>
  <%= render "dashboard/conversions/clv_empty_state" %>
<% end %>
