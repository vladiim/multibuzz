<%= turbo_frame_tag "conversions_#{current_account.prefix_id}" do %>
  <div class="dashboard-section">
    <% if @comparison_mode %>
      <!-- Side-by-side comparison mode -->
      <div class="grid grid-cols-2 gap-6">
        <% @results.each do |item| %>
          <% if item[:result][:success] %>
            <%= render "dashboard/conversions/dashboard_panel",
              result: item[:result],
              model: item[:model] %>
          <% else %>
            <div class="bg-red-50 p-4 rounded-lg">
              <h3 class="font-semibold text-red-900 mb-2"><%= item[:model].name.titleize %></h3>
              <p class="text-red-700">Error: <%= item[:result][:errors].join(', ') %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <!-- Single model view -->
      <% item = @results.first %>
      <% if item[:result][:success] %>
        <%= render "dashboard/conversions/full_dashboard",
          result: item[:result],
          model: item[:model] %>
      <% else %>
        <div class="bg-red-50 p-4 rounded-lg">
          <p class="text-red-700">Error loading conversions data: <%= item[:result][:errors].join(', ') %></p>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
