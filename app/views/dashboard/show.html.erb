<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>
  <%= render "shared/billing_banner", account: current_account %>
  <%= render "shared/onboarding_banner", account: current_account %>
  <%= render "shared/test_mode_banner" %>
  <%= render "shared/setup_guidance_banner", account: current_account %>

  <div class="py-6">
    <main>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Main Dashboard Container -->
        <div data-controller="toggle"
          data-toggle-default-value="conversions"
          data-toggle-active-class="border-indigo-500 text-indigo-600"
          data-toggle-inactive-class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">

          <!-- Tab Bar: Two rows on mobile, single row on desktop -->
          <div class="border-b border-gray-200">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
              <!-- Tab Navigation - scrollable on mobile -->
              <nav class="-mb-px flex gap-4 sm:gap-6 overflow-x-auto scrollbar-hide">
                <button type="button"
                  data-toggle-target="trigger"
                  data-action="toggle#select"
                  data-value="conversions"
                  class="py-3 px-1 text-sm font-medium border-b-2 whitespace-nowrap">
                  Conversions
                </button>
                <button type="button"
                  data-toggle-target="trigger"
                  data-action="toggle#select"
                  data-value="funnel"
                  class="py-3 px-1 text-sm font-medium border-b-2 whitespace-nowrap">
                  Funnel
                </button>
                <button type="button"
                  data-toggle-target="trigger"
                  data-action="toggle#select"
                  data-value="events"
                  class="py-3 px-1 text-sm font-medium border-b-2 whitespace-nowrap">
                  Events
                </button>
              </nav>

              <!-- Filters & Export Buttons - below tabs on mobile, inline on desktop -->
              <div class="flex items-center gap-2 py-2 sm:pb-3 sm:pt-0">
                <!-- Filters Toggle -->
                <button type="button"
                  data-action="click->toggle#toggleFilters"
                  data-toggle-target="filtersButton"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 border border-gray-300 rounded-md hover:bg-gray-50">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                  </svg>
                  Filters
                </button>
                <!-- Export Dropdown (Coming Soon) -->
                <div data-controller="toggle" data-toggle-close-on-click-outside-value="true" class="relative">
                  <button type="button" data-action="click->toggle#toggle" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 border border-gray-300 rounded-md hover:bg-gray-50">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Export
                    <span class="ml-1 px-1.5 py-0.5 text-xs bg-amber-100 text-amber-700 rounded">Soon</span>
                  </button>
                  <div data-toggle-target="content" class="hidden absolute right-0 mt-1 w-48 bg-white border border-gray-200 rounded-md shadow-lg z-10 p-2">
                    <p class="px-2 py-1 text-xs text-gray-500 mb-2">Coming soon! Join the waitlist:</p>
                    <%= waitlist_button(
                      feature_key: "csv_export",
                      feature_name: "CSV Export",
                      context: "dashboard_export",
                      label: "CSV Export",
                      class: "block w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded"
                    ) %>
                    <%= waitlist_button(
                      feature_key: "api_extract",
                      feature_name: "API Extract",
                      context: "dashboard_export",
                      label: "API Extract",
                      class: "block w-full text-left px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded"
                    ) %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Collapsible Filters Bar (pushes content down) -->
          <div data-toggle-target="filters" class="hidden py-4">
            <%= turbo_frame_tag "filters_#{current_account.prefix_id}",
              src: dashboard_filters_path(request.query_parameters),
              loading: :lazy do %>
              <div class="bg-white p-4 rounded-lg shadow animate-pulse">
                <div class="flex gap-4">
                  <div class="h-9 w-36 bg-gray-200 rounded"></div>
                  <div class="h-9 w-48 bg-gray-200 rounded"></div>
                  <div class="h-9 w-44 bg-gray-200 rounded"></div>
                  <div class="h-9 w-20 bg-gray-200 rounded"></div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Tab Content -->
          <div class="mt-6">
            <!-- Conversions Tab -->
            <div data-toggle-target="content" data-value="conversions">
              <!-- CLV Mode Toggle -->
              <div data-testid="clv-mode-toggle" class="flex items-center gap-2 mb-4">
                <span class="text-sm font-medium text-gray-500">View:</span>
                <div class="inline-flex rounded-lg p-1 bg-gray-100">
                  <%= form_with url: dashboard_clv_mode_path, method: :patch, data: { turbo_frame: "_top" } do %>
                    <input type="hidden" name="mode" value="transactions">
                    <button type="submit" class="px-3 py-1.5 text-sm font-medium rounded-md transition-colors <%= clv_mode? ? 'text-gray-600 hover:bg-gray-200' : 'bg-white text-gray-900 shadow-sm' %>">
                      Transactions
                    </button>
                  <% end %>
                  <%= form_with url: dashboard_clv_mode_path, method: :patch, data: { turbo_frame: "_top" } do %>
                    <input type="hidden" name="mode" value="clv">
                    <button type="submit" class="px-3 py-1.5 text-sm font-medium rounded-md transition-colors <%= clv_mode? ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-600 hover:bg-gray-200' %>">
                      Customer LTV
                    </button>
                  <% end %>
                </div>
              </div>

              <%= turbo_frame_tag "conversions_#{current_account.prefix_id}",
                src: dashboard_conversions_path(request.query_parameters),
                loading: :lazy do %>
                <%= render "dashboard/conversions/skeleton" %>
              <% end %>
            </div>

            <!-- Funnel Tab -->
            <div data-toggle-target="content" data-value="funnel" class="hidden">
              <%= turbo_frame_tag "funnel_#{current_account.prefix_id}",
                src: dashboard_funnel_path(request.query_parameters),
                loading: :lazy do %>
                <%= render "dashboard/funnel/skeleton" %>
              <% end %>
            </div>

            <!-- Events Tab (Live) -->
            <div data-toggle-target="content" data-value="events" class="hidden" data-controller="event-panel">
              <!-- Turbo Stream subscription for real-time updates -->
              <%= turbo_stream_from "account_#{current_account.prefix_id}_events" %>

              <!-- Header with filter -->
              <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                  <span class="text-sm text-gray-600">Showing last <%= @live_events.size %> events</span>
                  <% if @test_only %>
                    <span class="px-2 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-800 rounded">Test only</span>
                  <% end %>
                </div>
                <div class="flex items-center gap-4">
                  <!-- Test Only Toggle -->
                  <form action="<%= dashboard_path %>" method="get" data-controller="auto-submit">
                    <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                      <input type="checkbox"
                        name="test_only"
                        value="true"
                        <%= "checked" if @test_only %>
                        data-action="change->auto-submit#submit"
                        class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                      Test events only
                    </label>
                  </form>
                  <!-- Connection Status -->
                  <div data-controller="connection-status" class="flex items-center gap-1.5 text-sm text-gray-500">
                    <span data-connection-status-target="dot" class="w-2 h-2 bg-yellow-500 rounded-full"></span>
                    <span data-connection-status-target="text">Connecting...</span>
                  </div>
                </div>
              </div>

              <!-- Events List -->
              <div class="bg-white shadow rounded-lg overflow-hidden">
                <div id="events-list" class="divide-y divide-gray-200">
                  <% @live_events.each do |event| %>
                    <%= render "dashboard/live_events/event_card", event: event %>
                  <% end %>

                  <% if @live_events.empty? %>
                    <div class="px-4 py-12 text-center text-gray-500">
                      <p class="text-lg">No events yet</p>
                      <p class="text-sm mt-1">Events will appear here in real-time as they're received</p>
                    </div>
                  <% end %>
                </div>
              </div>

              <!-- Slide-out Panel -->
              <div id="event-panel"
                class="fixed inset-y-0 right-0 w-full sm:w-96 bg-white shadow-xl transform translate-x-full transition-transform duration-200 ease-in-out z-50">
                <%= render "dashboard/live_events/event_panel" %>
              </div>

              <!-- Panel Backdrop -->
              <div id="event-panel-backdrop"
                data-action="click->event-panel#close"
                class="fixed inset-0 bg-black bg-opacity-25 hidden z-40">
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
