<% identity = feed_item.record %>
<div data-action="click->event-panel#open"
  data-event-json="<%= feed_item_json(feed_item) %>"
  class="px-4 py-3 hover:bg-gray-50 cursor-pointer transition-colors">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="<%= feed_badge_class(:identify) %>">ID</span>

      <div>
        <div class="flex items-center gap-2">
          <span class="font-medium text-gray-900">identify</span>
          <% if identity.respond_to?(:is_test) && identity.is_test %>
            <span class="px-1.5 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-800 rounded">TEST</span>
          <% end %>
        </div>
        <div class="text-sm text-gray-500">
          <%= identify_primary_info(identity) %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-sm text-gray-500" title="<%= identity.last_identified_at.iso8601 %>">
        <%= time_ago_in_words(identity.last_identified_at) %> ago
      </span>
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</div>
