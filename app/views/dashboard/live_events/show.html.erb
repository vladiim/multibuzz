<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900">Live Events</h1>
    <div class="flex items-center gap-4">
      <!-- Test Only Toggle -->
      <form action="<%= dashboard_live_path %>" method="get" data-controller="auto-submit">
        <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
          <input type="checkbox"
            name="test_only"
            value="true"
            <%= "checked" if @test_only %>
            data-action="change->auto-submit#submit"
            class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
          Test events only
        </label>
      </form>

      <!-- Connection Status -->
      <div class="flex items-center gap-1.5 text-sm text-gray-500">
        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
        Connected
      </div>
    </div>
  </div>

  <!-- Turbo Stream subscription for real-time updates -->
  <%= turbo_stream_from "account_#{current_account.prefix_id}_events" %>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-200 bg-gray-50">
      <p class="text-sm text-gray-600">
        Showing last <%= @events.size %> events
        <% if @test_only %>(test only)<% end %>
      </p>
    </div>

    <div id="events-list" class="divide-y divide-gray-200">
      <% @events.each do |event| %>
        <%= render "event_card", event: event %>
      <% end %>

      <% if @events.empty? %>
        <div class="px-4 py-12 text-center text-gray-500">
          <p class="text-lg">No events yet</p>
          <p class="text-sm mt-1">Events will appear here in real-time as they're received</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Slide-out Panel -->
  <div id="event-panel"
    data-controller="event-panel"
    class="fixed inset-y-0 right-0 w-96 bg-white shadow-xl transform translate-x-full transition-transform duration-200 ease-in-out z-50">
    <%= render "event_panel" %>
  </div>

  <!-- Panel Backdrop -->
  <div id="event-panel-backdrop"
    data-action="click->event-panel#close"
    class="fixed inset-0 bg-black bg-opacity-25 hidden z-40">
  </div>
</div>
