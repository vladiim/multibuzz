<div data-event-id="<%= event.prefix_id %>"
  data-action="click->event-panel#open"
  data-event-json="<%= event_json(event) %>"
  class="px-4 py-3 hover:bg-gray-50 cursor-pointer transition-colors">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <!-- Event Type Badge -->
      <span class="<%= event_type_badge_class(event.event_type) %>">
        <%= event_type_initial(event.event_type) %>
      </span>

      <div>
        <div class="flex items-center gap-2">
          <span class="font-medium text-gray-900"><%= event.event_type %></span>
          <% if event.is_test %>
            <span class="px-1.5 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-800 rounded">TEST</span>
          <% end %>
        </div>
        <div class="text-sm text-gray-500">
          <%= event_primary_info(event) %>
          <% if event.session&.channel %>
            <span class="mx-1">•</span>
            <span><%= event.session.channel.titleize %></span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-sm text-gray-500" title="<%= event.occurred_at.iso8601 %>">
        <%= time_ago_in_words(event.occurred_at) %> ago
      </span>
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</div>
