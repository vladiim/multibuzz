<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <!-- Header -->
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <div>
      <h2 class="text-lg font-medium text-gray-900"><%= t("dashboard.api_keys.index.title") %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t("dashboard.api_keys.index.subtitle") %></p>
    </div>
    <div>
      <button type="button"
        data-controller="modal"
        data-action="click->modal#open"
        data-modal-target-value="api-key-modal"
        class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        <%= t("dashboard.api_keys.index.generate_button") %>
      </button>
    </div>
  </div>

  <% if @api_keys.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.api_keys.index.table.prefix") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.api_keys.index.table.environment") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.api_keys.index.table.created") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.api_keys.index.table.last_used") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.api_keys.index.table.status") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("dashboard.api_keys.index.table.actions") %></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @api_keys.each do |api_key| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900"><%= api_key.key_prefix %>****</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= api_key.live? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                <%= api_key.environment.capitalize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= api_key.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= api_key.last_used_at ? time_ago_in_words(api_key.last_used_at) + " ago" : "Never" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if api_key.active? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800"><%= t("dashboard.api_keys.index.status.active") %></span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800"><%= t("dashboard.api_keys.index.status.revoked") %></span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if api_key.active? %>
                <%= button_to t("dashboard.api_keys.index.actions.revoke"), dashboard_api_key_path(api_key), method: :delete, class: "text-red-600 hover:text-red-900", form: { data: { turbo_confirm: t("dashboard.api_keys.index.actions.revoke_confirm") } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-12 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900"><%= t("dashboard.api_keys.index.no_keys") %></h3>
      <p class="mt-1 text-sm text-gray-500">Get started by generating your first API key.</p>
      <div class="mt-6">
        <button type="button"
          data-controller="modal"
          data-action="click->modal#open"
          data-modal-target-value="api-key-modal"
          class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
          <%= t("dashboard.api_keys.index.generate_button") %>
        </button>
      </div>
    </div>
  <% end %>
</div>

<!-- API Key Generation Modal -->
<div id="api-key-modal" class="hidden fixed inset-0 z-50" data-controller="modal">
  <div class="fixed inset-0 bg-black bg-opacity-25" data-action="click->modal#close"></div>
  <div class="fixed inset-0 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full">
      <div class="px-6 py-4 border-b border-gray-200">
        <h3 class="text-lg font-medium text-gray-900"><%= t("dashboard.api_keys.form.title") %></h3>
      </div>
      <%= form_with url: dashboard_api_keys_path, method: :post, class: "px-6 py-4" do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700"><%= t("dashboard.api_keys.form.environment_label") %></label>
            <div class="mt-2 flex gap-4">
              <label class="inline-flex items-center">
                <input type="radio" name="api_key[environment]" value="test" class="h-4 w-4 text-indigo-600 border-gray-300 focus:ring-indigo-500" checked>
                <span class="ml-2 text-sm text-gray-700"><%= t("dashboard.api_keys.form.environment_test") %></span>
              </label>
              <label class="inline-flex items-center">
                <input type="radio" name="api_key[environment]" value="live" class="h-4 w-4 text-indigo-600 border-gray-300 focus:ring-indigo-500">
                <span class="ml-2 text-sm text-gray-700"><%= t("dashboard.api_keys.form.environment_live") %></span>
              </label>
            </div>
          </div>
          <div>
            <label for="api_key_name" class="block text-sm font-medium text-gray-700"><%= t("dashboard.api_keys.form.name_label") %></label>
            <input type="text" name="api_key[name]" id="api_key_name" placeholder="<%= t("dashboard.api_keys.form.name_placeholder") %>" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
          </div>
        </div>
        <div class="mt-6 flex gap-3 justify-end">
          <button type="button" data-action="click->modal#close" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">
            <%= t("dashboard.api_keys.form.cancel") %>
          </button>
          <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-md">
            <%= t("dashboard.api_keys.form.submit") %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
