<% model_names = credits.filter_map { |c| c.attribution_model&.name }.uniq.sort %>

<div data-controller="filter">
  <div class="flex items-center gap-2 mb-4">
    <select data-action="filter#change" data-filter-target="select"
      class="block w-full sm:w-auto rounded-md border-gray-300 text-sm text-gray-700 focus:border-indigo-500 focus:ring-indigo-500">
      <% model_names.each do |name| %>
        <option value="<%= name %>"><%= name.titleize %></option>
      <% end %>
    </select>
    <div class="relative" data-controller="toggle" data-toggle-close-on-click-outside-value="true">
      <button type="button" data-action="toggle#toggle"
        class="w-5 h-5 rounded-full border border-gray-300 text-gray-400 hover:text-gray-600 hover:border-gray-400 flex items-center justify-center text-xs font-serif italic leading-none">
        i
      </button>
      <div data-toggle-target="content" class="hidden absolute left-0 mt-1 w-72 bg-gray-900 text-white text-xs rounded-lg shadow-lg p-3 z-20 leading-relaxed">
        Each model distributes credit across the same journey but at different granularities.
        Most models show <strong>one row per touchpoint</strong> &mdash; long journeys mean many rows.
        Participation is the exception: it groups by <strong>unique channel</strong>, so it shows fewer rows.
      </div>
    </div>
  </div>

  <% model_names.each_with_index do |name, i| %>
    <div data-filter-target="content" data-value="<%= name %>" <%= 'hidden' if i > 0 %>>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr>
              <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Channel</th>
              <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Credit</th>
              <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Revenue</th>
              <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Source</th>
              <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Campaign</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% credits.select { |c| c.attribution_model&.name == name }.each do |credit| %>
              <tr>
                <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900"><%= credit.channel&.titleize %></td>
                <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900 text-right"><%= number_with_precision(credit.credit, precision: 2) %></td>
                <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900 text-right">
                  <% if credit.revenue_credit.present? %>
                    <%= number_to_currency(credit.revenue_credit) %>
                  <% else %>
                    <span class="text-gray-400">&mdash;</span>
                  <% end %>
                </td>
                <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500"><%= credit.utm_source || raw("&mdash;") %></td>
                <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500"><%= credit.utm_campaign || raw("&mdash;") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
