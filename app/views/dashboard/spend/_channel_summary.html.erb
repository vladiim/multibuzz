<%# Required locals: by_channel %>
<div class="lg:col-span-2 bg-white p-4 sm:p-6 rounded-lg shadow">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-base sm:text-lg font-medium text-gray-900">By Channel</h3>
    <div class="group relative">
      <svg class="w-4 h-4 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div class="hidden group-hover:block absolute z-10 w-48 p-2 text-xs text-gray-600 bg-white border border-gray-200 rounded shadow-lg right-0 top-6">
        Spend and attributed ROAS by channel using selected attribution model.
      </div>
    </div>
  </div>

  <% if by_channel.present? %>
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
          <th class="pb-3">Channel</th>
          <th class="pb-3 text-right">Spend</th>
          <th class="pb-3 text-right">ROAS</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% by_channel.each do |row| %>
          <tr>
            <td class="py-3">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= spend_channel_color(row[:channel]) %>"></span>
                <span class="font-medium text-gray-900"><%= row[:channel].titleize %></span>
              </div>
            </td>
            <td class="py-3 text-right text-gray-700"><%= format_spend(row[:spend_micros]) %></td>
            <td class="py-3 text-right">
              <span class="font-semibold text-gray-900"><%= row[:roas] ? "#{row[:roas]}x" : "—" %></span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="h-32 flex items-center justify-center text-gray-500 text-sm">
      No channel data available
    </div>
  <% end %>
</div>
