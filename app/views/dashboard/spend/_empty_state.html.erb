<div class="bg-white rounded-lg shadow">
  <div class="px-6 py-16 text-center max-w-lg mx-auto">
    <div class="mx-auto w-20 h-20 bg-indigo-50 rounded-2xl flex items-center justify-center mb-6">
      <svg class="w-10 h-10 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
      </svg>
    </div>

    <h3 class="text-xl font-semibold text-gray-900 mb-2">See where your money works hardest</h3>
    <p class="text-sm text-gray-500 mb-8">
      Connect your ad platform to unlock attributed ROAS, payback periods, and channel-level spend intelligence &mdash; powered by your multi-touch attribution data.
    </p>

    <%= link_to account_integrations_path,
        class: "inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors shadow-sm" do %>
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#fff" fill-opacity=".6" />
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#fff" fill-opacity=".7" />
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#fff" fill-opacity=".5" />
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#fff" fill-opacity=".8" />
      </svg>
      Connect Google Ads
    <% end %>

    <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">
      <div class="bg-gray-50 rounded-lg p-4">
        <div class="text-sm font-medium text-gray-900 mb-1">Attributed ROAS</div>
        <div class="text-xs text-gray-500">True return on ad spend using your multi-touch attribution models, not platform self-reporting.</div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <div class="text-sm font-medium text-gray-900 mb-1">Payback Period</div>
        <div class="text-xs text-gray-500">How long until a new customer's CLV covers the acquisition cost, by channel.</div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <div class="text-sm font-medium text-gray-900 mb-1">Channel Intelligence</div>
        <div class="text-xs text-gray-500">Hourly spend patterns, device breakdown, and campaign-level drill-downs.</div>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
      <span class="text-xs text-gray-400">Coming soon:</span>
      <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded">Meta Ads</span>
      <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded">TikTok</span>
      <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded">LinkedIn</span>
      <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded">+6 more</span>
    </div>
  </div>
</div>
