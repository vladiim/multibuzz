<%# Required locals: payback, totals %>

<h4 class="text-base font-medium text-gray-900 mb-4">Payback Period by Acquisition Channel</h4>

<% if payback.present? %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">
          <th class="pb-3 pr-4">Channel</th>
          <th class="pb-3 pr-4 text-right">NCAC</th>
          <th class="pb-3 pr-4 text-right">Customers</th>
          <th class="pb-3 pr-4 text-right">Payback</th>
          <th class="pb-3 text-right">CLV Curve (12 mo)</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% payback.each do |row| %>
          <tr class="hover:bg-gray-50">
            <td class="py-3 pr-4">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= spend_channel_color(row[:channel]) %>"></span>
                <span class="font-medium text-gray-900"><%= row[:channel].titleize %></span>
              </div>
            </td>
            <td class="py-3 pr-4 text-right text-gray-700">
              <%= row[:ncac] ? number_to_currency(row[:ncac], precision: 0) : "—" %>
            </td>
            <td class="py-3 pr-4 text-right text-gray-600">
              <%= number_with_delimiter(row[:customers]) %>
            </td>
            <td class="py-3 pr-4 text-right font-semibold">
              <% if row[:payback_months] == 0 %>
                <span class="text-green-600">Immediate</span>
              <% elsif row[:payback_months] %>
                <span class="<%= row[:payback_months] <= 3 ? 'text-green-600' : row[:payback_months] <= 6 ? 'text-amber-600' : 'text-red-600' %>">
                  <%= pluralize(row[:payback_months], "mo") %>
                </span>
              <% else %>
                <span class="text-gray-400">> 12 mo</span>
              <% end %>
            </td>
            <td class="py-3">
              <% if row[:clv_curve].present? %>
                <div class="flex items-end gap-px h-6">
                  <% max_clv = row[:clv_curve].map { |p| p[:cumulative_clv] }.max %>
                  <% row[:clv_curve].each do |point| %>
                    <% pct = max_clv&.positive? ? (point[:cumulative_clv] / max_clv * 100).round : 0 %>
                    <div class="flex-1 bg-indigo-300 rounded-t-sm"
                      style="height: <%= [pct, 4].max %>%"
                      title="Month <%= point[:month] %>: <%= number_to_currency(point[:cumulative_clv], precision: 0) %>">
                    </div>
                  <% end %>
                </div>
              <% else %>
                <span class="text-gray-400 text-xs">No data</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if totals[:ncac] %>
    <div class="mt-4 flex items-center gap-2 text-xs text-gray-400">
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>Blended NCAC: <%= number_to_currency(totals[:ncac], precision: 0) %>. Payback = month when cumulative CLV exceeds NCAC.</span>
    </div>
  <% end %>
<% else %>
  <div class="h-32 flex items-center justify-center text-sm text-gray-500">
    <div class="text-center">
      <p>No payback data available</p>
      <p class="mt-1 text-xs text-gray-400">Requires acquisition conversions with identity tracking</p>
    </div>
  </div>
<% end %>
