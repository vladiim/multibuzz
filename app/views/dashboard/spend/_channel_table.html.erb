<%# Required locals: by_channel, totals; optional: compare, confidence_band_active %>
<%
  compare ||= nil
  confidence_band_active ||= false
  comparing = compare.present?
  compare_by_channel = comparing ? compare[:by_channel].index_by { |r| r[:channel] } : {}
  total_columns = 10 + (comparing ? 2 : 0) + (confidence_band_active ? 1 : 0)
%>
<h4 class="text-base font-medium text-gray-900 mb-4">Channel Performance Detail</h4>

<% if by_channel.present? %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-b border-gray-200">
          <th class="pb-3 pr-4">Channel</th>
          <th class="pb-3 pr-4 text-right">Spend</th>
          <th class="pb-3 pr-4 text-right">Platform Rev</th>
          <th class="pb-3 pr-4 text-right">Attributed Rev</th>
          <th class="pb-3 pr-4 text-right">
            <div class="group relative inline-flex items-center gap-1">
              Gap %
              <svg class="w-3 h-3 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div class="hidden group-hover:block absolute z-10 w-64 p-2 text-xs font-normal normal-case text-gray-600 bg-white border border-gray-200 rounded shadow-lg right-0 top-5">
                Difference between mbuzz-attributed revenue and the platform's self-reported number. Different methodologies, both useful — platforms include view-through and assisted credit mbuzz does not.
              </div>
            </div>
          </th>
          <th class="pb-3 pr-4 text-right">ROAS</th>
          <% if comparing %>
            <th class="pb-3 pr-4 text-right text-amber-700">Δ ROAS</th>
            <th class="pb-3 pr-4 text-right text-amber-700">Δ Revenue</th>
          <% end %>
          <th class="pb-3 pr-4 text-right">Impressions</th>
          <th class="pb-3 pr-4 text-right">Clicks</th>
          <th class="pb-3 pr-4 text-right">CTR</th>
          <th class="pb-3 <%= confidence_band_active ? "pr-4" : "" %> text-right">CPC</th>
          <% if confidence_band_active %>
            <th class="pb-3 text-right">
              <div class="group relative inline-flex items-center gap-1">
                Confidence
                <svg class="w-3 h-3 text-gray-400 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div class="hidden group-hover:block absolute z-10 w-64 p-2 text-xs font-normal normal-case text-gray-600 bg-white border border-gray-200 rounded shadow-lg right-0 top-5">
                  ROAS spread across all active attribution models for this channel. Narrow band = models agree. Wide band = credit is genuinely contested. Click to see all models.
                </div>
              </div>
            </th>
          <% end %>
        </tr>
      </thead>
      <% by_channel.each do |row| %>
        <tbody data-controller="<%= confidence_band_active ? "toggle" : nil %>" class="border-b border-gray-100 last:border-b-0">
          <tr class="hover:bg-gray-50">
            <td class="py-3 pr-4">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= spend_channel_color(row[:channel]) %>"></span>
                <div>
                  <div class="font-medium <%= sync_stale?(row[:last_synced_at]) ? "text-gray-400" : "text-gray-900" %>">
                    <%= row[:channel].titleize %>
                  </div>
                  <% if (label = sync_freshness_label(row[:last_synced_at])) %>
                    <div class="text-xs <%= sync_stale?(row[:last_synced_at]) ? "text-amber-600" : "text-gray-400" %>" data-test-id="channel-freshness">
                      <%= label %>
                    </div>
                  <% end %>
                </div>
              </div>
            </td>
            <td class="py-3 pr-4 text-right text-gray-700"><%= format_spend(row[:spend_micros]) %></td>
            <td class="py-3 pr-4 text-right text-gray-600">
              <%= row[:platform_revenue]&.positive? ? number_to_currency(row[:platform_revenue], precision: 0) : "—" %>
            </td>
            <td class="py-3 pr-4 text-right text-gray-700"><%= number_to_currency(row[:attributed_revenue], precision: 0) %></td>
            <td class="py-3 pr-4 text-right">
              <% gap_amber = row[:gap_pct] && row[:gap_pct].abs >= 15 %>
              <span class="<%= gap_amber ? "text-amber-700 font-semibold" : "text-gray-600" %>">
                <%= row[:gap_pct].nil? ? "—" : "#{'+' if row[:gap_pct] >= 0}#{row[:gap_pct]}%" %>
              </span>
            </td>
            <td class="py-3 pr-4 text-right">
              <span class="font-semibold text-gray-900"><%= row[:roas] ? "#{row[:roas]}x" : "—" %></span>
            </td>
            <% if comparing %>
              <% compare_row = compare_by_channel[row[:channel]] %>
              <% delta_roas = (row[:roas] && compare_row&.[](:roas)) ? (row[:roas] - compare_row[:roas]).round(2) : nil %>
              <% delta_revenue = compare_row ? (row[:attributed_revenue] - compare_row[:attributed_revenue]).round(2) : nil %>
              <td class="py-3 pr-4 text-right">
                <span class="font-semibold <%= delta_roas.to_f >= 0 ? "text-emerald-700" : "text-rose-700" %>">
                  <%= delta_roas.nil? ? "—" : "#{'+' if delta_roas >= 0}#{delta_roas}x" %>
                </span>
              </td>
              <td class="py-3 pr-4 text-right">
                <span class="<%= delta_revenue.to_f >= 0 ? "text-emerald-700" : "text-rose-700" %>">
                  <%= delta_revenue.nil? ? "—" : number_to_currency(delta_revenue, precision: 0, format: (delta_revenue >= 0 ? "+%u%n" : nil)) %>
                </span>
              </td>
            <% end %>
            <td class="py-3 pr-4 text-right text-gray-600"><%= number_with_delimiter(row[:impressions]) %></td>
            <td class="py-3 pr-4 text-right text-gray-600"><%= number_with_delimiter(row[:clicks]) %></td>
            <td class="py-3 pr-4 text-right text-gray-600"><%= spend_ctr(row) %></td>
            <td class="py-3 <%= confidence_band_active ? "pr-4" : "" %> text-right text-gray-600"><%= spend_cpc(row) %></td>
            <% if confidence_band_active %>
              <td class="py-3 text-right">
                <%= render "dashboard/spend/confidence_band_cell", band: row[:confidence_band] %>
              </td>
            <% end %>
          </tr>
          <% if confidence_band_active && row[:confidence_band].present? %>
            <%= render "dashboard/spend/confidence_band_panel", band: row[:confidence_band], colspan: total_columns %>
          <% end %>
        </tbody>
      <% end %>
      <tfoot>
        <tr class="border-t-2 border-gray-200 font-medium">
          <td class="py-3 pr-4 text-gray-900">Total</td>
          <td class="py-3 pr-4 text-right text-gray-900"><%= format_spend(totals[:total_spend_micros]) %></td>
          <td class="py-3 pr-4 text-right text-gray-700">
            <%= totals[:platform_revenue]&.positive? ? number_to_currency(totals[:platform_revenue], precision: 0) : "—" %>
          </td>
          <td class="py-3 pr-4 text-right text-gray-900"><%= number_to_currency(totals[:attributed_revenue], precision: 0) %></td>
          <td class="py-3 pr-4 text-right">
            <% totals_gap_amber = totals[:gap_pct] && totals[:gap_pct].abs >= 15 %>
            <span class="<%= totals_gap_amber ? "text-amber-700 font-semibold" : "text-gray-700" %>">
              <%= totals[:gap_pct].nil? ? "—" : "#{'+' if totals[:gap_pct] >= 0}#{totals[:gap_pct]}%" %>
            </span>
          </td>
          <td class="py-3 pr-4 text-right font-semibold text-gray-900"><%= totals[:blended_roas] ? "#{totals[:blended_roas]}x" : "—" %></td>
          <% if comparing %>
            <% delta_blended = (totals[:blended_roas] && compare[:totals][:blended_roas]) ? (totals[:blended_roas] - compare[:totals][:blended_roas]).round(2) : nil %>
            <% delta_total_rev = (totals[:attributed_revenue] - compare[:totals][:attributed_revenue]).round(2) %>
            <td class="py-3 pr-4 text-right font-semibold <%= delta_blended.to_f >= 0 ? "text-emerald-700" : "text-rose-700" %>">
              <%= delta_blended.nil? ? "—" : "#{'+' if delta_blended >= 0}#{delta_blended}x" %>
            </td>
            <td class="py-3 pr-4 text-right <%= delta_total_rev >= 0 ? "text-emerald-700" : "text-rose-700" %>">
              <%= number_to_currency(delta_total_rev, precision: 0, format: (delta_total_rev >= 0 ? "+%u%n" : nil)) %>
            </td>
          <% end %>
          <td class="py-3 pr-4 text-right text-gray-600"><%= number_with_delimiter(by_channel.sum { |r| r[:impressions] }) %></td>
          <td class="py-3 pr-4 text-right text-gray-600"><%= number_with_delimiter(by_channel.sum { |r| r[:clicks] }) %></td>
          <td class="py-3 pr-4 text-right text-gray-600">
            <% total_imp = by_channel.sum { |r| r[:impressions] } %>
            <% total_clicks = by_channel.sum { |r| r[:clicks] } %>
            <%= total_imp.positive? ? "#{(total_clicks.to_f / total_imp * 100).round(1)}%" : "—" %>
          </td>
          <td class="py-3 <%= confidence_band_active ? "pr-4" : "" %> text-right text-gray-600">
            <%= total_clicks.positive? ? format_spend(totals[:total_spend_micros] / total_clicks) : "—" %>
          </td>
          <% if confidence_band_active %>
            <td class="py-3 text-right text-gray-400">—</td>
          <% end %>
        </tr>
      </tfoot>
    </table>
  </div>

<% else %>
  <div class="h-32 flex items-center justify-center text-gray-500">
    No spend data for the selected period
  </div>
<% end %>
