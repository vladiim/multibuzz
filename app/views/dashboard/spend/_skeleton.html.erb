<div class="dashboard-section animate-pulse">
  <!-- Hero metrics skeleton -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4 mb-6">
    <% 5.times do %>
      <div class="bg-white p-3 sm:p-5 rounded-lg shadow">
        <div class="h-4 w-20 bg-gray-200 rounded mb-2"></div>
        <div class="h-7 w-16 bg-gray-200 rounded"></div>
      </div>
    <% end %>
  </div>

  <!-- Chart + table skeleton -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-6">
    <div class="lg:col-span-3 bg-white p-6 rounded-lg shadow">
      <div class="h-5 w-40 bg-gray-200 rounded mb-4"></div>
      <div class="h-48 sm:h-64 bg-gray-200 rounded"></div>
    </div>
    <div class="lg:col-span-2 bg-white p-6 rounded-lg shadow">
      <div class="h-5 w-24 bg-gray-200 rounded mb-4"></div>
      <div class="space-y-4">
        <% 4.times do %>
          <div class="flex justify-between">
            <div class="h-4 w-24 bg-gray-200 rounded"></div>
            <div class="h-4 w-12 bg-gray-200 rounded"></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
