<%# Required locals: time_series; optional: compare, filter_params %>
<%
  compare ||= nil
  filter_params ||= {}
  comparing = compare.present? && compare[:time_series].present?
  primary_name = filter_params.dig(:models, 0)&.name&.titleize || "Primary"
  compare_name = filter_params.dig(:models, 1)&.name&.titleize || "Compare"
%>
<div class="lg:col-span-3 bg-white p-4 sm:p-6 rounded-lg shadow">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-base sm:text-lg font-medium text-gray-900">ROAS & Spend Trend</h3>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-0.5 bg-indigo-500 inline-block"></span>
        <span class="text-xs text-gray-500"><%= comparing ? primary_name : "ROAS" %></span>
      </div>
      <% if comparing %>
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-0.5 bg-amber-500 inline-block" style="border-top: 2px dashed #F59E0B; height: 0;"></span>
          <span class="text-xs text-gray-500"><%= compare_name %></span>
        </div>
      <% end %>
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-3 bg-gray-200 rounded-sm inline-block"></span>
        <span class="text-xs text-gray-500">Spend</span>
      </div>
    </div>
  </div>

  <% if time_series.present? %>
    <div id="spend-trend-chart"
      data-controller="chart"
      data-chart-type-value="spend-trend"
      data-chart-data-value="<%= time_series.to_json %>"
      <% if comparing %>
        data-chart-compare-data-value="<%= compare[:time_series].to_json %>"
        data-chart-compare-name-value="<%= compare_name %>"
        data-chart-primary-name-value="<%= primary_name %>"
      <% end %>
      class="h-48 sm:h-64">
    </div>
  <% else %>
    <div class="h-48 sm:h-64 flex items-center justify-center text-gray-500">
      No spend data for the selected period
    </div>
  <% end %>
</div>
