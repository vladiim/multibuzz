<%# Required locals: time_series %>
<div class="lg:col-span-3 bg-white p-4 sm:p-6 rounded-lg shadow">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-base sm:text-lg font-medium text-gray-900">ROAS & Spend Trend</h3>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-0.5 bg-indigo-500 inline-block"></span>
        <span class="text-xs text-gray-500">ROAS</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-3 bg-gray-200 rounded-sm inline-block"></span>
        <span class="text-xs text-gray-500">Spend</span>
      </div>
    </div>
  </div>

  <% if time_series.present? %>
    <div id="spend-trend-chart"
      data-controller="chart"
      data-chart-type-value="spend-trend"
      data-chart-data-value="<%= time_series.to_json %>"
      class="h-48 sm:h-64">
    </div>
  <% else %>
    <div class="h-48 sm:h-64 flex items-center justify-center text-gray-500">
      No spend data for the selected period
    </div>
  <% end %>
</div>
