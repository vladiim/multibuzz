<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>

  <div class="py-6 sm:py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <div class="bg-white shadow sm:rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h1 class="text-xl font-semibold text-gray-900">Select Meta Ads Account</h1>
          <p class="mt-1 text-sm text-gray-500">Pick an ad account, optionally tag it with a property so spend rolls up against your conversions, then connect.</p>
        </div>

        <% if @ad_accounts.any? %>
          <div class="divide-y divide-gray-200">
            <% @ad_accounts.each do |ad_account| %>
              <%= render "oauth/shared/connect_account_row",
                form_url: oauth_meta_ads_create_connection_path,
                hidden_fields: {
                  ad_account_id: ad_account[:id],
                  ad_account_name: ad_account[:name],
                  currency: ad_account[:currency],
                  timezone_name: ad_account[:timezone_name]
                },
                title: ad_account[:name],
                subtitle: "ID: #{ad_account[:id]} · #{ad_account[:currency]}",
                known_keys: @known_metadata_keys %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <% if @error %>
              <p class="text-sm text-red-600"><%= @error %></p>
            <% else %>
              <p class="text-sm text-gray-500">No active Meta ad accounts found. Make sure your Facebook account has access to at least one active ad account.</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
