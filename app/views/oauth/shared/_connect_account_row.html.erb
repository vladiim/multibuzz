<%# locals: form_url, hidden_fields, title, subtitle, known_keys %>
<% datalist_id = "known-keys-#{title.parameterize}" %>
<div class="px-6 py-5">
  <%= form_with url: form_url, method: :post, class: "space-y-4" do |f| %>
    <% hidden_fields.each do |name, value| %>
      <%= hidden_field_tag name, value %>
    <% end %>

    <div>
      <p class="text-sm font-medium text-gray-900"><%= title %></p>
      <p class="text-xs text-gray-500"><%= subtitle %></p>
    </div>

    <div class="rounded-md border border-gray-200 bg-gray-50 p-4 space-y-3" data-controller="toggle" data-toggle-hidden-class="hidden">
      <div class="flex items-start justify-between gap-2">
        <div class="space-y-0.5">
          <p class="text-sm font-medium text-gray-900">Tag this account <span class="font-normal text-gray-500">(optional)</span></p>
          <p class="text-xs text-gray-600">Group spend by location, plan, brand, etc. Use the same key your SDK sends in conversion <code class="bg-white px-1 rounded text-gray-800">properties</code>.</p>
        </div>
        <button type="button"
                data-action="click->toggle#toggle"
                aria-label="What is this for?"
                class="flex-shrink-0 inline-flex items-center justify-center w-5 h-5 rounded-full bg-white border border-gray-300 text-xs text-gray-500 hover:bg-gray-100 hover:text-gray-700 cursor-pointer">i</button>
      </div>

      <div data-toggle-target="content" class="hidden text-xs text-gray-600 bg-white border border-gray-200 rounded p-3 space-y-2">
        <p><strong class="text-gray-900">When to use this:</strong> if you run separate ad accounts for separate slices of your business — one per location, plan, brand — tag each account so mbuzz can roll its spend up against the right conversions.</p>
        <p><strong class="text-gray-900">How it works:</strong> the tag must match a key you send in your SDK's conversion <code class="bg-gray-50 px-1 rounded">properties</code>. e.g. tag this account with <code class="bg-gray-50 px-1 rounded">plan_name: Pro</code>, then send conversions with <code class="bg-gray-50 px-1 rounded">properties: { plan_name: "Pro" }</code>. mbuzz pairs them up.</p>
        <p><strong class="text-gray-900">Skip if:</strong> you only have one ad account, or you don't need to slice ROAS by anything yet. You can always add a tag later from the connection's detail page.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Tag</label>
          <input type="text"
                 name="metadata_key"
                 placeholder="e.g. plan_name"
                 list="<%= datalist_id %>"
                 class="block w-full text-sm rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2">
          <% if known_keys.any? %>
            <datalist id="<%= datalist_id %>">
              <% known_keys.each do |k| %>
                <option value="<%= k %>"></option>
              <% end %>
            </datalist>
          <% end %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Value</label>
          <input type="text"
                 name="metadata_value"
                 placeholder="e.g. Pro"
                 class="block w-full text-sm rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2">
        </div>
      </div>
    </div>

    <div>
      <button type="submit"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer">
        Connect <%= title %>
      </button>
    </div>
  <% end %>
</div>
