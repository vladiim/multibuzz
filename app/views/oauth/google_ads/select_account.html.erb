<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>

  <div class="py-6 sm:py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <div class="bg-white shadow sm:rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h1 class="text-xl font-semibold text-gray-900">Select Google Ads Account</h1>
          <p class="mt-1 text-sm text-gray-500">Pick an account, optionally tag it with a property so spend rolls up against your conversions, then connect.</p>
        </div>

        <% if @customers.any? %>
          <div class="divide-y divide-gray-200">
            <% @customers.each do |customer| %>
              <%= render "oauth/shared/connect_account_row",
                form_url: oauth_google_ads_create_connection_path,
                hidden_fields: {
                  customer_id: customer[:id],
                  customer_name: customer[:name],
                  currency: customer[:currency],
                  login_customer_id: customer[:login_customer_id]
                },
                title: customer[:name],
                subtitle: "ID: #{customer[:id]} · #{customer[:currency]}",
                known_keys: @known_metadata_keys %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <% if @error %>
              <p class="text-sm text-red-600"><%= @error %></p>
            <% else %>
              <p class="text-sm text-gray-500">No Google Ads accounts found. Make sure your Google account has access to at least one non-manager Google Ads account.</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
