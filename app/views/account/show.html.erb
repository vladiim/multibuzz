<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>

  <div class="py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-8">
        <%= render "layouts/account_nav" %>

        <div class="flex-1">
          <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-5 border-b border-gray-200">
              <h1 class="text-xl font-semibold text-gray-900">General Settings</h1>
            </div>

            <%= form_with model: current_account, url: account_path, method: :patch, class: "divide-y divide-gray-200" do |f| %>
              <div class="px-6 py-5 space-y-6">
                <div>
                  <%= f.label :name, "Account Name", class: "block text-sm font-medium text-gray-700" %>
                  <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                  <% if current_account.errors[:name].any? %>
                    <p class="mt-1 text-sm text-red-600"><%= current_account.errors[:name].first %></p>
                  <% end %>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700">Account ID</label>
                  <p class="mt-1 text-sm text-gray-500 font-mono"><%= current_account.prefix_id %></p>
                </div>

                <div>
                  <%= f.label :billing_email, "Billing Email", class: "block text-sm font-medium text-gray-700" %>
                  <%= f.email_field :billing_email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: current_user.email %>
                  <p class="mt-1 text-xs text-gray-500">Invoices and billing notifications will be sent to this address. Defaults to your login email if blank.</p>
                </div>
              </div>

              <!-- Data Mode Section -->
              <div class="px-6 py-5">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <label class="block text-sm font-medium text-gray-700">Data Mode</label>
                    <p class="mt-1 text-sm text-gray-500">
                      <% if current_account.live_mode_enabled? %>
                        <span class="inline-flex items-center gap-1.5">
                          <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                          <span class="font-medium text-green-700">Live Mode</span>
                        </span>
                        — Dashboard shows production data by default.
                      <% else %>
                        <span class="inline-flex items-center gap-1.5">
                          <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
                          <span class="font-medium text-amber-700">Test Mode</span>
                        </span>
                        — Dashboard shows test data by default.
                      <% end %>
                    </p>
                  </div>
                  <div class="ml-4">
                    <label class="relative inline-flex items-center cursor-pointer">
                      <%= f.check_box :live_mode_enabled,
                        class: "sr-only peer",
                        data: { action: "change->auto-submit#submit" } %>
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                  </div>
                </div>
                <p class="mt-3 text-xs text-gray-500">
                  Enable live mode once your SDK is sending production events. You can still view test data by switching modes in settings.
                </p>
              </div>

              <div class="px-6 py-4 bg-gray-50 rounded-b-lg">
                <%= f.submit "Save Changes", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
