<div class="min-h-screen bg-gray-50 py-12">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Progress -->
    <div class="mb-8">
      <div class="flex items-center justify-between text-sm text-gray-500 mb-2">
        <span>Step 3 of 5</span>
        <div class="flex items-center gap-4">
          <span><%= current_account.onboarding_percentage %>% complete</span>
          <%= button_to "Skip setup →", onboarding_skip_path, method: :post, class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
        </div>
      </div>
      <div class="h-2 bg-gray-200 rounded-full">
        <div class="h-2 bg-indigo-600 rounded-full" style="width: <%= current_account.onboarding_percentage %>%"></div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-8">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-2xl font-semibold text-gray-900">
          <%= current_sdk.platform? ? "Set up #{current_sdk.display_name}" : "Install the #{current_sdk.display_name} SDK" %>
        </h2>
        <% if current_sdk.github_url.present? %>
          <%= link_to current_sdk.github_url, target: "_blank", rel: "noopener", class: "flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900" do %>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
            View on GitHub
          <% end %>
        <% end %>
      </div>
      <p class="text-gray-600 mb-6">Follow these steps to start tracking events.</p>

      <% if current_sdk.custom_install? %>
        <%= render "onboarding/install_#{current_sdk.key}" %>
      <% else %>
        <%= render "onboarding/install_server_side" %>
      <% end %>

      <!-- Next Step -->
      <div class="pt-6 border-t border-gray-200 flex justify-between">
        <%= link_to "← Back", onboarding_setup_path, class: "text-gray-600 hover:text-gray-900" %>
        <%= link_to "I've completed the setup →", onboarding_verify_path, class: "px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700" %>
      </div>
    </div>

    <%= render "onboarding/skip_banner" %>
  </div>
</div>
