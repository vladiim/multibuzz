<div class="min-h-screen bg-gray-50 py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-3xl" data-testid="payment-setup">
    <div class="text-center">
      <h2 class="text-3xl font-extrabold text-gray-900">Pay for your Guided Setup</h2>
      <p class="mt-2 text-lg text-gray-600">
        $1,500 today. The full amount becomes mbuzz credit on your account and covers your plan's invoices.
      </p>
    </div>

    <%= form_with url: onboarding_start_payment_path, method: :post, data: { turbo: false } do %>
      <fieldset class="mt-8">
        <legend class="text-sm font-semibold text-gray-900 mb-3">Choose your plan</legend>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% @plans.each do |plan| %>
            <label class="bg-white p-5 rounded-lg shadow-sm border border-gray-200 hover:border-indigo-400 cursor-pointer flex flex-col">
              <div class="flex items-start gap-3">
                <%= radio_button_tag "plan_slug", plan.slug, plan == recommended_plan, class: "mt-1" %>
                <div>
                  <div class="text-base font-semibold text-gray-900"><%= plan.name %></div>
                  <div class="text-xs text-gray-500"><%= plan.formatted_events %> events / month</div>
                </div>
              </div>
              <div class="mt-3 text-2xl font-bold text-gray-900">
                <%= plan.formatted_price %><span class="text-sm font-normal text-gray-500">/mo</span>
              </div>
              <% if plan == recommended_plan %>
                <div class="mt-2 text-xs font-semibold text-indigo-600">Recommended for you</div>
              <% end %>
            </label>
          <% end %>
        </div>
      </fieldset>

      <div class="mt-6 bg-indigo-50 border border-indigo-100 rounded-lg p-5 text-sm text-indigo-900">
        <p class="font-semibold">$1,500 today, applied as credit to your plan.</p>
        <ul class="mt-2 list-disc list-inside space-y-1">
          <li>The full amount is credited back to your account and drawn down by your plan's invoices.</li>
          <li>Non-refundable. Unused credit is forfeited if you cancel.</li>
        </ul>
      </div>

      <div class="mt-6 text-right">
        <%= submit_tag "Pay $1,500", class: "px-6 py-3 bg-indigo-600 text-white rounded-md shadow-sm hover:bg-indigo-700 cursor-pointer font-semibold" %>
      </div>
    <% end %>
  </div>
</div>
