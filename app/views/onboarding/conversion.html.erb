<div class="min-h-screen bg-gray-50 py-12">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Progress -->
    <div class="mb-8">
      <div class="flex items-center justify-between text-sm text-gray-500 mb-2">
        <span>Step 5 of 5</span>
        <div class="flex items-center gap-4">
          <span><%= current_account.onboarding_percentage %>% complete</span>
          <%= button_to "Skip setup →", onboarding_skip_path, method: :post, class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
        </div>
      </div>
      <div class="h-2 bg-gray-200 rounded-full">
        <div class="h-2 bg-indigo-600 rounded-full" style="width: <%= current_account.onboarding_percentage %>%"></div>
      </div>
    </div>

    <!-- Success Banner -->
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-8 flex items-center">
      <svg class="w-6 h-6 text-green-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      <span class="text-green-800 font-medium">Event received!</span>
    </div>

    <div class="bg-white rounded-lg shadow p-8">
      <h2 class="text-2xl font-semibold text-gray-900 mb-2">Track Conversions</h2>
      <p class="text-gray-600 mb-6">Now let's track when users convert (purchase, sign up, etc.)</p>

      <div class="mb-8">
        <h3 class="text-lg font-medium text-gray-900 mb-3">Add conversion tracking</h3>
        <% if current_sdk.conversion_code.present? %>
          <div class="bg-gray-900 rounded-lg p-4 overflow-x-auto">
            <pre class="text-green-400 text-sm"><%= current_sdk.conversion_code %></pre>
          </div>
        <% end %>
      </div>

      <div class="pt-6 border-t border-gray-200 flex justify-between">
        <%= link_to "← Back", onboarding_verify_path, class: "text-gray-600 hover:text-gray-900" %>
        <%= link_to "View Attribution →", onboarding_attribution_path, class: "px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700" %>
      </div>
    </div>

    <%= render "onboarding/skip_banner" %>
  </div>
</div>
