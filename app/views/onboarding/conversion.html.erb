<%= turbo_stream_from "onboarding_#{current_account.prefix_id}" %>

<div class="py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <%# Inline success marker (event landed); replaces the old green banner. %>
    <p class="text-sm font-medium text-green-700 inline-flex items-center gap-1.5">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      Event received
    </p>

    <h2 class="mt-2 text-2xl sm:text-3xl font-bold text-gray-900">Track conversions</h2>
    <p class="mt-2 text-base sm:text-lg text-gray-600">
      Now let's track when users convert (purchase, sign up, etc.).
      <button data-controller="modal" data-action="click->modal#open" data-modal-target-value="events-vs-conversions-modal" class="text-indigo-600 underline cursor-pointer">What counts as a conversion?</button>
    </p>

    <%= turbo_frame_tag "conversion_status" do %>
      <div class="mt-6 sm:mt-8 bg-white border border-gray-200 rounded-lg shadow-sm p-4 sm:p-5">
        <h3 class="text-base font-semibold text-gray-900 mb-3">Add conversion tracking</h3>
        <% if current_sdk.conversion_code.present? %>
          <div class="bg-slate-900 rounded-md p-4 overflow-x-auto">
            <pre class="hljs text-sm leading-relaxed" data-controller="code-highlight" data-code-highlight-language-value="ruby"><%= current_sdk.conversion_code %></pre>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex items-center justify-between">
        <%= link_to "← Back", onboarding_verify_path, data: { turbo_frame: "_top" }, class: "text-sm text-gray-600 hover:text-gray-900" %>
        <%= link_to "View attribution", onboarding_attribution_path, data: { turbo_frame: "_top" }, class: "px-5 py-2.5 bg-indigo-600 text-white rounded-md shadow-sm font-medium hover:bg-indigo-700" %>
      </div>
    <% end %>
  </div>
</div>

<%= render "shared/events_vs_conversions_modal" %>
