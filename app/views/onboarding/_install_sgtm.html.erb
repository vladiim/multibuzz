<div class="space-y-8">
  <!-- Prerequisites -->
  <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
    <p class="text-amber-800 text-sm">
      <strong>Prerequisite:</strong> You need a server-side GTM container running on your own domain (e.g. <code class="bg-amber-100 px-1 rounded">gtm.yourdomain.com</code>). If you don't have one yet, see
      <a href="https://developers.google.com/tag-platform/tag-manager/server-side" target="_blank" rel="noopener" class="text-amber-900 underline">Google's sGTM setup guide</a>.
    </p>
  </div>

  <!-- Step 1: Import Tag Template -->
  <div class="border border-gray-200 rounded-lg p-6">
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-semibold">1</div>
      <div class="flex-1">
        <h3 class="text-lg font-medium text-gray-900 mb-2">Import the mbuzz Tag Template</h3>
        <p class="text-gray-600 mb-4">Add the mbuzz tag to your server-side GTM container.</p>

        <ol class="list-decimal list-inside space-y-2 text-gray-700 mb-4">
          <li>Open your <strong>server-side</strong> GTM container</li>
          <li>Go to <strong>Templates</strong> → <strong>Tag Templates</strong> → <strong>Search Gallery</strong></li>
          <li>Search for <strong>mbuzz</strong> and click <strong>Add to workspace</strong></li>
          <li>Click <strong>Add</strong> to confirm</li>
        </ol>

        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-sm text-gray-600">
          <strong>Alternative:</strong> Import manually from
          <a href="https://github.com/mbuzzco/mbuzz-sgtm" target="_blank" rel="noopener" class="text-indigo-600 hover:text-indigo-800">github.com/mbuzzco/mbuzz-sgtm</a>
          using <strong>Templates</strong> → <strong>New</strong> → <strong>Import</strong>.
        </div>
      </div>
    </div>
  </div>

  <!-- Step 2: Create Session Tag -->
  <div class="border border-gray-200 rounded-lg p-6">
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-semibold">2</div>
      <div class="flex-1">
        <h3 class="text-lg font-medium text-gray-900 mb-2">Create the Session Tag</h3>
        <p class="text-gray-600 mb-4">This tag fires on every page view to create visitors and sessions with attribution data.</p>

        <ol class="list-decimal list-inside space-y-2 text-gray-700 mb-4">
          <li>Go to <strong>Tags</strong> → <strong>New</strong></li>
          <li>Name it <code class="bg-gray-100 px-1 rounded">mbuzz - Session</code></li>
          <li>Choose <strong>mbuzz - Server-Side Attribution</strong> as the tag type</li>
          <li>Configure:</li>
        </ol>

        <div class="bg-gray-50 rounded-lg p-4 mb-4">
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="py-2 font-medium text-gray-700 w-40">Call Type</td>
                <td class="py-2"><code class="bg-gray-100 px-1 rounded">Session</code></td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-2 font-medium text-gray-700">API Key</td>
                <td class="py-2">Your mbuzz API key (below)</td>
              </tr>
              <tr>
                <td class="py-2 font-medium text-gray-700">Trigger</td>
                <td class="py-2"><code class="bg-gray-100 px-1 rounded">Page View</code> (the default "All Pages" trigger)</td>
              </tr>
            </tbody>
          </table>
        </div>

        <% if @plaintext_api_key.present? %>
          <div class="bg-slate-900 rounded-lg p-4 mb-4" data-controller="clipboard">
            <div class="flex items-center justify-between">
              <code class="text-green-400 text-sm font-mono break-all" data-clipboard-target="source"><%= @plaintext_api_key %></code>
              <button type="button" data-action="click->clipboard#copy" data-clipboard-target="button" class="ml-3 px-3 py-1 bg-slate-700 hover:bg-slate-600 text-white text-xs rounded">
                <span data-clipboard-target="label">Copy</span>
              </button>
            </div>
          </div>
        <% else %>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
            <p class="text-amber-800 text-sm mb-2">Your API key is hidden for security. Regenerate to see the full key.</p>
            <%= button_to "Regenerate API Key", onboarding_regenerate_api_key_path, method: :post, class: "px-3 py-1.5 bg-amber-600 hover:bg-amber-700 text-white text-sm font-medium rounded" %>
          </div>
        <% end %>

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 text-sm text-blue-800">
          <strong>Important:</strong> The session tag must fire <strong>before</strong> any event or conversion tags. Use tag sequencing or firing priority to ensure this.
        </div>
      </div>
    </div>
  </div>

  <!-- Step 3: Create Event Tag (optional) -->
  <div class="border border-gray-200 rounded-lg p-6">
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-semibold">3</div>
      <div class="flex-1">
        <h3 class="text-lg font-medium text-gray-900 mb-2">Create Event Tags <span class="text-sm font-normal text-gray-500">(optional)</span></h3>
        <p class="text-gray-600 mb-4">Track custom events like form submissions, button clicks, or scroll depth.</p>

        <ol class="list-decimal list-inside space-y-2 text-gray-700 mb-4">
          <li>Go to <strong>Tags</strong> → <strong>New</strong></li>
          <li>Name it <code class="bg-gray-100 px-1 rounded">mbuzz - Event</code></li>
          <li>Choose <strong>mbuzz - Server-Side Attribution</strong></li>
          <li>Set Call Type to <code class="bg-gray-100 px-1 rounded">Event</code></li>
          <li>Set Event Type (e.g. <code class="bg-gray-100 px-1 rounded">form_submit</code>)</li>
          <li>Add a trigger for the specific event</li>
        </ol>

        <p class="text-sm text-gray-500">Repeat for each event type you want to track.</p>
      </div>
    </div>
  </div>

  <!-- Step 4: Create Conversion Tag -->
  <div class="border border-gray-200 rounded-lg p-6">
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-semibold">4</div>
      <div class="flex-1">
        <h3 class="text-lg font-medium text-gray-900 mb-2">Create Conversion Tag</h3>
        <p class="text-gray-600 mb-4">Track conversions to calculate multi-touch attribution.</p>

        <ol class="list-decimal list-inside space-y-2 text-gray-700 mb-4">
          <li>Go to <strong>Tags</strong> → <strong>New</strong></li>
          <li>Name it <code class="bg-gray-100 px-1 rounded">mbuzz - Conversion</code></li>
          <li>Choose <strong>mbuzz - Server-Side Attribution</strong></li>
          <li>Set Call Type to <code class="bg-gray-100 px-1 rounded">Conversion</code></li>
          <li>Set Conversion Type (e.g. <code class="bg-gray-100 px-1 rounded">purchase</code> or <code class="bg-gray-100 px-1 rounded">lead</code>)</li>
          <li>Set Revenue and Currency if applicable</li>
          <li>Add a trigger for your conversion event</li>
        </ol>
      </div>
    </div>
  </div>

  <!-- Step 5: Test -->
  <div class="border border-gray-200 rounded-lg p-6">
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-semibold">5</div>
      <div class="flex-1">
        <h3 class="text-lg font-medium text-gray-900 mb-2">Test in Preview Mode</h3>
        <p class="text-gray-600 mb-4">Verify everything works before publishing.</p>

        <ol class="list-decimal list-inside space-y-2 text-gray-700">
          <li>Click <strong>Preview</strong> in your sGTM container</li>
          <li>Visit your website in a new tab</li>
          <li>In the preview panel, confirm the mbuzz Session tag fired</li>
          <li>Trigger a conversion and confirm the Conversion tag fired</li>
          <li>Check your <strong>mbuzz dashboard</strong> for the new session and events</li>
          <li>If everything looks good, click <strong>Submit</strong> to publish</li>
        </ol>
      </div>
    </div>
  </div>

  <!-- Docs link -->
  <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-sm text-gray-700">
    For detailed tag configuration, trigger setup, consent mode, and troubleshooting, see the
    <a href="<%= docs_path('integrations-sgtm') %>" class="text-indigo-600 hover:text-indigo-800 font-medium">full sGTM documentation</a>.
  </div>
</div>
