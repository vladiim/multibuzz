<div class="py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Let's get started</h2>
    <p class="mt-2 text-base sm:text-lg text-gray-600">4 quick questions</p>

    <%= form_with url: onboarding_discovery_path, method: :post, data: { testid: "discovery-form" } do %>
      <div class="mt-6 sm:mt-8 bg-white border border-gray-200 rounded-lg shadow-sm p-4 sm:p-5 space-y-6">
        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">1 &middot; What are you trying to attribute?</legend>
          <% [ [ "Ecommerce purchases", "ecommerce" ], [ "B2B leads & deals", "b2b_leads" ], [ "Signups & subscriptions", "signups" ] ].each do |label, value| %>
            <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
              <%= check_box_tag "setup_profile[attribution_goal][]", value %>
              <%= label %>
            </label>
          <% end %>
          <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
            Other:
            <%= text_field_tag "setup_profile[attribution_goal_other]", nil, placeholder: "type your answer", class: "border border-gray-300 rounded-md shadow-sm px-3 py-1.5 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </label>
        </fieldset>

        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">2 &middot; Where do you run ads?</legend>
          <% [ [ "Meta", "meta" ], [ "Google Ads", "google_ads" ], [ "TikTok", "tiktok" ], [ "LinkedIn", "linkedin" ], [ "None", "none" ] ].each do |label, value| %>
            <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
              <%= check_box_tag "setup_profile[ad_platforms][]", value %>
              <%= label %>
            </label>
          <% end %>
          <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
            Other:
            <%= text_field_tag "setup_profile[ad_platforms_other]", nil, placeholder: "type your answer", class: "border border-gray-300 rounded-md shadow-sm px-3 py-1.5 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </label>
        </fieldset>

        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">3 &middot; Which platform/s do you use?</legend>
          <% [ [ "Ruby", "ruby" ], [ "Python", "python" ], [ "Node.js", "node" ], [ "PHP", "php" ], [ "Server-side GTM", "sgtm" ], [ "Shopify", "shopify" ], [ "Magento", "magento" ], [ "REST API", "rest_api" ] ].each do |label, value| %>
            <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
              <%= check_box_tag "setup_profile[install_platforms][]", value %>
              <%= label %>
            </label>
          <% end %>
          <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
            Other:
            <%= text_field_tag "setup_profile[install_platforms_other]", nil, placeholder: "type your answer", class: "border border-gray-300 rounded-md shadow-sm px-3 py-1.5 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </label>
          <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
            <%= check_box_tag "setup_profile[install_platforms][]", "unsure" %>
            I'm not sure yet
          </label>
        </fieldset>

        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">4 &middot; Roughly how much do you spend on ads per month?</legend>
          <% [ [ "Under $5k", "under_5k" ], [ "$5k - $25k", "5k_25k" ], [ "$25k - $100k", "25k_100k" ], [ "$100k+", "over_100k" ] ].each do |label, value| %>
            <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
              <%= radio_button_tag "setup_profile[monthly_ad_spend]", value %>
              <%= label %>
            </label>
          <% end %>
          <label class="flex items-center gap-2 py-1 text-sm text-gray-700">
            <%= radio_button_tag "setup_profile[monthly_ad_spend]", "other" %>
            Other:
            <%= text_field_tag "setup_profile[monthly_ad_spend_other]", nil, placeholder: "type your answer", class: "border border-gray-300 rounded-md shadow-sm px-3 py-1.5 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </label>
        </fieldset>
      </div>

      <div class="mt-6 text-right">
        <%= submit_tag "Continue", class: "px-5 py-2.5 bg-indigo-600 text-white rounded-md shadow-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
