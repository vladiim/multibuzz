<%= turbo_stream_from "onboarding_#{current_account.prefix_id}" %>

<div class="min-h-screen bg-gray-50 py-12">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Progress -->
    <div class="mb-8">
      <div class="flex items-center justify-between text-sm text-gray-500 mb-2">
        <span>Step 4 of 5</span>
        <div class="flex items-center gap-4">
          <span><%= current_account.onboarding_percentage %>% complete</span>
          <%= button_to "Skip setup →", onboarding_skip_path, method: :post, data: { turbo_frame: "_top" }, class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
        </div>
      </div>
      <div class="h-2 bg-gray-200 rounded-full">
        <div class="h-2 bg-indigo-600 rounded-full" style="width: <%= current_account.onboarding_percentage %>%"></div>
      </div>
    </div>

    <%= turbo_frame_tag "verification_status", src: onboarding_event_status_path, data: { turbo_stream: true } do %>
      <div class="bg-white rounded-lg shadow p-8 text-center" data-verification>
        <div class="mx-auto w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-indigo-600 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>

        <h2 class="text-2xl font-semibold text-gray-900 mb-2">Waiting for your first event</h2>

        <% if current_sdk.platform? %>
          <p class="text-gray-600 mb-6">Events will appear once visitors interact with your store.</p>
          <div class="bg-gray-50 rounded-lg p-4 text-left text-sm text-gray-700">
            <p class="font-medium mb-2">To trigger a test event:</p>
            <ol class="list-decimal list-inside space-y-1">
              <li>Visit your storefront in a new browser/incognito window</li>
              <li>Add an item to cart and begin checkout</li>
              <li>Events will appear here within a few seconds</li>
            </ol>
          </div>
        <% else %>
          <p class="text-gray-600 mb-6">Run the code below in your application.</p>
          <div class="bg-slate-900 rounded-lg p-4 font-mono text-sm text-left">
            <code class="hljs" data-controller="code-highlight" data-code-highlight-language-value="<%= syntax_language_for(current_sdk) %>"><%= current_sdk.verification_command || current_sdk.event_code&.split("\n")&.first %></code>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= render "onboarding/skip_banner" %>
  </div>
</div>
