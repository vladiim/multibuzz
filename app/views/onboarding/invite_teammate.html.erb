<div class="min-h-screen bg-gray-50 py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-2xl flex justify-end gap-2 mb-4">
    <%= button_to "← Change setup option", onboarding_change_setup_path_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <%= button_to "Skip setup →", onboarding_skip_path, method: :post, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
  </div>

  <div class="sm:mx-auto sm:w-full sm:max-w-2xl">
    <h2 class="text-center text-3xl font-extrabold text-gray-900">Invite the teammate who'll install mbuzz</h2>
    <p class="mt-2 text-center text-lg text-gray-600">
      They'll get an email with everything they need: the API key, the SDK, the install steps.
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-2xl px-4">
    <% if @invited_email.present? && @invite_error.blank? %>
      <div class="bg-white p-6 rounded-lg shadow text-center" data-testid="teammate-invite-sent">
        <div class="text-4xl mb-3">📨</div>
        <h3 class="text-xl font-semibold text-gray-900">Invite sent to <%= @invited_email %></h3>
        <p class="mt-2 text-sm text-gray-600">
          We'll let you know when they accept. You can invite more teammates or head to the dashboard.
        </p>
        <div class="mt-6 flex justify-center gap-3">
          <%= link_to "Invite another", onboarding_invite_teammate_path, class: "px-5 py-2 border border-gray-300 text-sm rounded-md text-gray-700 hover:bg-gray-50" %>
          <%= link_to "Go to dashboard", dashboard_path, class: "px-5 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 text-sm" %>
        </div>
      </div>
    <% else %>
      <%= form_with url: onboarding_send_teammate_invite_path, method: :post, local: true, data: { testid: "teammate-invite-form" } do %>
        <div class="bg-white p-6 rounded-lg shadow">
          <% if @invite_error.present? %>
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md text-sm text-red-700">
              <%= @invite_error %>
            </div>
          <% end %>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">Teammate's email</label>
            <input type="email" name="email" id="email" required value="<%= @invited_email %>"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
              placeholder="developer@yourcompany.com">
          </div>

          <div class="mt-4">
            <label for="role" class="block text-sm font-medium text-gray-700">Role</label>
            <select name="role" id="role"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
              <option value="admin" selected>Admin (recommended for the person installing)</option>
              <option value="member">Member</option>
            </select>
          </div>
        </div>

        <div class="mt-6 text-right">
          <%= submit_tag "Send invite", class: "px-6 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
