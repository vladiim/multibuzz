<div class="py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <% if @invited_email.present? && @invite_error.blank? %>
      <div data-testid="teammate-invite-sent">
        <%= render "shared/success_state",
              emoji: "📨",
              heading: "Invite sent to #{@invited_email}",
              body: "We'll let you know when they accept. You can invite more teammates or head to the dashboard.",
              primary_cta_label: "Go to dashboard",
              primary_cta_path: dashboard_path,
              secondary_cta_label: "Invite another",
              secondary_cta_path: onboarding_invite_teammate_path %>
      </div>
    <% else %>
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Invite the teammate who'll install mbuzz</h2>
      <p class="mt-2 text-base sm:text-lg text-gray-600">They'll get an email with everything they need: the API key, the SDK, the install steps.</p>

      <%= form_with url: onboarding_send_teammate_invite_path, method: :post, data: { turbo: false, testid: "teammate-invite-form" } do %>
        <div class="mt-6 sm:mt-8 bg-white border border-gray-200 rounded-lg shadow-sm p-4 sm:p-5 space-y-4">
          <% if @invite_error.present? %>
            <div class="p-3 bg-red-50 border border-red-200 rounded-md text-sm text-red-700">
              <%= @invite_error %>
            </div>
          <% end %>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Teammate's email</label>
            <input type="email" name="email" id="email" required value="<%= @invited_email %>"
              class="block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
              placeholder="developer@yourcompany.com">
          </div>

          <div>
            <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Role</label>
            <select name="role" id="role"
              class="block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
              <option value="admin" selected>Admin (recommended for the person installing)</option>
              <option value="member">Member</option>
            </select>
          </div>
        </div>

        <div class="mt-6 text-right">
          <%= submit_tag "Send invite", class: "px-5 py-2.5 bg-indigo-600 text-white rounded-md shadow-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
