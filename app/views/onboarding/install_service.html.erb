<div class="min-h-screen bg-gray-50 py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-3xl text-right mb-4">
    <%= button_to "← Change setup option", onboarding_change_setup_path_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="sm:mx-auto sm:w-full sm:max-w-3xl" data-testid="install-service">
    <div class="text-center">
      <h2 class="text-3xl font-extrabold text-gray-900">Install service inclusions</h2>
      <p class="mt-2 text-lg text-gray-600">Here's what we'll do, when you pay, and what it costs.</p>
    </div>

    <div class="mt-10">
      <h3 class="text-lg font-semibold text-gray-900">What happens next</h3>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
          <div class="text-sm font-semibold text-indigo-600">1 &middot; Kickoff call</div>
          <p class="mt-1 text-sm text-gray-600">Agree goals and the value moment you want to see.</p>
        </div>
        <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
          <div class="text-sm font-semibold text-indigo-600">2 &middot; Install</div>
          <p class="mt-1 text-sm text-gray-600">We install the four mbuzz API calls in your stack.</p>
        </div>
        <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
          <div class="text-sm font-semibold text-indigo-600">3 &middot; Integration</div>
          <p class="mt-1 text-sm text-gray-600">Connect Meta Ads, Google Ads, or server-side GTM. We'll build one for you if you don't have one.</p>
        </div>
        <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
          <div class="text-sm font-semibold text-indigo-600">4 &middot; Training &amp; value check</div>
          <p class="mt-1 text-sm text-gray-600">Dashboard walkthrough plus a 30-day check-in.</p>
        </div>
      </div>
    </div>

    <div class="mt-10">
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 space-y-1">
        <p class="text-2xl font-bold text-gray-900">Price: $1,500 USD</p>
        <p class="text-sm text-gray-600">Non-refundable mbuzz credit</p>
        <p class="text-sm text-gray-600">Payment due after the kickoff call</p>
      </div>
    </div>

    <div class="mt-8 text-right">
      <%= link_to "Continue", onboarding_discovery_path,
        class: "inline-block px-6 py-3 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 font-semibold" %>
    </div>
  </div>
</div>
