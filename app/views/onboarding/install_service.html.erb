<div class="min-h-screen bg-gray-50 py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-4xl text-right mb-4">
    <%= button_to "← Change setup option", onboarding_change_setup_path_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="sm:mx-auto sm:w-full sm:max-w-4xl" data-testid="install-service">

    <%# ── Title ── %>
    <div class="text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight">mbuzz install service</h2>
    </div>

    <%# ── What you get ── %>
    <div class="mt-12">
      <h3 class="text-2xl font-bold text-gray-900">What you get</h3>

      <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <div class="flex items-center gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-50 text-indigo-700 font-bold flex items-center justify-center">1</span>
            <h4 class="text-base font-semibold text-gray-900">Kickoff call</h4>
          </div>
          <p class="mt-3 text-sm text-gray-600 leading-relaxed">
            60-minute working session. We agree your value moment, the conversions that matter, and which ad platforms to wire up first.
          </p>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <div class="flex items-center gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-50 text-indigo-700 font-bold flex items-center justify-center">2</span>
            <h4 class="text-base font-semibold text-gray-900">We write the code</h4>
          </div>
          <p class="mt-3 text-sm text-gray-600 leading-relaxed">
            The four mbuzz API calls (session, event, conversion, identify) installed in your stack. Ruby, Node, Python, PHP, sGTM, Shopify, or plain REST.
          </p>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <div class="flex items-center gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-50 text-indigo-700 font-bold flex items-center justify-center">3</span>
            <h4 class="text-base font-semibold text-gray-900">Ad platform integration</h4>
          </div>
          <p class="mt-3 text-sm text-gray-600 leading-relaxed">
            We connect Meta Ads, Google Ads, or server-side GTM in your account. If you don't have an integration yet, we'll build one for you as part of this. No extra fee.
          </p>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
          <div class="flex items-center gap-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-50 text-indigo-700 font-bold flex items-center justify-center">4</span>
            <h4 class="text-base font-semibold text-gray-900">Test, train, follow up</h4>
          </div>
          <p class="mt-3 text-sm text-gray-600 leading-relaxed">
            We watch the first real events land in production, walk you through the dashboard, and check back at 30 days to make sure attribution is doing what you hired it to do.
          </p>
        </div>
      </div>
    </div>

    <%# ── The credit (the kicker) ── %>
    <div class="mt-14 relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-600 to-indigo-800 text-white p-6 sm:p-12 shadow-2xl">
      <div class="relative">
        <p class="text-3xl sm:text-5xl font-extrabold leading-tight tracking-tight">
          $1,500 setup.<br>
          $1,500 mbuzz credit.<br>
          <span class="text-indigo-200">Net cost: $0.</span>
        </p>
        <p class="mt-6 text-lg text-indigo-100 leading-relaxed max-w-2xl">
          The $1,500 you pay lands straight back on your account as credit and burns down against your monthly subscription as you use it. It's prepaid mbuzz, with the install thrown in for free.
        </p>

        <div class="mt-8 pt-8 border-t border-indigo-400/30 grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div>
            <p class="text-3xl font-bold">≈ 5 months</p>
            <p class="mt-1 text-sm text-indigo-200">of Pro ($299/mo)</p>
          </div>
          <div>
            <p class="text-3xl font-bold">≈ 15 months</p>
            <p class="mt-1 text-sm text-indigo-200">of Growth ($99/mo)</p>
          </div>
          <div>
            <p class="text-3xl font-bold">~ 4 years</p>
            <p class="mt-1 text-sm text-indigo-200">of Starter ($29/mo)</p>
          </div>
        </div>
      </div>
    </div>

    <%# ── Risk reversal / fine print ── %>
    <div class="mt-8 bg-white rounded-xl border border-gray-200 p-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
        <div class="flex items-start gap-2">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-semibold text-gray-900">One-off</p>
            <p class="text-gray-600">No contract. No lock-in. No retainer.</p>
          </div>
        </div>
        <div class="flex items-start gap-2">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-semibold text-gray-900">Pay after the call</p>
            <p class="text-gray-600">You only commit once the kickoff has happened and the plan is agreed.</p>
          </div>
        </div>
        <div class="flex items-start gap-2">
          <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-semibold text-gray-900">Non-refundable</p>
            <p class="text-gray-600">Non-refundable payment, due after the kickoff call. The credit covers it.</p>
          </div>
        </div>
      </div>
    </div>

    <%# ── CTA ── %>
    <div class="mt-10 flex justify-end">
      <%= link_to onboarding_discovery_path,
        class: "inline-flex items-center justify-center gap-2 w-full sm:w-auto px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-semibold shadow-sm transition-colors" do %>
        Continue
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      <% end %>
    </div>
  </div>
</div>
