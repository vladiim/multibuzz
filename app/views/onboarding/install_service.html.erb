<div class="py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto" data-testid="install-service">

    <%# Title %>
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight text-center">mbuzz install service</h2>

    <%# What you get %>
    <div class="mt-8 sm:mt-10">
      <h3 class="text-base font-semibold text-gray-900 mb-3 sm:mb-4">What you get</h3>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <% [
          [ 1, "Kickoff call", "30-minute working session. We define your value moment, the conversions that matter, and which ad platforms to wire up first." ],
          [ 2, "We write the code", "The four mbuzz API calls (session, event, conversion, identify) installed in your stack. Ruby, Node, Python, PHP, sGTM, or plain REST." ],
          [ 3, "Ad platform integration", "You connect Meta Ads or Google Ads. If we don't support your platform yet, we'll build and implement the integration for you as part of this. No extra fee." ],
          [ 4, "Test, train, follow up", "We watch the first real events land in production, walk you through the dashboard, and check back at 30 days to make sure attribution is doing what you hired it to do." ]
        ].each do |number, title, body| %>
          <div class="bg-white p-4 sm:p-5 rounded-lg shadow-sm border border-gray-200">
            <div class="flex items-center gap-3">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-indigo-50 text-indigo-700 font-bold text-sm flex items-center justify-center"><%= number %></span>
              <h4 class="text-base font-semibold text-gray-900"><%= title %></h4>
            </div>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed"><%= body %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# The credit (the kicker) -- sanctioned gradient promo, per DESIGN_SYSTEM §2.3 %>
    <div class="mt-8 sm:mt-10 overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-600 to-indigo-800 text-white p-6 sm:p-10 shadow-lg">
      <p class="text-2xl sm:text-4xl font-bold leading-tight tracking-tight">
        $1,500 USD setup.<br>
        $1,500 mbuzz credit.<br>
        <span class="text-indigo-200">Net cost: $0.</span>
      </p>
      <p class="mt-4 sm:mt-5 text-sm sm:text-base text-indigo-100 leading-relaxed">
        The $1,500 you pay lands straight back in your mbuzz account as credit and burns down against your monthly subscription as you use it. It's prepaid mbuzz, with the install thrown in for free.
      </p>
    </div>

    <%# Risk reversal / fine print %>
    <div class="mt-6 sm:mt-8 bg-white rounded-lg border border-gray-200 shadow-sm p-4 sm:p-5">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 text-sm">
        <% [
          [ "One-off", "No contract. No lock-in. No retainer." ],
          [ "Pay after the call", "You only commit once the kickoff has happened and the plan is agreed." ],
          [ "Non-refundable", "Non-refundable payment, due after the kickoff call. The credit covers it." ]
        ].each do |title, body| %>
          <div class="flex items-start gap-2">
            <svg class="w-5 h-5 text-indigo-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <div>
              <p class="font-semibold text-gray-900"><%= title %></p>
              <p class="text-gray-600"><%= body %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# CTA -- second nav element on this screen (chrome's Exit is the first) %>
    <div class="mt-6 sm:mt-8 flex justify-end">
      <%= link_to onboarding_discovery_path,
        class: "inline-flex items-center justify-center gap-2 w-full sm:w-auto px-6 py-3 bg-indigo-600 text-white rounded-md shadow-sm hover:bg-indigo-700 font-semibold" do %>
        Continue
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      <% end %>
    </div>
  </div>
</div>
