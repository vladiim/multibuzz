<div class="py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Set up your SDK</h2>
    <p class="mt-2 text-base sm:text-lg text-gray-600">Grab your test key, then choose an SDK to start sending events.</p>

    <% if flash[:notice] %>
      <div class="mt-6 p-3 bg-green-50 border border-green-200 rounded-md text-sm text-green-800">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%# API Key %>
    <div class="mt-6 sm:mt-8 bg-white border border-gray-200 rounded-lg shadow-sm p-4 sm:p-5" data-controller="clipboard" data-api-key>
      <h3 class="text-base font-semibold text-gray-900">Your API key</h3>
      <p class="mt-1 text-sm text-gray-600">Use this test key during development. You'll switch to a live key when ready for production.</p>

      <% if test_api_key %>
        <% if @plaintext_api_key %>
          <div class="mt-4 flex items-center gap-2">
            <div class="flex-1 bg-gray-900 rounded-md p-3 font-mono text-sm overflow-x-auto">
              <code id="api-key-value" class="text-green-400 break-all" data-clipboard-target="source"><%= @plaintext_api_key %></code>
            </div>
            <button type="button"
              data-action="click->clipboard#copy"
              data-clipboard-target="button"
              class="flex-shrink-0 px-3 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-md shadow-sm">
              <span data-clipboard-target="label">Copy</span>
            </button>
          </div>
          <p class="mt-2 text-sm text-amber-600 font-medium">Save this key now. For security, it won't be shown again.</p>
        <% else %>
          <div class="mt-4 flex items-center gap-2">
            <div class="flex-1 bg-gray-100 rounded-md p-3 font-mono text-sm">
              <code class="text-gray-500"><%= test_api_key.masked_key %></code>
            </div>
            <%= button_to "Regenerate", onboarding_regenerate_api_key_path, method: :post, class: "flex-shrink-0 px-3 py-2 bg-white text-gray-700 border border-gray-300 rounded-md shadow-sm text-sm font-medium hover:bg-gray-50" %>
          </div>
          <p class="mt-2 text-sm text-gray-500">Your API key is hidden for security. Click regenerate to create a new key.</p>
        <% end %>
      <% else %>
        <p class="mt-3 text-sm text-gray-500">No test API key found. <%= link_to "Create one", account_api_keys_path, class: "text-indigo-600 hover:text-indigo-800" %>.</p>
      <% end %>
    </div>

    <%# SDK Selection %>
    <div class="mt-4 bg-white border border-gray-200 rounded-lg shadow-sm p-4 sm:p-5" data-sdk-grid>
      <h3 class="text-base font-semibold text-gray-900">Choose your SDK</h3>
      <p class="mt-1 text-sm text-gray-600">Select a live SDK to continue, or join the waitlist for upcoming platforms.</p>

      <div class="mt-4 grid grid-cols-2 md:grid-cols-3 gap-3">
        <% available_sdks.each do |sdk| %>
          <div data-sdk-card>
            <% if sdk.live? %>
              <%= button_to onboarding_select_sdk_path, params: { sdk: sdk.key }, method: :post,
                    form_class: "h-full",
                    class: "w-full h-full p-4 rounded-md border border-gray-200 shadow-sm bg-white hover:border-indigo-400 hover:shadow text-center flex flex-col items-center justify-center cursor-pointer" do %>
                <div class="h-10 w-10 flex items-center justify-center mb-2"><%= sdk_icon_for(sdk, css_class: "w-8 h-8") %></div>
                <div class="font-medium text-gray-900 text-sm"><%= sdk.display_name %></div>
                <span class="mt-1.5 inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= sdk_status_badge_class(sdk.status) %>"><%= sdk.status_badge %></span>
              <% end %>
            <% else %>
              <%= button_to onboarding_waitlist_sdk_path, params: { sdk: sdk.key }, method: :post,
                    form_class: "h-full",
                    class: "w-full h-full p-4 rounded-md border border-gray-200 shadow-sm bg-gray-50 hover:border-indigo-300 hover:shadow text-center flex flex-col items-center justify-center cursor-pointer" do %>
                <div class="h-10 w-10 flex items-center justify-center mb-2 opacity-60"><%= sdk_icon_for(sdk, css_class: "w-8 h-8") %></div>
                <div class="font-medium text-gray-500 text-sm"><%= sdk.display_name %></div>
                <span class="mt-1.5 inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= sdk_status_badge_class(sdk.status) %>"><%= sdk.status_badge %></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
