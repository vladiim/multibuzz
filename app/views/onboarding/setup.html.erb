<div class="min-h-screen bg-gray-50 py-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Progress -->
    <div class="mb-8">
      <div class="flex items-center justify-between text-sm text-gray-500 mb-2">
        <span>Step 2 of 5</span>
        <div class="flex items-center gap-4">
          <span><%= current_account.onboarding_percentage %>% complete</span>
          <%= button_to "Skip setup →", onboarding_skip_path, method: :post, class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
        </div>
      </div>
      <div class="h-2 bg-gray-200 rounded-full">
        <div class="h-2 bg-indigo-600 rounded-full" style="width: <%= current_account.onboarding_percentage %>%"></div>
      </div>
    </div>

    <% if flash[:notice] %>
      <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <!-- API Key Section -->
    <div class="bg-white rounded-lg shadow p-6 mb-8" data-controller="clipboard" data-api-key>
      <h2 class="text-xl font-semibold text-gray-900 mb-2">Your API Key</h2>
      <p class="text-gray-600 mb-4">Use this test key during development. You'll switch to a live key when ready for production.</p>

      <% if test_api_key %>
        <% if @plaintext_api_key %>
          <div class="flex items-center gap-3">
            <div class="flex-1 bg-gray-900 rounded-lg p-4 font-mono text-sm">
              <code id="api-key-value" class="text-green-400 break-all" data-clipboard-target="source"><%= @plaintext_api_key %></code>
            </div>
            <button type="button"
              data-action="click->clipboard#copy"
              data-clipboard-target="button"
              class="flex-shrink-0 px-4 py-3 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium rounded-lg transition-colors">
              <span data-clipboard-target="label">Copy</span>
            </button>
          </div>
          <p class="mt-3 text-sm text-amber-600 font-medium">
            Save this key now. For security, it won't be shown again.
          </p>
        <% else %>
          <div class="flex items-center gap-3">
            <div class="flex-1 bg-gray-100 rounded-lg p-4 font-mono text-sm">
              <code class="text-gray-500"><%= test_api_key.masked_key %></code>
            </div>
            <%= button_to "Regenerate", onboarding_regenerate_api_key_path, method: :post, class: "flex-shrink-0 px-4 py-3 bg-gray-600 hover:bg-gray-500 text-white text-sm font-medium rounded-lg transition-colors" %>
          </div>
          <p class="mt-3 text-sm text-gray-500">
            Your API key is hidden for security. Click regenerate to create a new key.
          </p>
        <% end %>
      <% else %>
        <p class="text-yellow-600">No test API key found. <%= link_to "Create one", account_api_keys_path, class: "text-indigo-600 hover:text-indigo-800" %>.</p>
      <% end %>
    </div>

    <!-- SDK Selection -->
    <div class="bg-white rounded-lg shadow p-6" data-sdk-grid>
      <h2 class="text-xl font-semibold text-gray-900 mb-2">Choose Your SDK</h2>
      <p class="text-gray-600 mb-6">Select a live SDK to continue, or join the waitlist for upcoming platforms.</p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <% available_sdks.each do |sdk| %>
          <div data-sdk-card>
            <% if sdk.live? %>
              <%= button_to onboarding_select_sdk_path, params: { sdk: sdk.key }, method: :post, class: "w-full h-44 p-4 rounded-lg border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors text-center flex flex-col items-center justify-center cursor-pointer" do %>
                <div class="h-12 w-12 flex items-center justify-center mb-3"><%= sdk_icon_for(sdk, css_class: "w-10 h-10") %></div>
                <div class="font-medium text-gray-900 text-sm"><%= sdk.display_name %></div>
                <span class="inline-block mt-2 px-2 py-0.5 text-xs font-medium rounded-full <%= sdk_status_badge_class(sdk.status) %>">
                  <%= sdk.status_badge %>
                </span>
              <% end %>
            <% else %>
              <%= button_to onboarding_waitlist_sdk_path, params: { sdk: sdk.key }, method: :post, class: "w-full h-44 p-4 rounded-lg border-2 border-gray-100 bg-gray-50 hover:border-indigo-300 hover:bg-indigo-50 transition-colors text-center flex flex-col items-center justify-center cursor-pointer" do %>
                <div class="h-12 w-12 flex items-center justify-center mb-3 opacity-60"><%= sdk_icon_for(sdk, css_class: "w-10 h-10") %></div>
                <div class="font-medium text-gray-400 text-sm"><%= sdk.display_name %></div>
                <span class="inline-block mt-2 px-2 py-0.5 text-xs font-medium rounded-full <%= sdk_status_badge_class(sdk.status) %>">
                  <%= sdk.status_badge %>
                </span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%= render "onboarding/skip_banner" %>
  </div>
</div>
