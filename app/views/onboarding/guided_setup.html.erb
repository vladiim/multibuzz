<div class="min-h-screen bg-gray-50 py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-3xl text-right mb-4">
    <%= button_to "← Change setup option", onboarding_change_setup_path_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
  <div class="sm:mx-auto sm:w-full sm:max-w-3xl" data-testid="guided-setup">
    <div class="text-center">
      <h2 class="text-3xl font-extrabold text-gray-900">Guided Setup</h2>
      <p class="mt-2 text-lg text-gray-600">
        Our specialist installs mbuzz, connects one ad platform, and trains your team.
      </p>
    </div>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
        <div class="text-sm font-semibold text-indigo-600">1 &middot; Kickoff call</div>
        <p class="mt-1 text-sm text-gray-600">Agree goals and the value moment you want to see.</p>
      </div>
      <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
        <div class="text-sm font-semibold text-indigo-600">2 &middot; Install</div>
        <p class="mt-1 text-sm text-gray-600">We install the four mbuzz API calls in your stack.</p>
      </div>
      <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
        <div class="text-sm font-semibold text-indigo-600">3 &middot; Integration</div>
        <p class="mt-1 text-sm text-gray-600">Connect Meta Ads, Google Ads, or server-side GTM.</p>
      </div>
      <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-100">
        <div class="text-sm font-semibold text-indigo-600">4 &middot; Training &amp; value check</div>
        <p class="mt-1 text-sm text-gray-600">Dashboard walkthrough plus a 30-day check-in.</p>
      </div>
    </div>

    <div class="mt-8 bg-indigo-50 border border-indigo-100 rounded-lg p-5">
      <div class="text-lg font-semibold text-indigo-900">$1,500 today, applied as credit to your plan</div>
      <ul class="mt-2 text-sm text-indigo-900 list-disc list-inside space-y-1">
        <li>The full $1,500 is granted back as account credit and drawn down by your plan's invoices.</li>
        <li>Pick your plan below. The credit applies to every mbuzz charge: subscription renewals, plan changes, and usage overages.</li>
        <li>Non-refundable. Unused credit is forfeited if you cancel.</li>
      </ul>
    </div>

    <%= form_with url: onboarding_accept_guided_setup_path, method: :post, data: { turbo: false } do %>
      <fieldset class="mt-8">
        <legend class="text-sm font-semibold text-gray-900 mb-3">Choose your plan</legend>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% @plans.each do |plan| %>
            <label class="bg-white p-5 rounded-lg shadow-sm border-2 border-gray-100 hover:border-indigo-300 cursor-pointer flex flex-col">
              <div class="flex items-start gap-3">
                <%= radio_button_tag "plan_slug", plan.slug, plan == @recommended_plan, class: "mt-1" %>
                <div>
                  <div class="text-base font-semibold text-gray-900"><%= plan.name %></div>
                  <div class="text-xs text-gray-500"><%= plan.formatted_events %> events / month</div>
                </div>
              </div>
              <div class="mt-3 text-2xl font-bold text-gray-900"><%= plan.formatted_price %><span class="text-sm font-normal text-gray-500">/mo</span></div>
              <% if plan == @recommended_plan %>
                <div class="mt-2 text-xs font-semibold text-indigo-600">Recommended for you</div>
              <% end %>
            </label>
          <% end %>
        </div>
      </fieldset>

      <div class="mt-8 text-right">
        <%= submit_tag "Get Guided Setup. Pay $1,500.", class: "px-6 py-3 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer font-semibold" %>
      </div>
    <% end %>
  </div>
</div>
