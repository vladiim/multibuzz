<div class="min-h-screen bg-gray-50 py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-3xl text-right mb-4">
    <%= button_to "← Change setup option", onboarding_change_setup_path_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
  <div class="sm:mx-auto sm:w-full sm:max-w-3xl" data-testid="guided-setup">
    <div class="text-center">
      <h2 class="text-3xl font-extrabold text-gray-900">Last step</h2>
      <p class="mt-2 text-lg text-gray-600">Book your kickoff, we'll be in touch ASAP.</p>
    </div>

    <%= form_with url: onboarding_book_kickoff_path, method: :post, data: { testid: "book-kickoff-form" } do %>
      <div class="mt-8 bg-white p-6 rounded-lg shadow space-y-6">
        <% if @scheduling_error.present? %>
          <div class="p-3 bg-red-50 border border-red-200 rounded-md text-sm text-red-700" data-testid="scheduling-error">
            <%= @scheduling_error %>
          </div>
        <% end %>

        <div data-controller="searchable-select" class="relative">
          <span class="block text-sm font-semibold text-gray-900">Your time zone <span class="text-red-600">*</span></span>

          <button type="button"
            data-action="click->searchable-select#toggle"
            data-searchable-select-target="trigger"
            class="mt-2 w-full flex items-center justify-between gap-3 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-left focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 hover:border-gray-400 transition-colors">
            <span data-searchable-select-target="label" class="<%= @scheduling_form.timezone.blank? ? "text-gray-400" : "text-gray-900" %>">
              <%= @scheduling_form.timezone.presence || "Select your time zone" %>
            </span>
            <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
            </svg>
          </button>

          <input type="hidden"
            name="scheduling_preferences[timezone]"
            data-searchable-select-target="hidden"
            value="<%= @scheduling_form.timezone %>">

          <div data-searchable-select-target="panel" class="hidden absolute z-20 mt-1 w-full bg-white shadow-lg rounded-md border border-gray-200 overflow-hidden">
            <div class="p-2 border-b border-gray-100 bg-gray-50">
              <div class="relative">
                <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
                </svg>
                <input type="text"
                  data-action="input->searchable-select#filter"
                  data-searchable-select-target="input"
                  placeholder="Search time zones"
                  autocomplete="off"
                  class="w-full pl-8 pr-3 py-1.5 text-sm bg-white border border-gray-200 rounded-md focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
              </div>
            </div>
            <ul data-searchable-select-target="list" class="max-h-64 overflow-y-auto py-1">
              <% ActiveSupport::TimeZone.all.map(&:name).each do |tz_name| %>
                <li data-action="click->searchable-select#select"
                  data-searchable-select-option
                  data-value="<%= tz_name %>"
                  data-search-label="<%= tz_name %>"
                  class="px-3 py-1.5 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-900 cursor-pointer">
                  <%= tz_name %>
                </li>
              <% end %>
              <li data-searchable-select-target="empty" hidden class="px-3 py-3 text-sm text-gray-500 italic">No matches.</li>
            </ul>
          </div>
        </div>

        <div>
          <span class="block text-sm font-semibold text-gray-900">Your preferred days</span>
          <p class="mt-1 text-sm text-gray-600">Tick all the days that work.</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <% SchedulingPreferences::DAYS_OF_WEEK.each do |day| %>
              <label class="cursor-pointer select-none">
                <input type="checkbox" name="scheduling_preferences[days][]" value="<%= day %>" <%= "checked" if @scheduling_form.day_selected?(day) %> class="peer sr-only">
                <span class="inline-flex items-center px-3 py-2 rounded-md text-sm border bg-white text-gray-700 border-gray-300 hover:border-indigo-400 peer-checked:bg-indigo-600 peer-checked:text-white peer-checked:border-indigo-600 peer-focus:ring-2 peer-focus:ring-indigo-400">
                  <%= SchedulingPreferences::DAY_LABELS.fetch(day) %>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <span class="block text-sm font-semibold text-gray-900">Your preferred times</span>
          <p class="mt-1 text-sm text-gray-600">Tick all the times that work. Times are in your time zone.</p>
          <div class="mt-2 grid grid-cols-2 sm:grid-cols-4 gap-2">
            <% SchedulingPreferences::TIME_BLOCKS.each do |block| %>
              <label class="cursor-pointer select-none">
                <input type="checkbox" name="scheduling_preferences[time_blocks][]" value="<%= block %>" <%= "checked" if @scheduling_form.time_block_selected?(block) %> class="peer sr-only">
                <span class="flex flex-col items-start px-3 py-2 rounded-md text-sm border bg-white text-gray-700 border-gray-300 hover:border-indigo-400 peer-checked:bg-indigo-600 peer-checked:text-white peer-checked:border-indigo-600 peer-focus:ring-2 peer-focus:ring-indigo-400">
                  <span class="font-medium"><%= SchedulingPreferences::TIME_BLOCK_LABELS.fetch(block) %></span>
                  <span class="text-xs opacity-70"><%= SchedulingPreferences::TIME_BLOCK_HOURS.fetch(block) %></span>
                </span>
              </label>
            <% end %>
          </div>
        </div>
      </div>

      <div class="mt-6 text-right">
        <%= submit_tag "Book now", class: "px-6 py-3 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer font-semibold" %>
      </div>
    <% end %>
  </div>
</div>
