<% content_for(:title) { "#{t('contact.new.title')} | mbuzz" } %>

<%= render "layouts/nav" %>

<div class="min-h-screen bg-white">
  <!-- Header -->
  <section class="py-16 px-6 border-b border-gray-200">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl font-bold text-gray-900 tracking-tight"><%= t("contact.new.title") %></h1>
      <p class="mt-4 text-lg text-gray-600">
        <%= t("contact.new.subtitle") %>
      </p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16 px-6">
    <div class="max-w-xl mx-auto">
      <%= form_with model: @submission, url: contact_path, class: "space-y-6" do |form| %>
        <% if @submission.errors.any? %>
          <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-red-800 font-medium">Please fix the following errors:</p>
            <ul class="mt-2 text-red-700 text-sm list-disc list-inside">
              <% @submission.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Name -->
        <div>
          <%= form.label :name, t("contact.new.name_label"), class: "block text-sm font-medium text-gray-900 mb-2" %>
          <%= form.text_field :name,
            required: true,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all",
            placeholder: t("contact.new.name_placeholder") %>
        </div>

        <!-- Email -->
        <div>
          <%= form.label :email, t("contact.new.email_label"), class: "block text-sm font-medium text-gray-900 mb-2" %>
          <%= form.email_field :email,
            required: true,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all",
            placeholder: t("contact.new.email_placeholder") %>
        </div>

        <!-- Subject -->
        <div>
          <%= form.label :subject, t("contact.new.subject_label"), class: "block text-sm font-medium text-gray-900 mb-2" %>
          <%= form.select :subject,
            ContactSubmission::VALID_SUBJECTS.map { |s| [t("contact.new.subjects.#{s}"), s] },
            { include_blank: false },
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all" %>
        </div>

        <!-- Message -->
        <div>
          <%= form.label :message, t("contact.new.message_label"), class: "block text-sm font-medium text-gray-900 mb-2" %>
          <%= form.text_area :message,
            required: true,
            rows: 6,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all resize-none",
            placeholder: t("contact.new.message_placeholder") %>
        </div>

        <!-- Submit -->
        <div>
          <%= form.submit t("contact.new.submit"),
            class: "w-full px-6 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </section>
</div>

<%= render "layouts/footer" %>
