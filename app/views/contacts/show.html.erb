<% content_for(:title) { "Message Sent | mbuzz" } %>

<%= render "layouts/nav" %>

<div class="min-h-screen bg-white flex items-center justify-center px-6">
  <div class="max-w-md text-center">
    <!-- Success Icon -->
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <!-- Title -->
    <h1 class="text-3xl font-bold text-gray-900 mb-2">
      Message Sent!
    </h1>
    <p class="text-lg text-gray-600 mb-8">
      Thanks for getting in touch. We'll get back to you as soon as possible.
    </p>

    <!-- Back Home -->
    <%= link_to "Back to home", root_path,
      class: "inline-block px-6 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-all" %>
  </div>
</div>

<%= render "layouts/footer" %>
