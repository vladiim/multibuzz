<div class="score-signup">
  <h1>Create your free account</h1>
  <p class="subtitle">Unlock your full measurement maturity report, team comparison, and progress tracking.</p>

  <% if @user.errors.any? %>
    <div class="errors">
      <% @user.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <%= form_with url: join_path, method: :post do |f| %>
    <% if @claim_token.present? %>
      <input type="hidden" name="claim_token" value="<%= @claim_token %>">
    <% end %>

    <label for="user_company_name">Company name</label>
    <input type="text" name="user[company_name]" id="user_company_name" value="<%= @company_name %>" placeholder="e.g. Acme Corp" autofocus>

    <label for="user_email">Email</label>
    <input type="email" name="user[email]" id="user_email" value="<%= @user.email %>">

    <label for="user_password">Password</label>
    <input type="password" name="user[password]" id="user_password" minlength="8">

    <button type="submit" class="submit-btn">Create Account &mdash; Free</button>
  <% end %>

  <div class="login-link">
    Already have an account? <a href="<%= login_path(return_to: score_dashboard_path, claim_token: @claim_token) %>">Log in</a>
  </div>
</div>
