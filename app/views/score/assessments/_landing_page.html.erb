     data-score-assessment-claim-url-value="<%= claim_score_assessment_path %>"
     data-score-assessment-signup-url-value="<%= signup_path %>">

  <div class="assessment-overlay" data-score-assessment-target="overlay">
    <div class="assessment-progress"><div class="assessment-progress-bar" data-score-assessment-target="progressBar"></div></div>
    <button class="assessment-close" data-action="click->score-assessment#close">&larr; Exit</button>
    <div class="assessment-counter" data-score-assessment-target="counter"></div>

    <!-- Question view -->
    <div class="question-container" data-score-assessment-target="questionView">
      <div class="question-text" data-score-assessment-target="questionText"></div>
      <div class="answers" data-score-assessment-target="answers"></div>
    </div>

    <!-- Insight interstitial -->
    <div class="insight-interstitial" data-score-assessment-target="insightView">
      <div data-score-assessment-target="insightIcon"></div>
      <p data-score-assessment-target="insightText"></p>
      <div class="insight-source" data-score-assessment-target="insightSource"></div>
    </div>

    <!-- Loading -->
    <div class="loading-screen" data-score-assessment-target="loadingView">
      <div class="spinner"></div>
      <div class="loading-text">Calculating your score...</div>
      <div class="loading-sub">Analysing 6 dimensions across 10 responses</div>
    </div>

    <!-- Results -->
    <div class="results-container" data-score-assessment-target="resultsView">
      <div class="result-level-badge" data-score-assessment-target="resultBadge"></div>
      <p class="result-insight" data-score-assessment-target="resultInsight"></p>
      <div class="radar-container" data-score-assessment-target="radarChart"></div>
      <div class="dimension-breakdown" data-score-assessment-target="dimensionBreakdown"></div>
      <div class="results-actions">
        <button class="primary-action" data-action="click->score-assessment#createAccount">Create Free Account &mdash; Unlock Full Report</button>
        <button class="secondary-action" data-action="click->score-assessment#share">Share on LinkedIn</button>
      </div>
    </div>
  </div>
</div>

</div><%# close score-landing controller %>
