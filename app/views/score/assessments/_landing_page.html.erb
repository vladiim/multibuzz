          <% end %>
        </p>
      </div>

      <div class="results-actions">
        <% if logged_in? %>
          <button class="primary-action" data-action="click->score-assessment#createAccount">View Full Report</button>
        <% else %>
          <button class="primary-action" data-action="click->score-assessment#createAccount">Create Free Account &mdash; Unlock Full Report</button>
        <% end %>

        <div class="share-row">
          <button class="secondary-action" data-action="click->score-assessment#shareLinkedIn">LinkedIn</button>
          <button class="secondary-action" data-action="click->score-assessment#shareTwitter">X / Twitter</button>
          <button class="secondary-action" data-action="click->score-assessment#copyLink" data-copy-btn>Copy Link</button>
        </div>
      </div>
    </div>
  </div>

</div><%# close score-landing + score-assessment controllers %>
