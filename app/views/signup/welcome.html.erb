<% content_for(:title) { "Welcome to mbuzz" } %>

<%# Marketing analytics: fire signup_complete to dataLayer for GA4 / Google
    Ads / Meta Pixel via the gtm-event Stimulus controller. The conversion
    is also recorded server-side via mbuzz, this is the parallel client-
    side hit for ad-platform optimisation. user_id is hashed (SHA256 of
    lowercase email) for Enhanced Conversions / Advanced Matching — never
    raw PII. %>
<div data-controller="gtm-event"
     data-gtm-event-name-value="signup_complete"
     data-gtm-event-properties-value="<%= { user_id_hashed: @user_id_hashed }.to_json %>"></div>

<%= render "layouts/nav" %>

<div class="min-h-screen bg-white flex items-center justify-center px-6">
  <div class="max-w-md text-center">
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">
      Welcome to mbuzz!
    </h1>
    <p class="text-lg text-gray-600 mb-8">
      Your account is ready. Let's get you set up in under five minutes.
    </p>

    <%= link_to "Continue to setup", onboarding_path,
      class: "inline-block px-6 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-all" %>
  </div>
</div>

<%= render "layouts/footer" %>
