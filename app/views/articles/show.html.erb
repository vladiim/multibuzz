<nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 text-sm text-gray-500">
  <%= link_to "Academy", academy_path, class: "hover:text-gray-700" %>
  <span class="mx-2">/</span>
  <%= link_to @article.section.titleize, academy_section_path(@article.section), class: "hover:text-gray-700" %>
  <span class="mx-2">/</span>
  <span class="text-gray-700"><%= @article.title %></span>
</nav>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
  <article class="prose prose-lg prose-gray max-w-none
                 prose-headings:font-bold prose-headings:text-gray-900
                 prose-h1:text-4xl prose-h1:mb-4 prose-h1:tracking-tight
                 prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
                 prose-p:text-gray-600 prose-p:leading-relaxed
                 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
                 prose-code:text-sm prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                 prose-pre:bg-gray-900 prose-pre:text-gray-100 prose-pre:rounded-lg">

    <header class="mb-12 not-prose">
      <h1 class="text-4xl font-bold text-gray-900 tracking-tight mb-4">
        <%= @article.title %>
      </h1>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <% if @article.published_at %>
          <time datetime="<%= @article.published_at.iso8601 %>">
            <%= @article.published_at.strftime("%B %d, %Y") %>
          </time>
          <span>&middot;</span>
        <% end %>
        <span><%= @article.reading_time %> min read</span>
        <% if @article.has_download %>
          <span>&middot;</span>
          <span class="text-blue-600">Includes downloadable resource</span>
        <% end %>
      </div>
    </header>

    <%= render_article_content(@article) %>

  </article>
</main>
