<section class="py-16 px-6">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-4xl font-bold text-gray-900 tracking-tight mb-4">
      MTA Academy
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl">
      Master multi-touch attribution with technical guides, implementation patterns, and real-world examples.
    </p>
  </div>
</section>

<% if @featured.any? %>
  <section class="py-12 px-6 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Start Here</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @featured.each do |article| %>
          <%= render "article_card", article: article %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<section class="py-12 px-6">
  <div class="max-w-5xl mx-auto">
    <% @sections.each do |section, articles| %>
      <div class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-4 capitalize">
          <%= section.tr("-", " ") %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% articles.each do |article| %>
            <%= render "article_card", article: article %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
