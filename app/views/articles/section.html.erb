<section class="py-16 px-6">
  <div class="max-w-5xl mx-auto">
    <nav class="text-sm text-gray-500 mb-6">
      <%= link_to "Academy", academy_path, class: "hover:text-gray-700" %>
      <span class="mx-2">/</span>
      <span class="text-gray-700"><%= @section.tr("-", " ").titleize %></span>
    </nav>

    <h1 class="text-4xl font-bold text-gray-900 tracking-tight mb-4 capitalize">
      <%= @section.tr("-", " ") %>
    </h1>
  </div>
</section>

<section class="py-12 px-6">
  <div class="max-w-5xl mx-auto">
    <% if @articles.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% @articles.each do |article| %>
          <%= render "article_card", article: article %>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500">No articles in this section yet.</p>
    <% end %>
  </div>
</section>
