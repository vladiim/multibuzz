<div class="my-10 not-prose">
  <div class="relative overflow-hidden rounded-xl bg-gradient-to-br from-indigo-600 via-indigo-700 to-purple-700 p-8 shadow-lg">
    <div class="absolute top-0 right-0 -mt-4 -mr-4 h-32 w-32 rounded-full bg-white/10 blur-2xl"></div>
    <div class="absolute bottom-0 left-0 -mb-8 -ml-8 h-40 w-40 rounded-full bg-purple-500/20 blur-3xl"></div>

    <div class="relative sm:flex sm:items-center sm:justify-between gap-6">
      <div class="mb-6 sm:mb-0">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-5 h-5 text-indigo-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-indigo-200 text-sm font-medium uppercase tracking-wide">Interactive Demo</span>
        </div>
        <h3 class="text-xl font-bold text-white mb-1">See mbuzz in action</h3>
        <p class="text-indigo-100 text-sm">Explore 8 attribution models with sample data — no signup needed</p>
      </div>

      <%= link_to demo_path, class: "group inline-flex items-center gap-2 px-6 py-3 bg-white text-indigo-700 rounded-lg font-semibold shadow-md hover:shadow-lg hover:bg-indigo-50 transition-all duration-200" do %>
        Try Demo
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>
    </div>
  </div>
</div>
