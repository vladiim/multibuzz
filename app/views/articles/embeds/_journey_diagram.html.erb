<%# Interactive journey diagram showing multi-session attribution %>
<%# Visualizes a 3-session journey from anonymous to conversion %>

<%
  sessions = [
    {
      day: "Day 1",
      channel: "Google Ads",
      channel_type: "paid_search",
      color: "#6366f1",
      bg: "#eef2ff",
      border: "#c7d2fe",
      icon: "search",
      pages: ["Landing page"],
      identity: "Anonymous",
      identity_id: "cookie_abc123",
      outcome: "Exit"
    },
    {
      day: "Day 8",
      channel: "Organic Search",
      channel_type: "organic",
      color: "#10b981",
      bg: "#ecfdf5",
      border: "#a7f3d0",
      icon: "globe",
      pages: ["Blog post"],
      identity: "Anonymous",
      identity_id: "cookie_abc123",
      outcome: "Exit"
    },
    {
      day: "Day 12",
      channel: "Email Campaign",
      channel_type: "email",
      color: "#ec4899",
      bg: "#fdf2f8",
      border: "#fbcfe8",
      icon: "email",
      pages: ["Pricing page"],
      identity: "Identified",
      identity_id: "user@company.com",
      outcome: "Conversion"
    }
  ]
%>

<div class="my-8 not-prose">
  <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
    <%# Header %>
    <div class="bg-gradient-to-r from-slate-800 to-slate-900 px-6 py-4">
      <div class="flex items-center justify-between">
        <h3 class="text-white font-semibold">Customer Journey: Multi-Session Attribution</h3>
        <span class="text-xs text-slate-400 bg-slate-700 px-2 py-1 rounded">Example Journey</span>
      </div>
    </div>

    <div class="p-6">
      <%# Journey timeline %>
      <div class="relative">
        <%# Connecting line %>
        <div class="hidden md:block absolute top-12 left-0 right-0 h-0.5 bg-gray-200 z-0"></div>

        <div class="grid md:grid-cols-3 gap-6 relative z-10">
          <% sessions.each_with_index do |session, i| %>
            <div class="relative">
              <%# Session card %>
              <div class="rounded-lg border-2 overflow-hidden" style="border-color: <%= session[:border] %>; background-color: <%= session[:bg] %>;">
                <%# Session header %>
                <div class="px-4 py-2 flex items-center justify-between" style="background-color: <%= session[:color] %>20;">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background-color: <%= session[:color] %>;">
                      <%= i + 1 %>
                    </div>
                    <span class="text-sm font-semibold" style="color: <%= session[:color] %>;"><%= session[:channel] %></span>
                  </div>
                  <span class="text-xs font-medium text-gray-500"><%= session[:day] %></span>
                </div>

                <%# Session body %>
                <div class="px-4 py-3 space-y-2">
                  <%# Pages visited %>
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <span class="text-xs text-gray-600"><%= session[:pages].join(" → ") %></span>
                  </div>

                  <%# Identity %>
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <span class="text-xs text-gray-600"><%= session[:identity] %>: <code class="text-xs bg-white px-1 py-0.5 rounded"><%= session[:identity_id] %></code></span>
                  </div>

                  <%# Outcome %>
                  <div class="flex items-center gap-2">
                    <% if session[:outcome] == "Conversion" %>
                      <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <span class="text-xs font-semibold text-green-600"><%= session[:outcome] %></span>
                    <% else %>
                      <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                      </svg>
                      <span class="text-xs text-gray-500"><%= session[:outcome] %></span>
                    <% end %>
                  </div>
                </div>
              </div>

              <%# Arrow between cards (mobile: vertical, desktop: hidden - line handles it) %>
              <% if i < sessions.length - 1 %>
                <div class="md:hidden flex justify-center py-2">
                  <svg class="w-4 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 16 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4v16m0 0l-4-4m4 4l4-4"/>
                  </svg>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <%# Identity resolution callout %>
      <div class="mt-6 bg-indigo-50 rounded-lg px-4 py-3 border border-indigo-100">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-indigo-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
          <div>
            <p class="text-sm font-medium text-indigo-800">Identity Resolution</p>
            <p class="text-xs text-indigo-600 mt-1">
              When the user converts on Day 12, MTA links all three sessions via <code class="bg-indigo-100 px-1 py-0.5 rounded">cookie_abc123</code>. Without this, Session 1 and 2 would appear as abandoned visits, and Email would get 100% last-touch credit.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
