<%# Reusable customer-journey visual for attribution articles.
    Locals:
      title:    String header (uppercase tracking)
      steps:    Array of step hashes with keys:
                  day:     "Day 1" / "Day -30" / "Same day" — small label above
                  label:   "Facebook Ad" — main pill text
                  role:    :inactive | :credited | :conversion (controls colour)
                  percent: optional small label under pill (e.g. "100%", "50%")
                  sublabel: optional italic text under percent
      caption:  String — italic caption under the row %>

<% role_classes = {
     inactive:   "bg-slate-100 text-slate-500",
     credited:   "bg-emerald-100 text-emerald-800 border border-emerald-300",
     primary:    "bg-emerald-500 text-white font-bold",
     conversion: "bg-indigo-500 text-white font-bold"
   } %>

<% percent_classes = {
     inactive:   "text-slate-400",
     credited:   "text-emerald-700 font-semibold",
     primary:    "text-emerald-700 font-bold",
     conversion: "text-indigo-700 font-semibold"
   } %>

<div class="not-prose my-8 bg-white border border-slate-200 rounded-lg overflow-hidden">
  <% if defined?(title) && title.present? %>
    <div class="px-5 py-3 border-b border-slate-200 bg-slate-50">
      <p class="text-xs font-bold text-slate-500 tracking-[0.15em]"><%= title %></p>
    </div>
  <% end %>
  <div class="px-5 py-6">
    <div class="grid gap-2 sm:gap-3 text-center" style="grid-template-columns: repeat(<%= steps.length %>, minmax(0, 1fr));">
      <% steps.each do |s| %>
        <div>
          <div class="text-[10px] sm:text-xs text-slate-500 font-mono mb-2"><%= s[:day] %></div>
          <div class="<%= role_classes[s[:role]] %> px-1.5 sm:px-2 py-3 rounded-md text-[11px] sm:text-sm leading-tight"><%= s[:label] %></div>
          <% if s[:percent] %>
            <div class="text-[10px] mt-1.5 <%= percent_classes[s[:role]] %>"><%= s[:percent] %></div>
          <% end %>
          <% if s[:sublabel] %>
            <div class="text-[10px] text-slate-500 italic mt-0.5"><%= s[:sublabel] %></div>
          <% end %>
        </div>
      <% end %>
    </div>
    <% if defined?(caption) && caption.present? %>
      <p class="text-xs text-slate-500 italic leading-snug mt-4"><%= caption.html_safe %></p>
    <% end %>
  </div>
</div>
