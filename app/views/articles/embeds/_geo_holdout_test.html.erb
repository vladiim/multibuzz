<%# Geo-holdout incrementality test visualization %>
<%# Shows control vs treatment with incremental lift calculation %>

<div class="my-8 not-prose">
  <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-slate-800 to-slate-900 px-6 py-4">
      <div class="flex items-center justify-between">
        <h3 class="text-white font-semibold">Geo-Holdout Incrementality Test</h3>
        <span class="text-xs text-slate-400 bg-slate-700 px-2 py-1 rounded">Example</span>
      </div>
      <p class="text-sm text-slate-400 mt-1">What is Meta's true incremental impact?</p>
    </div>

    <%# Test setup %>
    <div class="p-6">
      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <%# Control %>
        <div class="rounded-lg border-2 border-gray-200 p-4">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-3 h-3 rounded-full bg-gray-400"></div>
            <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wide">Control</h4>
            <span class="text-xs text-gray-500">50% of geos</span>
          </div>
          <p class="text-sm text-gray-600 mb-3">No Meta spend</p>
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 uppercase tracking-wide">Revenue (4 weeks)</p>
            <p class="text-2xl font-bold text-gray-900">$400,000</p>
          </div>
        </div>

        <%# Treatment %>
        <div class="rounded-lg border-2 p-4" style="border-color: #818cf8;">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-3 h-3 rounded-full bg-indigo-500"></div>
            <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wide">Treatment</h4>
            <span class="text-xs text-gray-500">50% of geos</span>
          </div>
          <p class="text-sm text-gray-600 mb-3">Normal Meta spend</p>
          <div class="bg-indigo-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 uppercase tracking-wide">Revenue (4 weeks)</p>
            <p class="text-2xl font-bold text-gray-900">$500,000</p>
          </div>
        </div>
      </div>

      <%# Results bar visualization %>
      <div class="mb-6">
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Revenue Comparison</p>
        <div class="space-y-2">
          <div>
            <div class="flex items-center justify-between text-sm mb-1">
              <span class="text-gray-600">Control</span>
              <span class="font-medium text-gray-900">$400k</span>
            </div>
            <div class="bg-gray-100 rounded-full h-4">
              <div class="h-4 rounded-full bg-gray-400" style="width: 80%;"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between text-sm mb-1">
              <span class="text-gray-600">Treatment</span>
              <span class="font-medium text-gray-900">$500k</span>
            </div>
            <div class="bg-gray-100 rounded-full h-4">
              <div class="h-4 rounded-full flex" style="width: 100%;">
                <div class="h-4 rounded-l-full bg-gray-400" style="width: 80%;"></div>
                <div class="h-4 rounded-r-full bg-emerald-500" style="width: 20%;"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="flex items-center justify-end gap-3 mt-2 text-xs text-gray-500">
          <div class="flex items-center gap-1">
            <div class="w-3 h-2 rounded bg-gray-400"></div>
            <span>Baseline</span>
          </div>
          <div class="flex items-center gap-1">
            <div class="w-3 h-2 rounded bg-emerald-500"></div>
            <span>Incremental lift</span>
          </div>
        </div>
      </div>

      <%# Results metrics %>
      <div class="grid grid-cols-3 gap-3">
        <div class="bg-emerald-50 rounded-lg p-3 text-center">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Incremental lift</p>
          <p class="text-xl font-bold text-emerald-600">$100k</p>
          <p class="text-xs text-emerald-600 font-medium">+25%</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-3 text-center">
          <p class="text-xs text-gray-500 uppercase tracking-wide">Meta spend</p>
          <p class="text-xl font-bold text-gray-900">$60k</p>
        </div>
        <div class="bg-indigo-50 rounded-lg p-3 text-center">
          <p class="text-xs text-gray-500 uppercase tracking-wide">True iROAS</p>
          <p class="text-xl font-bold text-indigo-600">1.67x</p>
        </div>
      </div>
    </div>

    <div class="bg-emerald-50 px-6 py-3 border-t border-emerald-100">
      <p class="text-sm text-emerald-800">
        <strong>This number doesn't change when Meta changes attribution windows.</strong> It measures causation, not correlation.
      </p>
    </div>
  </div>
</div>
