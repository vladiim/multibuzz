<%# Embeddable model comparison for articles %>
<%# Shows two attribution models side-by-side with demo data %>

<div class="my-8 not-prose">
  <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-slate-800 to-slate-900 px-6 py-4">
      <div class="flex items-center justify-between">
        <h3 class="text-white font-semibold">Attribution Model Comparison</h3>
        <span class="text-xs text-slate-400 bg-slate-700 px-2 py-1 rounded">Demo Data</span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-gray-200">
      <%# Linear Model %>
      <div class="p-6">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-6 bg-indigo-500 rounded-full"></div>
          <h4 class="font-semibold text-gray-900">Linear</h4>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 uppercase tracking-wide">Conversions</p>
            <p class="text-xl font-bold text-gray-900">2,382</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 uppercase tracking-wide">Revenue</p>
            <p class="text-xl font-bold text-gray-900">$147,230</p>
          </div>
        </div>

        <div class="space-y-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Credit by Channel</p>
          <% [
            { name: "Paid Search", pct: 28, color: "indigo" },
            { name: "Organic", pct: 24, color: "emerald" },
            { name: "Email", pct: 19, color: "pink" },
            { name: "Paid Social", pct: 17, color: "amber" },
            { name: "Direct", pct: 12, color: "slate" }
          ].each do |channel| %>
            <div class="flex items-center gap-3">
              <div class="w-24 text-sm text-gray-600 truncate"><%= channel[:name] %></div>
              <div class="flex-1 bg-gray-100 rounded-full h-2">
                <div class="bg-<%= channel[:color] %>-500 h-2 rounded-full" style="width: <%= channel[:pct] %>%"></div>
              </div>
              <div class="w-12 text-right text-sm font-medium text-gray-900"><%= channel[:pct] %>%</div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Markov Chain Model %>
      <div class="p-6">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1 h-6 bg-teal-500 rounded-full"></div>
          <h4 class="font-semibold text-gray-900">Markov Chain</h4>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 uppercase tracking-wide">Conversions</p>
            <p class="text-xl font-bold text-gray-900">2,382</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-3">
            <p class="text-xs text-gray-500 uppercase tracking-wide">Revenue</p>
            <p class="text-xl font-bold text-gray-900">$147,230</p>
          </div>
        </div>

        <div class="space-y-2">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Credit by Channel</p>
          <% [
            { name: "Paid Search", pct: 22, color: "indigo" },
            { name: "Organic", pct: 31, color: "emerald" },
            { name: "Email", pct: 14, color: "pink" },
            { name: "Paid Social", pct: 21, color: "amber" },
            { name: "Direct", pct: 12, color: "slate" }
          ].each do |channel| %>
            <div class="flex items-center gap-3">
              <div class="w-24 text-sm text-gray-600 truncate"><%= channel[:name] %></div>
              <div class="flex-1 bg-gray-100 rounded-full h-2">
                <div class="bg-<%= channel[:color] %>-500 h-2 rounded-full" style="width: <%= channel[:pct] %>%"></div>
              </div>
              <div class="w-12 text-right text-sm font-medium text-gray-900"><%= channel[:pct] %>%</div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="bg-indigo-50 px-6 py-3 border-t border-indigo-100">
      <p class="text-sm text-indigo-700">
        <strong>Notice:</strong> Markov Chain credits Organic +7% more than Linear. Same data, different truth.
      </p>
    </div>
  </div>
</div>
