<%# Decision framework — should I use MTA, MMM, or both? Driven by spend tier. %>
<%# Each tier inherits the previous tier's methods and adds one. Visual: stacks rise as spend increases. %>

<%
  tiers = [
    {
      label: "TIER 1",
      spend: "Under $100K/yr",
      decision: "WAIT",
      decision_color: "slate",
      summary: "Platform reports and GA4 are enough to start. Independent measurement infrastructure costs more than it returns at this scale &mdash; revisit when you cross $100K.",
      stack: [
        { kind: :platform, label: "Platform reports + GA4", sub: "Last-click, biased self-reports" }
      ]
    },
    {
      label: "TIER 2",
      spend: "$100K&ndash;$500K/yr",
      decision: "TACTICAL",
      decision_color: "slate",
      summary: "Add MTA to recover 30&ndash;40% of data lost to client-side tracking and to compare channels on the same yardstick. If you spend on TV, podcast, or OOH, start logging weekly spend now so MMM is ready when you cross the next tier.",
      stack: [
        { kind: :platform, label: "Platform reports + GA4", sub: nil },
        { kind: :mta,      label: "MTA",                    sub: "Server-side, multi-touch" }
      ]
    },
    {
      label: "TIER 3",
      spend: "$500K&ndash;$2M/yr",
      decision: "STRATEGIC",
      decision_color: "indigo",
      summary: "Run MTA daily for tactical decisions, MMM quarterly for budget allocation. Disagreements between them tell you where to investigate. Need 2+ years of weekly history for MMM &mdash; if short, run MTA now and start MMM in 12 months.",
      stack: [
        { kind: :platform, label: "Platform reports + GA4", sub: nil },
        { kind: :mta,      label: "MTA",                    sub: "Daily / weekly" },
        { kind: :mmm,      label: "MMM",                    sub: "Quarterly allocation" }
      ]
    },
    {
      label: "TIER 4",
      spend: "$2M+/yr",
      decision: "CAUSAL",
      decision_color: "amber",
      summary: "Geo-holdout tests resolve MTA/MMM disagreements with experimental evidence and feed back to recalibrate both methods. At this scale, the cost of running tests is small relative to the budget you're allocating.",
      stack: [
        { kind: :platform,       label: "Platform reports + GA4", sub: nil },
        { kind: :mta,            label: "MTA",                    sub: "Daily / weekly" },
        { kind: :mmm,            label: "MMM",                    sub: "Quarterly allocation" },
        { kind: :incrementality, label: "Incrementality",         sub: "Geo holdouts, RCTs" }
      ]
    }
  ]

  card_classes = {
    platform:       "bg-slate-50  border-slate-300 text-slate-600",
    mta:            "bg-slate-100 border-slate-400 text-slate-800",
    mmm:            "bg-indigo-100 border-indigo-500 text-indigo-900",
    incrementality: "bg-slate-900 border-amber-400 text-white"
  }

  decision_badge_classes = {
    "slate"  => "bg-slate-200 text-slate-700",
    "indigo" => "bg-indigo-200 text-indigo-800",
    "amber"  => "bg-amber-200 text-amber-900"
  }
%>

<figure class="my-12 not-prose">
  <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

    <%# Header %>
    <div class="px-6 sm:px-8 pt-8 pb-6 border-b border-slate-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">Should I use MTA, MMM, or both?</h2>
      <p class="text-slate-500 text-sm sm:text-base mt-1">Find your annual marketing spend. Each tier adds one method &mdash; you don't drop the previous ones.</p>
    </div>

    <%# ─── DESKTOP LAYOUT — four-column stacking visual ─── %>
    <%# Single grid with three explicit rows so every column shares the same Y boundaries:
        row 1 = headers, row 2 = stack zones (1fr — all equal height), row 3 = divider + summary. %>
    <div class="hidden sm:block px-6 lg:px-8 py-8 bg-gradient-to-b from-slate-50/60 to-white">

      <div class="grid grid-cols-4 grid-rows-[auto_1fr_auto] gap-x-3">

        <%# Row 1 — column headers %>
        <% tiers.each do |tier| %>
          <div class="text-center mb-3">
            <div class="text-[11px] font-bold text-slate-500 tracking-[0.15em]"><%= tier[:label] %></div>
            <div class="text-sm font-mono font-semibold text-slate-900 mt-0.5"><%= tier[:spend].html_safe %></div>
          </div>
        <% end %>

        <%# Row 2 — stack zones. flex-col-reverse + justify-start packs cards at the bottom of the zone;
            min-h ensures the row is tall enough for Tier 4's four cards. %>
        <% tiers.each do |tier| %>
          <div class="flex flex-col-reverse justify-start gap-1.5 min-h-[14rem]">
            <% tier[:stack].each do |card| %>
              <div class="<%= card_classes[card[:kind]] %> border-l-4 rounded-md px-3 py-2.5">
                <div class="text-sm font-bold leading-tight"><%= card[:label] %></div>
                <% if card[:sub] %>
                  <div class="text-[11px] opacity-75 leading-tight mt-0.5"><%= card[:sub] %></div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Row 3 — decision badge + summary. All cells share the same top edge (divider Y aligned). %>
        <% tiers.each do |tier| %>
          <div class="mt-4 pt-4 border-t border-slate-200">
            <div class="flex justify-center mb-2">
              <span class="<%= decision_badge_classes[tier[:decision_color]] %> text-[10px] font-bold tracking-[0.15em] px-2.5 py-1 rounded-full">
                &rarr; <%= tier[:decision] %>
              </span>
            </div>
            <p class="text-xs text-slate-600 leading-relaxed"><%= tier[:summary].html_safe %></p>
          </div>
        <% end %>

      </div>

    </div>

    <%# ─── MOBILE LAYOUT — vertical tier cards with capability pills ─── %>
    <div class="sm:hidden px-4 py-6 bg-gradient-to-b from-slate-50/60 to-white space-y-4">
      <% tiers.each do |tier| %>
        <div class="bg-white border border-slate-200 rounded-lg p-4">

          <%# Tier header row %>
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <div class="text-[11px] font-bold text-slate-500 tracking-[0.15em]"><%= tier[:label] %></div>
            <span class="<%= decision_badge_classes[tier[:decision_color]] %> text-[10px] font-bold tracking-[0.15em] px-2 py-0.5 rounded-full">
              &rarr; <%= tier[:decision] %>
            </span>
          </div>
          <div class="text-sm font-mono font-semibold text-slate-900 mb-3"><%= tier[:spend].html_safe %></div>

          <%# Capability pills %>
          <div class="flex flex-wrap gap-1.5 mb-3">
            <% tier[:stack].each do |card| %>
              <span class="<%= card_classes[card[:kind]] %> border text-[11px] font-semibold px-2 py-1 rounded">
                <%= card[:label] %>
              </span>
            <% end %>
          </div>

          <%# Summary %>
          <p class="text-xs text-slate-600 leading-relaxed"><%= tier[:summary].html_safe %></p>
        </div>
      <% end %>
    </div>

    <%# Footer takeaway %>
    <div class="px-6 sm:px-8 py-5 bg-slate-50 border-t border-slate-200">
      <p class="text-sm text-slate-700 leading-relaxed">
        <strong class="text-slate-900">Skip a tier and you'll feel it.</strong>
        Running MMM without MTA leaves you with no daily decisions. Running incrementality without MMM means you're spending tens of thousands per test to answer questions a model could narrow down for free. Stack the methods in order &mdash; each one calibrates the next.
      </p>
    </div>

  </div>
  <figcaption class="text-xs text-slate-500 mt-3 text-center">
    Spend tiers reflect mbuzz's reading of practitioner thresholds &middot; See <a href="/articles/measurement-maturity-map" class="underline decoration-slate-300 hover:decoration-slate-500">the measurement maturity map</a> for the full ladder
  </figcaption>
</figure>
