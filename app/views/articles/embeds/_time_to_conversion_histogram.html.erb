<%# Time-to-conversion histogram with cumulative-percent line and a recommended-window cutoff marker. %>
<%# Illustrative data for a typical considered-purchase business. %>

<%
  buckets = [
    { label: "0–7 d",   density: 50, cumulative: 50 },
    { label: "8–14 d",  density: 25, cumulative: 75 },
    { label: "15–21 d", density: 10, cumulative: 85 },
    { label: "22–30 d", density: 6,  cumulative: 91 },
    { label: "31–45 d", density: 5,  cumulative: 96 },
    { label: "46–72 d", density: 3,  cumulative: 99 },
    { label: "73 d+",   density: 1,  cumulative: 100 }
  ]
  max_density = buckets.map { |b| b[:density] }.max
  cutoff_index = 3 # vertical cutoff line sits at the END of the "22–30 d" bucket
%>

<figure class="my-12 not-prose">
  <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

    <%# Header %>
    <div class="px-6 sm:px-8 pt-8 pb-6 border-b border-slate-200">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">Time-to-conversion distribution</h2>
      <p class="text-slate-500 text-sm sm:text-base mt-1">Pick a window that captures ~90% of your conversions. Going further adds noise without adding signal.</p>
    </div>

    <%# Body %>
    <div class="px-4 sm:px-8 py-6 bg-gradient-to-b from-slate-50/60 to-white">

      <%# Legend %>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1.5 mb-5 text-xs text-slate-600">
        <span class="inline-flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-indigo-500"></span>
          <strong class="font-semibold">% of conversions</strong> in this bucket
        </span>
        <span class="inline-flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-emerald-500"></span>
          <strong class="font-semibold">cumulative %</strong>
        </span>
        <span class="inline-flex items-center gap-2">
          <span class="inline-block w-3 h-3 border-l-2 border-dashed border-amber-500"></span>
          <strong class="font-semibold">recommended window</strong>
        </span>
      </div>

      <%# Histogram rows %>
      <div class="space-y-2.5 relative">
        <% buckets.each_with_index do |b, i| %>
          <div class="grid grid-cols-[5rem_1fr_3.5rem] sm:grid-cols-[6rem_1fr_4rem] items-center gap-x-3 sm:gap-x-4">
            <div class="text-xs sm:text-sm font-mono text-slate-700 text-right"><%= b[:label] %></div>
            <div class="relative">
              <div class="h-6 sm:h-7 bg-slate-100 rounded-sm overflow-hidden">
                <div class="h-full bg-indigo-500 rounded-sm flex items-center pl-2" style="width: <%= (b[:density].to_f / max_density * 100).round %>%;">
                  <span class="text-[11px] sm:text-xs font-mono font-semibold text-white"><%= b[:density] %>%</span>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-1 text-xs sm:text-sm font-mono">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              <span class="font-semibold text-emerald-700"><%= b[:cumulative] %>%</span>
            </div>
          </div>
        <% end %>

        <%# Cutoff label band — sits BELOW the bars %>
        <div class="grid grid-cols-[5rem_1fr_3.5rem] sm:grid-cols-[6rem_1fr_4rem] gap-x-3 sm:gap-x-4 mt-3 pt-3 border-t-2 border-dashed border-amber-400">
          <div></div>
          <div class="text-xs text-amber-700 font-semibold">
            &uarr; 30-day window captures 91% of conversions
          </div>
          <div></div>
        </div>
      </div>

    </div>

    <%# Footer takeaway %>
    <div class="px-6 sm:px-8 py-5 bg-slate-50 border-t border-slate-200">
      <p class="text-sm text-slate-700 leading-relaxed">
        <strong class="text-slate-900">Run this query against your own data first.</strong>
        The shape of this distribution determines your window &mdash; not the platform default. Industries with longer consideration cycles will have a much fatter right tail; impulse e-commerce will be even more front-loaded than this example.
      </p>
    </div>

  </div>
  <figcaption class="text-xs text-slate-500 mt-3 text-center">
    Illustrative distribution &middot; Run the SQL above this chart to generate your own
  </figcaption>
</figure>
