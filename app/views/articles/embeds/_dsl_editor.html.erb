<%# Embeddable rule editor for articles %>
<%# Uses highlight.js like the homepage AML editor %>

<% code ||= <<~RUBY
within_window 90.days do
  within_window 30.days, weight: 0.6 do
    time_decay half_life: 7.days
  end

  within_window 30.days..60.days, weight: 0.4 do
    time_decay half_life: 14.days
  end
end
RUBY %>

<% title ||= "Custom Time-Decay Attribution" %>

<div class="my-8 not-prose">
  <div class="bg-slate-900 rounded-xl shadow-lg overflow-hidden max-w-2xl mx-auto">
    <div class="flex items-center justify-between px-4 py-3 bg-slate-800 border-b border-slate-700">
      <div class="flex items-center gap-3">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
        <span class="text-slate-400 text-sm font-mono"><%= title %></span>
      </div>
      <span class="text-xs text-slate-500 bg-slate-700 px-2 py-1 rounded">Rule Editor</span>
    </div>

    <div class="p-4 overflow-x-auto">
      <pre class="hljs font-mono text-sm leading-relaxed"><code data-controller="code-highlight" data-code-highlight-language-value="ruby"><%= code %></code></pre>
    </div>

    <div class="px-4 py-3 bg-slate-800 border-t border-slate-700">
      <p class="text-slate-400 text-sm">
        Build custom attribution rules in minutes. Weight channels, apply time-decay, define your own logic.
      </p>
    </div>
  </div>
</div>
