<%# Before/After January 12 attribution window change %>
<%# Shows what view-through windows were available and what disappeared %>

<%
  before_windows = [
    { name: "1-day view", pct: 60, hex: "#10b981", status: "active" },
    { name: "2-7 day view", pct: 25, hex: "#f59e0b", status: "gone" },
    { name: "8-28 day view", pct: 15, hex: "#ef4444", status: "gone" }
  ]
%>

<div class="my-8 not-prose">
  <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-slate-800 to-slate-900 px-6 py-4">
      <div class="flex items-center justify-between">
        <h3 class="text-white font-semibold">View-Through Attribution: Before vs After</h3>
        <span class="text-xs text-slate-400 bg-slate-700 px-2 py-1 rounded">January 12, 2026</span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-gray-200">
      <%# Before %>
      <div class="p-6">
        <div class="flex items-center gap-2 mb-5">
          <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
          <h4 class="font-semibold text-gray-900">Before January 12</h4>
        </div>

        <div class="space-y-3">
          <% before_windows.each do |window| %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm text-gray-700"><%= window[:name] %></span>
                <span class="text-sm font-semibold text-gray-900"><%= window[:pct] %>%</span>
              </div>
              <div class="bg-gray-100 rounded-full h-3">
                <div class="h-3 rounded-full" style="width: <%= window[:pct] %>%; background-color: <%= window[:hex] %>;"></div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-between">
          <span class="text-sm text-gray-500">Total reported</span>
          <span class="text-lg font-bold text-gray-900">100%</span>
        </div>
      </div>

      <%# After %>
      <div class="p-6">
        <div class="flex items-center gap-2 mb-5">
          <div class="w-2 h-2 rounded-full bg-red-500"></div>
          <h4 class="font-semibold text-gray-900">After January 12</h4>
        </div>

        <div class="space-y-3">
          <%# 1-day view still works %>
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-gray-700">1-day view</span>
              <span class="text-sm font-semibold text-gray-900">60%</span>
            </div>
            <div class="bg-gray-100 rounded-full h-3">
              <div class="h-3 rounded-full bg-emerald-500" style="width: 60%;"></div>
            </div>
          </div>

          <%# 2-7 day — gone %>
          <div class="opacity-40">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-gray-700 line-through">2-7 day view</span>
              <span class="text-xs font-semibold text-red-600 bg-red-50 px-2 py-0.5 rounded">GONE</span>
            </div>
            <div class="bg-gray-100 rounded-full h-3">
              <div class="h-3 rounded-full bg-gray-300" style="width: 25%;"></div>
            </div>
          </div>

          <%# 8-28 day — gone %>
          <div class="opacity-40">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-gray-700 line-through">8-28 day view</span>
              <span class="text-xs font-semibold text-red-600 bg-red-50 px-2 py-0.5 rounded">GONE</span>
            </div>
            <div class="bg-gray-100 rounded-full h-3">
              <div class="h-3 rounded-full bg-gray-300" style="width: 15%;"></div>
            </div>
          </div>
        </div>

        <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-between">
          <span class="text-sm text-gray-500">Total reported</span>
          <div class="flex items-center gap-2">
            <span class="text-lg font-bold text-red-600">60%</span>
            <span class="text-xs text-red-500 font-medium bg-red-50 px-2 py-0.5 rounded">-40%</span>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-amber-50 px-6 py-3 border-t border-amber-100">
      <p class="text-sm text-amber-800">
        <strong>Your campaigns didn't get worse.</strong> Your measurement window shrank from 28 days to 1 day for view attribution.
      </p>
    </div>
  </div>
</div>
