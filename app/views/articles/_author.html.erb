<div class="mt-12 pt-8 border-t border-gray-200">
  <div class="flex items-start gap-4">
    <% if author.image.present? %>
      <%= image_tag author.image, alt: author.name, class: "w-16 h-16 rounded-full object-cover" %>
    <% else %>
      <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center">
        <span class="text-blue-600 font-semibold text-xl"><%= author.name.split.map(&:first).join %></span>
      </div>
    <% end %>
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-1">
        <span class="font-semibold text-gray-900"><%= author.name %></span>
        <% if author.linkedin_url.present? %>
          <%= link_to author.linkedin_url, target: "_blank", rel: "noopener", class: "text-gray-400 hover:text-blue-600" do %>
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <% end %>
        <% end %>
      </div>
      <p class="text-sm text-gray-500 mb-2"><%= author.title %>, mbuzz</p>
      <p class="text-sm text-gray-600 leading-relaxed"><%= author.bio_short %></p>
      <% if author.credentials.any? %>
        <div class="flex flex-wrap gap-2 mt-3">
          <% author.credentials.each do |credential| %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
              <%= credential %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
