<%#
  LP pricing contrast card. Used by vs-triple-whale, vs-dreamdata, vs-hyros.
  GA4 page currently uses a "1 vs 8 models" variant — not this partial.

  Locals:
    competitor_name    — String. E.g. "Triple Whale".
    competitor_price   — String. E.g. "$149" (no /month suffix — added by partial).
    competitor_cadence — String. Default "/month". Override if needed (e.g. "/year").
    mbuzz_subtext      — String. Small grey line below the cards.
    mbuzz_includes     — Optional Array of String. Bulleted list of what the free
                         tier includes (e.g. ["8 attribution models", "DSL", ...]).
    bg_variant         — String. "gray" (default) or "white".
%>
<% competitor_cadence ||= "/month" %>
<% bg_variant ||= "gray" %>
<% bg_class = { "white" => "bg-white", "gray" => "bg-gray-50" }[bg_variant] %>
<% mbuzz_includes ||= [ "8 attribution models, side-by-side", "Attribution DSL (custom models)", "Spend intelligence + LTV mode", "Server-side SDKs (Ruby, Node, Python, PHP, Shopify, sGTM)", "Full export — CSV, API, MCP" ] %>

<section class="py-16 md:py-20 px-6 bg-pattern-grid <%= bg_class %>">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-10">The price difference</h2>
    <div class="flex flex-col sm:flex-row items-stretch justify-center gap-6">
      <div class="bg-white rounded-xl border border-gray-200 p-8 w-full sm:w-72 text-center flex flex-col">
        <p class="text-sm font-medium text-gray-500 uppercase tracking-wide"><%= competitor_name %></p>
        <p class="mt-3 text-5xl font-bold text-gray-900"><%= competitor_price %></p>
        <p class="mt-1 text-sm text-gray-500"><%= competitor_cadence %></p>
      </div>
      <div class="flex items-center justify-center">
        <div class="text-3xl font-bold text-gray-400">vs</div>
      </div>
      <div class="bg-white rounded-xl border-2 border-blue-600 p-8 w-full sm:w-72 text-center shadow-lg flex flex-col">
        <p class="text-sm font-medium text-blue-600 uppercase tracking-wide">mbuzz</p>
        <p class="mt-3 text-5xl font-bold text-gray-900">$0</p>
        <p class="mt-1 text-sm text-gray-500">/month free tier</p>
        <% if mbuzz_includes.any? %>
          <ul class="mt-5 pt-5 border-t border-gray-100 space-y-2 text-left">
            <% mbuzz_includes.each do |feat| %>
              <li class="flex items-start gap-2 text-xs text-gray-700">
                <svg class="w-3.5 h-3.5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span><%= feat %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
      </div>
    </div>
    <p class="mt-6 text-gray-600"><%= mbuzz_subtext %></p>
  </div>
</section>
