<% content_for :title, @page.title %>

<div class="min-h-[80vh]">
  <%= render "landing_pages/lp_hero",
    kicker: "mbuzz vs GA4 Attribution",
    headline: "You're letting Google tell you how well Google is working.",
    subhead: "GA4's single attribution model is a black box that requires 400+ conversions, favors Google channels, and gives you no way to compare or customize. That's not measurement — it's a conflict of interest.",
    primary_cta_text: "Start free",
    disclaimer: "Keep GA4 for web analytics. Add mbuzz for attribution. They're complementary." %>

  <%= render "landing_pages/lp_stat_banner" %>

  <%= render "landing_pages/lp_pain_points",
    intro_text: "These are the problems that lead teams to search for a GA4 attribution alternative.",
    points: [
      {
        title: "\"Which number goes in the board deck?\"",
        description: "Facebook says 200. Google says 180. GA4 says 150. Every platform inflates its own numbers 1.5–3x. GA4 is supposed to be the neutral arbiter — but it's built by the same company that sells you Google Ads. You need a truly independent source of truth."
      },
      {
        title: "\"Not enough data for attribution?\"",
        description: "GA4's Data-Driven Attribution needs 400+ conversions to work. Below that, it silently falls back to last-click — the model everyone agrees is least useful. Most startups and mid-market teams live below this threshold."
      },
      {
        title: "\"From 6 models to one black box?\"",
        description: "In 2023, GA4 dropped first-click, linear, time-decay, and position-based. What's left is opaque — you can't see how credit is assigned, compare alternatives, or build custom rules."
      }
    ] %>

  <%= render "landing_pages/lp_comparison_table",
    competitor_name: "GA4",
    bg_variant: "gray",
    intro_text: "GA4 is an excellent web analytics tool. Attribution just isn't its strength. Here's the full picture.",
    rows: [
      { feature: "Attribution models", competitor: { text: "1 (Data-Driven)", wins: false }, mbuzz: { text: "8 built-in + Attribution DSL", wins: true } },
      { feature: "Minimum conversions", competitor: { text: "400+ required", wins: false }, mbuzz: { text: "None", wins: true } },
      { feature: "Platform bias", competitor: { text: "Favors Google channels", wins: false }, mbuzz: { text: "Independent", wins: true } },
      { feature: "Model transparency", competitor: { text: "Black box", wins: false }, mbuzz: { text: "Every rule visible and editable", wins: true } },
      { feature: "Tracking method", competitor: { text: "Client-side JS", wins: false }, mbuzz: { text: "Server-side SDKs (6 languages)", wins: true } },
      { feature: "Custom models", competitor: { text: "Not available", wins: false }, mbuzz: { text: "Attribution DSL on every tier", wins: true } },
      { feature: "Data ownership", competitor: { text: "Google's infrastructure", wins: false }, mbuzz: { text: "Your data, full export", wins: true } },
      { feature: "Web analytics", competitor: { text: "Excellent full suite", wins: true }, mbuzz: { text: "Attribution only", wins: false } },
      { feature: "Google Ads integration", competitor: { text: "Native (deep)", wins: true }, mbuzz: { text: "Connected (spend sync via OAuth)", wins: true } },
      { feature: "Price", competitor: { text: "Free", wins: true }, mbuzz: { text: "Free tier available", wins: true } }
    ],
    verdict: "GA4 wins on web analytics and Google Ads integration. mbuzz wins on attribution depth, independence, and transparency. Not a replacement — run both." %>

  <%= render "landing_pages/lp_mid_cta",
    prompt_text: "Want to see what independent attribution looks like?" %>

  <%= render "landing_pages/lp_feature_showcase",
    heading: "Models. DSL. Spend. LTV.",
    bg_variant: "white",
    cells: [
      {
        eyebrow: "Eight models, one view",
        title: "Same data. Eight models. The spread is the answer.",
        description: "GA4 gives you one number from one black box. mbuzz shows you what every model says — and where they disagree. The spread between first-touch and last-touch is the honest truth range.",
        bullets: [
          "First-touch, last-touch, linear, time-decay, position-based, Markov, Shapley, data-driven",
          "Same underlying data — swap the lens, not the dataset",
          "Export every model's output on every tier"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-02-channels.png",
        screenshot_alt: "mbuzz channel comparison across 8 attribution models",
        cta: "See the models side-by-side",
        cta_path: demo_path,
        modal_frame_id: "demo_conversions",
        modal_frame_src: demo_dashboard_conversions_path(models: [ "first_touch", "last_touch" ])
      },
      {
        eyebrow: "Attribution DSL",
        title: "Write your own attribution. Audit the rest.",
        description: "SQL-like language. Encode your sales cycle directly into the math. Fork any built-in model, tweak the decay, add lookback windows. GA4 gives you a single model you can't inspect. mbuzz gives you eight plus the code behind them.",
        bullets: [
          "Plain-text rules, diff-friendly, version-controlled",
          "Fork and modify any built-in model in one line",
          "Run custom models alongside the built-ins — no tier gate"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-03-dsl.png",
        screenshot_alt: "mbuzz Attribution DSL — custom model examples",
        cta: "See example models",
        cta_path: root_path(anchor: "aml-editor"),
        modal_partial: "pages/home/aml_editor"
      },
      {
        eyebrow: "Spend Intelligence",
        title: "Where does the next $10K go?",
        description: "GA4 shows where revenue came from. mbuzz tells you what happens when you shift budget. Diminishing-returns curves, payback period by channel, reallocation suggestions — the questions that matter above $100K/mo in spend.",
        bullets: [
          "Response curves per channel — see saturation before you hit it",
          "Payback period by channel, not just ROAS",
          "Platform-reported vs real-captured revenue, reconciled"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-04-roas-delta.png",
        screenshot_alt: "mbuzz ROAS delta — platform-reported vs real-captured revenue",
        cta: "See the spend breakdown",
        cta_path: demo_dashboard_spend_path,
        modal_frame_id: "demo_spend",
        modal_frame_src: demo_dashboard_spend_path(preview: 1)
      },
      {
        eyebrow: "LTV mode",
        title: "Your worst channel might be your best.",
        description: "Every report flips between first-month revenue and 12-month lifetime value in one click. The channel that looked worst on acquisition usually wins on lifetime revenue. GA4 doesn't flip views — mbuzz does it on every tier.",
        bullets: [
          "Toggle any channel ranking between first-month and 12-month LTV",
          "See channel rank changes explicitly (up 2, down 4, same)",
          "Works across every attribution model"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-05-channel-detail.png",
        screenshot_alt: "mbuzz LTV leaderboard — channel rankings flip between first-month and 12-month",
        cta: "See the channel flip",
        cta_path: demo_path,
        modal_partial: "pages/home/ltv_leaderboard"
      }
    ] %>

  <%= render "landing_pages/lp_feature_grid",
    heading: "Also in mbuzz.",
    cells: [
      {
        title: "Server-side SDKs",
        description: "Ruby, Node, Python, PHP, Shopify, sGTM. Open-source. Your data never touches client-side pixels that ad-blockers nuke."
      },
      {
        title: "Own your data",
        description: "Full export on every plan — CSV, API, MCP server for agent access. No vendor lock-in, no tier gate."
      },
      {
        title: "Works below 400 conversions",
        description: "GA4's Data-Driven model silently falls back to last-click below 400 conversions/month. mbuzz runs every model at any data volume."
      }
    ] %>

  <%# GA4-specific "1 vs 8 models" visual replaces the standard pricing card (both products have free tiers — count comparison is sharper here). %>
  <section class="py-16 md:py-20 px-6 bg-gray-50">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-10">Attribution models: 1 vs 8</h2>
      <div class="flex flex-col sm:flex-row items-stretch justify-center gap-6">
        <div class="bg-white rounded-xl border border-gray-200 p-8 w-full sm:w-72 text-center">
          <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">GA4</p>
          <p class="mt-4 text-5xl font-bold text-gray-900">1</p>
          <p class="mt-2 text-sm text-gray-500">Data-Driven (black box)</p>
          <div class="mt-4 text-left space-y-1">
            <p class="text-xs text-gray-400 line-through">First Click — removed 2023</p>
            <p class="text-xs text-gray-400 line-through">Linear — removed 2023</p>
            <p class="text-xs text-gray-400 line-through">Time Decay — removed 2023</p>
            <p class="text-xs text-gray-400 line-through">Position Based — removed 2023</p>
            <p class="text-xs text-gray-400 line-through">Last Click — removed 2023</p>
          </div>
        </div>
        <div class="flex items-center justify-center">
          <div class="text-3xl font-bold text-gray-400">vs</div>
        </div>
        <div class="bg-white rounded-xl border-2 border-blue-600 p-8 w-full sm:w-72 text-center shadow-lg">
          <p class="text-sm font-medium text-blue-600 uppercase tracking-wide">mbuzz</p>
          <p class="mt-4 text-5xl font-bold text-gray-900">8+</p>
          <p class="mt-2 text-sm text-gray-500">Built-in + custom rules</p>
          <div class="mt-4 text-left space-y-1">
            <p class="text-xs text-gray-700">First Touch</p>
            <p class="text-xs text-gray-700">Last Touch</p>
            <p class="text-xs text-gray-700">Linear</p>
            <p class="text-xs text-gray-700">Time Decay</p>
            <p class="text-xs text-gray-700">U-Shaped (Position Based)</p>
            <p class="text-xs text-gray-700">W-Shaped</p>
            <p class="text-xs text-gray-700">Data-Driven</p>
            <p class="text-xs text-gray-700">Custom (Attribution DSL)</p>
          </div>
        </div>
      </div>
      <p class="mt-8 text-gray-600">Both have free tiers. But GA4's single model favors Google channels by design.</p>
    </div>
  </section>

  <%= render "landing_pages/lp_bottom_cta",
    subhead: "Explore the live demo with sample data. Compare 8 models side-by-side. Then decide if it's worth 5 minutes to set up." %>
</div>
