<% content_for :title, @page.title %>

<div class="min-h-[80vh]">
  <%= render "landing_pages/lp_hero",
    kicker: "mbuzz vs Dreamdata",
    headline: "Attribution answers this week. Not in 8 weeks.",
    subhead: "Dreamdata is the B2B journey platform — best-in-class journey visualization, deep CRM integration, LinkedIn audience activation. It starts at $750/mo and takes 4–8 weeks to deploy. mbuzz does four things — eight models, a SQL-like DSL, spend intelligence, LTV mode. Days to set up. $0 to start.",
    primary_cta_text: "Start free" %>

  <%= render "landing_pages/lp_stat_banner" %>

  <%= render "landing_pages/lp_pain_points",
    intro_text: "These are the problems that lead B2B teams to search for a Dreamdata alternative.",
    points: [
      {
        title: "\"$9,000/year and still no ROI proof?\"",
        description: "At $750/mo, Dreamdata costs more than some teams spend on the ads they're trying to measure. You need attribution that proves ROI before committing to enterprise pricing."
      },
      {
        title: "\"Channel numbers by next week?\"",
        description: "Dreamdata's CRM integration and historical processing takes 4–8 weeks. mbuzz's server-side SDKs capture data in days. When the board asks \"which channels work?\", you need an answer now."
      },
      {
        title: "\"Custom attribution locked to the top tier?\"",
        description: "Dreamdata gates custom attribution rules to the most expensive plan. mbuzz puts 8 built-in models plus the Attribution DSL on every tier — including free."
      }
    ] %>

  <%= render "landing_pages/lp_comparison_table",
    competitor_name: "Dreamdata",
    bg_variant: "gray",
    intro_text: "Dreamdata is a B2B journey platform. mbuzz is an attribution engine. Different products, different price points. Here's the full picture.",
    rows: [
      { feature: "Attribution model", competitor: { text: "Vendor-defined models", wins: false }, mbuzz: { text: "8 built-in + Attribution DSL (inspectable)", wins: true } },
      { feature: "Tracking method", competitor: { text: "Client-side + CRM ingestion", wins: false }, mbuzz: { text: "Server-side SDKs (Ruby, Node, Python, PHP, Shopify, sGTM)", wins: true } },
      { feature: "Starting price", competitor: { text: "$750/mo", wins: false }, mbuzz: { text: "$0 (paid from $29/mo)", wins: true } },
      { feature: "Setup time", competitor: { text: "4–8 weeks", wins: false }, mbuzz: { text: "Days", wins: true } },
      { feature: "Journey visualization", competitor: { text: "Best-in-class", wins: true }, mbuzz: { text: "Basic channel timeline", wins: false } },
      { feature: "LinkedIn audience activation", competitor: { text: "Deep integration", wins: true }, mbuzz: { text: "Not supported", wins: false } },
      { feature: "CRM integration", competitor: { text: "Salesforce, HubSpot, Pipedrive", wins: true }, mbuzz: { text: "Not included", wins: false } },
      { feature: "Account-level (B2B) attribution", competitor: { text: "Deep account journeys", wins: true }, mbuzz: { text: "Contact-level only", wins: false } },
      { feature: "Custom models", competitor: { text: "Top tier only", wins: false }, mbuzz: { text: "All tiers (Attribution DSL)", wins: true } },
      { feature: "Data ownership", competitor: { text: "Their infrastructure", wins: false }, mbuzz: { text: "Your data, full export", wins: true } },
      { feature: "Data export", competitor: { text: "Top tier", wins: false }, mbuzz: { text: "All tiers — CSV, API, MCP", wins: true } },
      { feature: "LTV / cohort mode", competitor: { text: "Enterprise plans", wins: false }, mbuzz: { text: "Every tier", wins: true } }
    ],
    verdict: "Dreamdata is the B2B journey platform — worth $750/mo if you need CRM-deep journey visualization and LinkedIn audience activation. mbuzz is the fast, cheap attribution engine — 8 models, inspectable DSL, server-side data, $29 vs $750. Different scales, different jobs." %>

  <%= render "landing_pages/lp_mid_cta",
    prompt_text: "Want to see it running in minutes, not weeks?" %>

  <%= render "landing_pages/lp_feature_showcase",
    heading: "Models. DSL. Spend. LTV.",
    bg_variant: "white",
    cells: [
      {
        eyebrow: "Eight models, one view",
        title: "Same data. Eight models. The spread is the answer.",
        description: "Dreamdata runs its own set of models. mbuzz shows you what every model says — and where they disagree. The spread between first-touch and last-touch is the honest truth range.",
        bullets: [
          "First-touch, last-touch, linear, time-decay, position-based, Markov, Shapley, data-driven",
          "Same underlying data — swap the lens, not the dataset",
          "Export every model's output on every tier"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-02-channels.png",
        screenshot_alt: "mbuzz channel comparison across 8 attribution models",
        cta: "See the models side-by-side",
        cta_path: demo_path,
        modal_frame_id: "demo_conversions",
        modal_frame_src: demo_dashboard_conversions_path(models: [ "first_touch", "last_touch" ])
      },
      {
        eyebrow: "Attribution DSL",
        title: "Write your own attribution. Audit the rest.",
        description: "SQL-like language. Encode your sales cycle directly into the math — critical for B2B cycles that don't fit standard templates. Fork any built-in model in one line. On Dreamdata, custom rules are gated to the top tier; on mbuzz they ship on every plan.",
        bullets: [
          "Plain-text rules, diff-friendly, version-controlled",
          "Fork and modify any built-in model in one line",
          "No tier gate — custom models on free and paid alike"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-03-dsl.png",
        screenshot_alt: "mbuzz Attribution DSL — custom model examples",
        cta: "See example models",
        cta_path: root_path(anchor: "aml-editor"),
        modal_partial: "pages/home/aml_editor"
      },
      {
        eyebrow: "Spend Intelligence",
        title: "Where does the next $10K go?",
        description: "Dreamdata tells you what happened. mbuzz also tells you what happens when you shift budget. Diminishing-returns curves, payback period by channel, reallocation suggestions — the questions that matter when every dollar is scrutinized.",
        bullets: [
          "Response curves per channel — see saturation before you hit it",
          "Payback period by channel, not just ROAS",
          "Platform-reported vs real-captured revenue, reconciled"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-04-roas-delta.png",
        screenshot_alt: "mbuzz ROAS delta — platform-reported vs real-captured revenue",
        cta: "See the spend breakdown",
        cta_path: demo_dashboard_spend_path,
        modal_frame_id: "demo_spend",
        modal_frame_src: demo_dashboard_spend_path(preview: 1)
      },
      {
        eyebrow: "LTV mode",
        title: "Your worst channel might be your best.",
        description: "Every report flips between first-month revenue and 12-month lifetime value in one click. The channel that looked worst on acquisition usually wins on lifetime revenue. On Dreamdata, LTV lives in enterprise plans; on mbuzz it's every tier.",
        bullets: [
          "Toggle any channel ranking between first-month and 12-month LTV",
          "See channel rank changes explicitly (up 2, down 4, same)",
          "Works across every attribution model"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-05-channel-detail.png",
        screenshot_alt: "mbuzz LTV leaderboard — channel rankings flip between first-month and 12-month",
        cta: "See the channel flip",
        cta_path: demo_path,
        modal_partial: "pages/home/ltv_leaderboard"
      }
    ] %>

  <%= render "landing_pages/lp_feature_grid",
    heading: "Also in mbuzz.",
    cells: [
      {
        title: "Server-side SDKs",
        description: "Ruby, Node, Python, PHP, Shopify, sGTM. Open-source. Your data never touches client-side pixels that ad-blockers nuke."
      },
      {
        title: "Own your data",
        description: "Full export on every plan — CSV, API, MCP server for agent access. No vendor lock-in, no tier gate."
      },
      {
        title: "Days, not weeks",
        description: "SDK install is hours. First attribution reports in days. Compare to Dreamdata's 4–8 week CRM integration and backfill."
      }
    ] %>

  <%= render "landing_pages/lp_pricing_card",
    competitor_name: "Dreamdata",
    competitor_price: "$750",
    bg_variant: "white",
    mbuzz_subtext: "Start free. Paid plans from $29/mo — that's 26x cheaper than Dreamdata's entry point." %>

  <%= render "landing_pages/lp_bottom_cta",
    subhead: "Explore the live demo with sample data. Or sign up free and connect your own channels in days.",
    secondary_cta_text: "Start for free" %>
</div>
