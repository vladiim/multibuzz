<% content_for :title, @page.title %>

<div class="min-h-[80vh]">
  <%# ── Hero ── %>
  <section class="py-16 md:py-24 px-6 bg-pattern-dots">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-medium text-blue-600 uppercase tracking-wide mb-4">mbuzz vs Triple Whale</p>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 tracking-tight">
        Your CFO wants channel ROI. Triple Whale only sees Shopify.
      </h1>
      <p class="mt-6 text-xl text-gray-600 max-w-3xl mx-auto">
        When the board asks "which channels actually drive revenue?", you need an answer that covers every touchpoint — not just what happens inside one platform.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to "See your attribution in 5 minutes", signup_path, class: "px-8 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all" %>
        <%= link_to "Explore the live demo", demo_path, class: "px-8 py-3 text-base font-semibold text-gray-900 bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 rounded-md transition-all" %>
      </div>
      <p class="mt-4 text-sm text-gray-500">Free tier. No credit card.</p>
    </div>

    <%# LP.1: Dashboard preview inside hero — visible above fold on desktop %>
    <div class="mt-12 max-w-5xl mx-auto">
      <%= render "pages/home/dashboard_preview" %>
    </div>
  </section>

  <%# LP.4: Bold stat banner — strongest proof point pre-revenue %>
  <section class="py-6 px-6 bg-blue-600">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-lg md:text-xl font-semibold text-white">Server-side tracking captures <span class="text-2xl md:text-3xl font-bold">30–40% more data</span> than client-side pixels</p>
      <p class="mt-1 text-sm text-blue-100">Ad blockers and browser privacy features can't block what they can't see.</p>
    </div>
  </section>

  <%# ── Pain points (buyer problems, not feature gaps) ── %>
  <section class="py-16 md:py-20 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">Sound familiar?</h2>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto">
        These are the problems that lead teams to search for a Triple Whale alternative.
      </p>
      <div class="space-y-8">
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center mt-1">
            <span class="text-red-600 font-bold text-sm">1</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">"Facebook says 200 conversions. Google says 180. We had 150 total."</h3>
            <p class="mt-1 text-gray-600">Every platform claims credit for the same customers. You need an independent referee that measures all channels equally — not another platform grading its own homework.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center mt-1">
            <span class="text-red-600 font-bold text-sm">2</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">"We're spending $30K/mo on ads and can't tell our board what's working."</h3>
            <p class="mt-1 text-gray-600">With client-side pixels, ad blockers eat 30–40% of your data. You're optimizing on partial information. Server-side tracking captures what pixels miss — before the browser gets involved.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center mt-1">
            <span class="text-red-600 font-bold text-sm">3</span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900">"We sell on WooCommerce / BigCommerce / custom — Triple Whale doesn't work for us."</h3>
            <p class="mt-1 text-gray-600">mbuzz works on any platform via server-side SDKs (Ruby, Node, Python, PHP). Your attribution doesn't depend on which cart you chose.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# LP.2: Mid-page CTA after pain points %>
  <section class="py-8 px-6 bg-gray-50 text-center">
    <p class="text-lg text-gray-700 font-medium">Ready to see what your real attribution looks like?</p>
    <div class="mt-4 flex flex-col sm:flex-row justify-center gap-3">
      <%= link_to "Explore the live demo", demo_path, class: "px-6 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all inline-block" %>
      <%= link_to "Start free", signup_path, class: "px-6 py-2.5 text-sm font-semibold text-gray-700 hover:text-gray-900 transition-all inline-block" %>
    </div>
  </section>

  <%# ── Visual price comparison ── %>
  <section class="py-16 md:py-20 px-6 bg-gray-50">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-10">The price difference</h2>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <div class="bg-white rounded-xl border border-gray-200 p-8 w-full sm:w-64 text-center">
          <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">Triple Whale</p>
          <p class="mt-3 text-5xl font-bold text-gray-900">$129</p>
          <p class="mt-1 text-sm text-gray-500">/month</p>
        </div>
        <div class="text-3xl font-bold text-gray-400">vs</div>
        <div class="bg-white rounded-xl border-2 border-blue-600 p-8 w-full sm:w-64 text-center shadow-lg">
          <p class="text-sm font-medium text-blue-600 uppercase tracking-wide">mbuzz</p>
          <p class="mt-3 text-5xl font-bold text-gray-900">$0</p>
          <p class="mt-1 text-sm text-gray-500">/month to start</p>
        </div>
      </div>
      <p class="mt-6 text-gray-600">Start free. Paid plans from $29/mo when you're ready to scale.</p>
    </div>
  </section>

  <%# ── LTV Leaderboard bridge + component ── %>
  <section class="pt-16 md:pt-20 px-6 bg-gray-900">
    <div class="max-w-3xl mx-auto text-center pb-8">
      <h2 class="text-3xl font-bold text-white mb-4">Here's what teams discover in their first week</h2>
      <p class="text-lg text-gray-400">The channel that looks best in month one is rarely the one that drives the most lifetime revenue. Toggle to 12-month LTV and watch the rankings flip.</p>
    </div>
  </section>
  <%= render "pages/home/ltv_leaderboard" %>

  <%# ── Comparison table with tradeoff framing ── %>
  <section class="py-16 md:py-20 px-6 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">Honest comparison</h2>
      <p class="text-lg text-gray-600 text-center mb-10 max-w-2xl mx-auto">Triple Whale is excellent if you're Shopify-only and want zero-effort setup. If you need more, here's how they compare.</p>
      <div class="bg-white rounded-lg shadow-lg overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-900 text-white">
              <th class="px-6 py-4 text-left text-sm font-semibold w-1/3"></th>
              <th class="px-6 py-4 text-left text-sm font-semibold w-1/3">Triple Whale</th>
              <th class="px-6 py-4 text-left text-sm font-semibold w-1/3">mbuzz</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">Platforms</td>
              <td class="px-6 py-4 text-sm text-gray-500">Shopify only</td>
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">Any platform</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">Tracking method</td>
              <td class="px-6 py-4 text-sm text-gray-500">Client-side pixels</td>
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">Server-side SDKs</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">Attribution models</td>
              <td class="px-6 py-4 text-sm text-gray-500">3 basic</td>
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">8 + custom rules (DSL)</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">Data capture</td>
              <td class="px-6 py-4 text-sm text-gray-500">~60% (ad blockers)</td>
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">~95% (server-side)</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">Starting price</td>
              <td class="px-6 py-4 text-sm text-gray-500">$129/mo</td>
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">Free</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">Setup time</td>
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">Minutes (Shopify app)</td>
              <td class="px-6 py-4 text-sm text-gray-500">Hours (SDK integration)</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">AI assistant</td>
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">Moby AI (natural language)</td>
              <td class="px-6 py-4 text-sm text-gray-500">Not yet</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm text-gray-500 text-center">Triple Whale wins on Shopify ease-of-use. mbuzz wins on accuracy, model depth, and platform flexibility.</p>
    </div>
  </section>

  <%# ── Bottom CTA ── %>
  <section class="py-20 px-6 bg-gray-900">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        See real attribution data — no signup required
      </h2>
      <p class="mt-4 text-lg text-gray-400">
        Explore the live demo with sample data. Or sign up free and connect your own channels in 5 minutes.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to "Explore the live demo", demo_path, class: "px-8 py-3 text-base font-semibold text-gray-900 bg-white hover:bg-gray-100 rounded-md transition-all inline-block" %>
        <%= link_to "Sign up free", signup_path, class: "px-8 py-3 text-base font-semibold text-white border border-gray-600 hover:border-gray-400 rounded-md transition-all inline-block" %>
      </div>
    </div>
  </section>
</div>
