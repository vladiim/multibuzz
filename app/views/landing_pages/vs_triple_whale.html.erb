<% content_for :title, @page.title %>

<div class="min-h-[80vh]">
  <%= render "landing_pages/lp_hero",
    kicker: "mbuzz vs Triple Whale",
    headline: "Free attribution that shows the math.",
    subhead: "Triple Whale bundles 75 dashboards, Moby AI, a custom pixel, and Sonar data enrichment for $149/mo. mbuzz does four things — eight attribution models, a SQL-like DSL, spend intelligence, LTV mode — across server-side SDKs in six languages. No frills. $0 to start.",
    primary_cta_text: "Get 30,000 events free" %>

  <%= render "landing_pages/lp_pricing_card",
    competitor_name: "Triple Whale",
    competitor_price: "$149",
    bg_variant: "white",
    mbuzz_subtext: "Start free. Paid plans from $29/mo when you're ready to scale." %>

  <%= render "landing_pages/lp_stat_banner" %>

  <%= render "landing_pages/lp_pain_points",
    intro_text: "These are the problems that lead teams to search for a Triple Whale alternative.",
    points: [
      {
        title: "\"How did they get that number?\"",
        description: "Triple Whale runs one proprietary model nobody outside the company can audit. mbuzz runs eight models side-by-side on the same data — the spread is the honest answer."
      },
      {
        title: "\"$1,500/mo for one blended ROAS?\"",
        description: "Triple Whale costs $149–$1,500+/mo for a dashboard suite and an AI assistant. mbuzz starts at $0, runs eight models plus Attribution DSL from $29, and exports data on every tier."
      },
      {
        title: "\"Where does the next $10K go?\"",
        description: "Above $100K/mo you need diminishing-returns curves and reallocation by channel — not another blended ROAS dashboard. mbuzz's Spend Intelligence ships in every tier."
      }
    ] %>

  <%= render "landing_pages/lp_comparison_table",
    competitor_name: "Triple Whale",
    bg_variant: "gray",
    intro_text: "Triple Whale is Shopify's command center. mbuzz is the attribution engine. Different products, different jobs. Here's the full picture.",
    rows: [
      { feature: "Attribution model", competitor: { text: "Proprietary, not externally auditable", wins: false }, mbuzz: { text: "8 built-in + Attribution DSL (inspectable)", wins: true } },
      { feature: "Tracking method", competitor: { text: "First-party pixel + Sonar enrichment", wins: false }, mbuzz: { text: "Server-side SDKs (Ruby, Node, Python, PHP, Shopify, sGTM)", wins: true } },
      { feature: "Starting price", competitor: { text: "$149/mo", wins: false }, mbuzz: { text: "$0", wins: true } },
      { feature: "AI assistant", competitor: { text: "Moby (chat + agents)", wins: true }, mbuzz: { text: "MCP server — plug in your own", wins: false } },
      { feature: "Pre-built dashboards", competitor: { text: "75+ ready-made", wins: true }, mbuzz: { text: "You build what you need", wins: false } },
      { feature: "Creative analytics", competitor: { text: "Ad-creative performance built-in", wins: true }, mbuzz: { text: "Not included", wins: false } },
      { feature: "Klaviyo, Recharge, Gorgias", competitor: { text: "Native integrations", wins: true }, mbuzz: { text: "Not supported", wins: false } },
      { feature: "Subscription / cohort data", competitor: { text: "Advanced tier only ($219/mo)", wins: true }, mbuzz: { text: "LTV mode in every tier", wins: true } },
      { feature: "Budget recommendations", competitor: { text: "Blended ROAS only", wins: false }, mbuzz: { text: "Response curves, payback, reallocation", wins: true } },
      { feature: "Data export", competitor: { text: "Top tier only", wins: false }, mbuzz: { text: "All tiers — CSV, API, MCP", wins: true } },
      { feature: "Ecommerce platforms", competitor: { text: "Shopify only", wins: false }, mbuzz: { text: "Anywhere you can install an SDK", wins: true } },
      { feature: "Setup time", competitor: { text: "Minutes (Shopify app)", wins: true }, mbuzz: { text: "Same day (self-serve SDK)", wins: false } }
    ],
    verdict: "Want all the frills — Moby AI, 75 dashboards, Sonar enrichment, creative analytics, Klaviyo/Recharge/Gorgias, subscription data? Triple Whale is worth $149/mo. Want transparent attribution math, server-side data you own, and the basics on every tier? mbuzz." %>

  <%= render "landing_pages/lp_mid_cta",
    prompt_text: "Want to see it running before you switch?" %>

  <%= render "landing_pages/lp_feature_showcase",
    heading: "Models. DSL. Spend. LTV.",
    bg_variant: "white",
    cells: [
      {
        eyebrow: "Eight models, one view",
        title: "Same data. Eight models. The spread is the honest answer.",
        description: "Triple Whale gives you one number. mbuzz shows you what every model says — and where they disagree. That gap is the truth range Triple Whale hides.",
        bullets: [
          "First-touch, last-touch, linear, time-decay, position-based, Markov, Shapley, data-driven",
          "Same underlying data — swap the lens, not the dataset",
          "Export every model's output on every tier"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-02-channels.png",
        screenshot_alt: "mbuzz channel comparison across 8 attribution models",
        cta: "See the models side-by-side",
        cta_path: demo_path,
        modal_frame_id: "demo_conversions",
        modal_frame_src: demo_dashboard_conversions_path(models: [ "first_touch", "last_touch" ])
      },
      {
        eyebrow: "Attribution DSL",
        title: "Write your own attribution. Audit the rest.",
        description: "SQL-like language. Encode your sales cycle directly into the math. Fork any built-in model, tweak the decay, add lookback windows. You own the logic — not a vendor's black box.",
        bullets: [
          "Plain-text rules, diff-friendly, version-controlled",
          "Fork and modify any built-in model in one line",
          "Run custom models alongside the built-ins — no tier gate"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-03-dsl.png",
        screenshot_alt: "mbuzz Attribution DSL — custom model examples",
        cta: "See example models",
        cta_path: root_path(anchor: "aml-editor"),
        modal_partial: "pages/home/aml_editor"
      },
      {
        eyebrow: "Spend Intelligence",
        title: "Where does the next $10K go?",
        description: "Triple Whale tells you ROAS. mbuzz tells you what happens when you shift budget. Diminishing-returns curves, payback period by channel, reallocation suggestions — the questions that matter above $100K/mo in spend.",
        bullets: [
          "Response curves per channel — see saturation before you hit it",
          "Payback period by channel, not just ROAS",
          "Platform-reported vs real-captured revenue, reconciled"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-04-roas-delta.png",
        screenshot_alt: "mbuzz ROAS delta — platform-reported vs real-captured revenue",
        cta: "See the spend breakdown",
        cta_path: demo_dashboard_spend_path,
        modal_frame_id: "demo_spend",
        modal_frame_src: demo_dashboard_spend_path(preview: 1)
      },
      {
        eyebrow: "LTV mode",
        title: "Your worst channel might be your best.",
        description: "Every report flips between first-month revenue and 12-month lifetime value in one click. The channel that looked worst on acquisition usually wins on lifetime revenue. Triple Whale's cohort/LTV analysis is gated to the $219/mo Advanced tier. Ours ships in every plan.",
        bullets: [
          "Toggle any channel ranking between first-month and 12-month LTV",
          "See channel rank changes explicitly (up 2, down 4, same)",
          "Works across every attribution model"
        ],
        screenshot_url: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/screenshot-05-channel-detail.png",
        screenshot_alt: "mbuzz LTV leaderboard — channel rankings flip between first-month and 12-month",
        cta: "See the channel flip",
        cta_path: demo_path,
        modal_partial: "pages/home/ltv_leaderboard"
      }
    ] %>

  <%= render "landing_pages/lp_feature_grid",
    heading: "Also in mbuzz.",
    cells: [
      {
        title: "Server-side SDKs",
        description: "Ruby, Node, Python, PHP, Shopify, sGTM. Open-source. Your data never touches client-side pixels that ad-blockers nuke."
      },
      {
        title: "Google Ads spend sync",
        description: "Platform-reported vs real-captured revenue on one screen. Reconciles the gap between Google's number and yours."
      },
      {
        title: "Own your data",
        description: "Full export on every plan — CSV, API, MCP server for agent access. No vendor lock-in, no tier gate."
      }
    ] %>

  <%= render "landing_pages/lp_bottom_cta",
    subhead: "The demo runs on sample data. Sign up free to connect your own. No credit card, no sales call." %>
</div>
