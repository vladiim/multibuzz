<%#
  LP bottom CTA. Dual CTAs. Dark by default; "light" variant for pages
  that have a dark leaderboard section directly above (prevents the
  two-dark-sections-stacked visual).

  Locals:
    subhead             — String. Paragraph below H2.
    secondary_cta_text  — String. Default "Sign up free".
    bg_variant          — String. "dark" (default) or "light".
%>
<% secondary_cta_text ||= "Sign up free" %>
<% bg_variant ||= "dark" %>

<% if bg_variant == "dark" %>
  <section class="py-20 px-6 bg-gray-900">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        See real attribution data — no signup required
      </h2>
      <p class="mt-4 text-lg text-gray-400">
        <%= subhead %>
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to "Explore the live demo", demo_path, class: "px-8 py-3 text-base font-semibold text-gray-900 bg-white hover:bg-gray-100 rounded-md transition-all inline-block" %>
        <%= link_to secondary_cta_text, signup_path, class: "px-8 py-3 text-base font-semibold text-white border border-gray-600 hover:border-gray-400 rounded-md transition-all inline-block" %>
      </div>
    </div>
  </section>
<% else %>
  <section class="py-20 px-6 bg-gray-50 bg-pattern-grid border-t border-gray-200">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
        See real attribution data — no signup required
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        <%= subhead %>
      </p>
      <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to "Explore the live demo", demo_path, class: "px-8 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all inline-block" %>
        <%= link_to secondary_cta_text, signup_path, class: "px-8 py-3 text-base font-semibold text-gray-900 bg-white border border-gray-300 hover:border-gray-400 rounded-md transition-all inline-block" %>
      </div>
    </div>
  </section>
<% end %>
