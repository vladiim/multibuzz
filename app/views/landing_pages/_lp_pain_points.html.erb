<%#
  LP pain-point block. 3 numbered buyer problems.

  Locals:
    intro_text  — String. Subhead under "Sound familiar?" H2.
    points      — Array of 3 Hashes: { title: String, description: String }
%>
<section class="py-16 md:py-20 px-6 bg-white bg-pattern-grid">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">Sound familiar?</h2>
    <p class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto">
      <%= intro_text %>
    </p>
    <div class="space-y-8">
      <% points.each_with_index do |point, index| %>
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center mt-1">
            <span class="text-red-600 font-bold text-sm"><%= index + 1 %></span>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-900"><%= point[:title] %></h3>
            <p class="mt-1 text-gray-600"><%= point[:description] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
