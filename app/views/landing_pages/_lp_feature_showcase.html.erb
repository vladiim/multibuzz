<%#
  LP feature showcase — alternating rows with screenshot + copy.
  The CTA opens a modal that renders live product content (turbo-frame from
  the demo routes, or a self-contained partial). Modal footer has a
  "View full demo" button linking to the full page.

  Locals:
    heading    — String. Default "See it working."
    bg_variant — String. "white" (default) or "gray".
    cells      — Array of Hashes, max 4:
                 {
                   eyebrow:,
                   title:,
                   description:,
                   bullets: [],
                   screenshot_url:,     # thumbnail shown on the page
                   screenshot_alt:,
                   cta:,                # click text (e.g. "See the spend breakdown")
                   cta_path:,           # modal footer "View full demo" link. Default demo_path.
                   modal_frame_id:,     # optional — turbo frame id on the demo page (e.g. "demo_spend")
                   modal_frame_src:,    # optional — path to load into the frame
                   modal_partial:,      # optional — self-contained partial rendered inside the modal
                 }
                 If neither modal_frame_* nor modal_partial is provided,
                 the modal falls back to showing the screenshot at full size.
%>
<% heading ||= "See it working." %>
<% bg_variant ||= "white" %>
<% bg_class = { "white" => "bg-white", "gray" => "bg-gray-50" }[bg_variant] %>

<section class="py-16 md:py-20 px-6 bg-pattern-grid <%= bg_class %>">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900"><%= heading %></h2>
    </div>
    <div>
      <% cells.each_with_index do |cell, i| %>
        <% modal_id = "showcase-modal-#{i}" %>
        <% unless i == 0 %>
          <div class="py-12 md:py-16">
            <hr class="border-gray-200">
          </div>
        <% end %>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <button type="button"
            data-controller="modal"
            data-action="click->modal#open"
            data-modal-target-value="<%= modal_id %>"
            class="<%= i.odd? ? 'lg:order-2' : '' %> group block text-left w-full rounded-xl overflow-hidden shadow-xl border border-gray-200 bg-white hover:shadow-2xl hover:border-blue-300 transition-all relative">
            <img src="<%= cell[:screenshot_url] %>"
              alt="<%= cell[:screenshot_alt] %>"
              loading="lazy"
              class="w-full h-auto block">
            <span class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm rounded-md px-2.5 py-1.5 text-xs font-medium text-gray-700 shadow-md group-hover:bg-blue-600 group-hover:text-white transition-all flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              Preview live
            </span>
          </button>
          <div class="<%= i.odd? ? 'lg:order-1' : '' %>">
            <% if cell[:eyebrow] %>
              <p class="text-sm font-medium text-blue-600 uppercase tracking-wide mb-3"><%= cell[:eyebrow] %></p>
            <% end %>
            <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4"><%= cell[:title] %></h3>
            <p class="text-lg text-gray-600 mb-6 leading-relaxed"><%= cell[:description] %></p>
            <% if cell[:bullets] %>
              <ul class="space-y-2.5 mb-6">
                <% cell[:bullets].each do |bullet| %>
                  <li class="flex items-start gap-2.5 text-gray-700">
                    <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span><%= bullet %></span>
                  </li>
                <% end %>
              </ul>
            <% end %>
            <button type="button"
              data-controller="modal"
              data-action="click->modal#open"
              data-modal-target-value="<%= modal_id %>"
              class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 font-semibold">
              <%= cell[:cta] || "Preview it live" %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>
        </div>

        <%# Modal: live product content + "View full demo" footer CTA %>
        <div id="<%= modal_id %>" class="hidden fixed inset-0 z-50" data-controller="modal">
          <div class="fixed inset-0 bg-black/75" data-action="click->modal#close"></div>
          <div class="fixed inset-0 flex items-center justify-center p-4 md:p-8 pointer-events-none">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-6xl max-h-[92vh] flex flex-col pointer-events-auto">
              <div class="flex justify-between items-start p-5 md:p-6 border-b border-gray-200">
                <div class="pr-4">
                  <% if cell[:eyebrow] %>
                    <p class="text-xs font-medium text-blue-600 uppercase tracking-wide"><%= cell[:eyebrow] %></p>
                  <% end %>
                  <h3 class="text-lg md:text-xl font-bold text-gray-900 mt-1"><%= cell[:title] %></h3>
                </div>
                <button type="button" data-action="click->modal#close" class="text-gray-400 hover:text-gray-600 flex-shrink-0" aria-label="Close">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <div class="flex-1 overflow-y-auto bg-gray-50">
                <% if cell[:modal_frame_id] && cell[:modal_frame_src] %>
                  <div class="p-5 md:p-6">
                    <turbo-frame id="<%= cell[:modal_frame_id] %>" src="<%= cell[:modal_frame_src] %>" loading="lazy">
                      <div class="p-16 text-center text-gray-400 text-sm">Loading live preview…</div>
                    </turbo-frame>
                  </div>
                <% elsif cell[:modal_partial] %>
                  <%= render cell[:modal_partial] %>
                <% else %>
                  <div class="p-5 md:p-6">
                    <img src="<%= cell[:screenshot_url] %>"
                      alt="<%= cell[:screenshot_alt] %>"
                      class="w-full h-auto rounded-lg border border-gray-200 shadow-sm bg-white">
                  </div>
                <% end %>
              </div>
              <div class="p-5 md:p-6 border-t border-gray-200 flex flex-col sm:flex-row justify-end gap-3">
                <button type="button" data-action="click->modal#close" class="px-5 py-2.5 text-sm font-medium text-gray-700 hover:text-gray-900 rounded-md">
                  Close
                </button>
                <%= link_to(cell[:cta_path] || demo_path, class: "px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all inline-flex items-center justify-center gap-2") do %>
                  View full demo
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
