<%#
  LP.2 — mid-page CTA after pain points.

  Locals:
    prompt_text  — String. Default "Ready to see what your real attribution looks like?"
%>
<% prompt_text ||= "Ready to see what your real attribution looks like?" %>

<section class="py-8 px-6 bg-gray-50 bg-pattern-grid text-center">
  <p class="text-lg text-gray-700 font-medium"><%= prompt_text %></p>
  <div class="mt-4 flex flex-col sm:flex-row justify-center gap-3">
    <%= link_to "Explore the live demo", demo_path, class: "px-6 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all inline-block" %>
    <%= link_to "Start free", signup_path, class: "px-6 py-2.5 text-sm font-semibold text-gray-700 hover:text-gray-900 transition-all inline-block" %>
  </div>
</section>
