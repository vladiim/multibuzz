<%#
  LP comparison table. 3 columns: feature | competitor | mbuzz.

  Locals:
    competitor_name — String. E.g. "Triple Whale".
    intro_text      — String. Paragraph above the table.
    rows            — Array of Hashes, each row:
                      {
                        feature: String,
                        competitor: { text: String, wins: Boolean },
                        mbuzz: { text: String, wins: Boolean }
                      }
                      "wins" styles as text-gray-900 font-medium; otherwise text-gray-500.
                      Both can be true (tie — both highlighted).
    verdict         — String. Small grey caption below the table.
    bg_variant      — String. "white" (default) or "gray".
%>
<% bg_variant ||= "white" %>
<% bg_class = { "white" => "bg-white", "gray" => "bg-gray-50" }[bg_variant] %>
<section class="py-16 md:py-20 px-6 bg-pattern-grid <%= bg_class %>">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">Honest comparison</h2>
    <p class="text-lg text-gray-600 text-center mb-10 max-w-2xl mx-auto"><%= intro_text %></p>
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-gray-900 text-white">
            <th class="px-6 py-4 text-left text-sm font-semibold w-1/3"></th>
            <th class="px-6 py-4 text-left text-sm font-semibold w-1/3"><%= competitor_name %></th>
            <th class="px-6 py-4 text-left text-sm font-semibold w-1/3">mbuzz</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% rows.each do |row| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= row[:feature] %></td>
              <td class="px-6 py-4 text-sm <%= row[:competitor][:wins] ? "text-gray-900 font-medium" : "text-gray-500" %>"><%= row[:competitor][:text] %></td>
              <td class="px-6 py-4 text-sm <%= row[:mbuzz][:wins] ? "text-gray-900 font-medium" : "text-gray-500" %>"><%= row[:mbuzz][:text] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-sm text-gray-500 text-center"><%= verdict %></p>
  </div>
</section>
