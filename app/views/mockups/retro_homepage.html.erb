<%# ========================================
    EVERYTHING YOU NEED
    ======================================== %>
<section class="py-20 bg-retro-deep">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="font-display text-4xl md:text-5xl text-retro-cream mb-4">
        Everything You Need
      </h2>
      <p class="font-body text-retro-cream/70 max-w-2xl mx-auto">
        No modules to unlock. No enterprise tiers hiding features. Everything, for everyone.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% [
        { icon: "chart-bar", title: "Multi-Touch Attribution", desc: "First-touch, last-touch, linear, time-decay, position-based, or custom." },
        { icon: "users", title: "Customer Journeys", desc: "See every touchpoint that led to conversion. Full funnel visibility." },
        { icon: "cog", title: "Custom Models", desc: "Build attribution models that match your business logic. No limits." },
        { icon: "lightning-bolt", title: "Real-Time Data", desc: "See conversions as they happen. No 24-hour delays." },
        { icon: "database", title: "Data Export", desc: "Your data, exportable anytime. CSV, JSON, or direct warehouse sync." },
        { icon: "shield-check", title: "Privacy-First", desc: "Server-side tracking. No third-party cookies. GDPR/CCPA ready." }
      ].each do |feature| %>
        <div class="card-retro-dark">
          <div class="w-10 h-10 bg-retro-orange/20 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-retro-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <% case feature[:icon] %>
              <% when "chart-bar" %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              <% when "users" %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
              <% when "cog" %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <% when "lightning-bolt" %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              <% when "database" %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
              <% when "shield-check" %>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              <% end %>
            </svg>
          </div>
          <h3 class="font-display text-xl text-retro-cream mb-2"><%= feature[:title] %></h3>
          <p class="font-body text-sm text-retro-cream/70"><%= feature[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

