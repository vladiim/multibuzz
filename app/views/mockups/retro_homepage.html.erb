        { name: "Ruby", status: "live" },
        { name: "Python", status: "coming" },
        { name: "PHP", status: "coming" },
        { name: "Node.js", status: "coming" },
        { name: "Go", status: "coming" }
      ].each do |sdk| %>
        <div class="card-retro flex items-center gap-3 py-3 px-5">
          <span class="font-body font-bold text-retro-deep"><%= sdk[:name] %></span>
          <span class="badge-retro <%= sdk[:status] == 'live' ? 'badge-live' : 'badge-coming' %>">
            <%= sdk[:status] == 'live' ? 'Live' : 'Coming Soon' %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</section>

