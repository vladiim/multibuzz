        { name: "Ruby", status: "live" },
        { name: "Python", status: "coming" },
        { name: "PHP", status: "coming" },
        { name: "Node.js", status: "coming" },
        { name: "Go", status: "coming" }
      ].each_with_index do |sdk, i| %>
        <div class="card-retro flex items-center gap-4 py-4 px-6 <%= i.even? ? 'tilt-left' : 'tilt-right' %>">
