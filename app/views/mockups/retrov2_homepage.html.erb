          <span class="badge-retro <%= sdk[:status] == 'live' ? 'badge-live' : 'badge-coming' %>">
            <%= sdk[:status] == 'live' ? 'Live' : 'Soon' %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</section>

