<%# ========================================
    V3 INTERACTIVE JAVASCRIPT - Enhanced
    ======================================== %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Attribution model data sets
  const attributionData = {
    linear: {
      bars: { paid_search: 85, email: 72, organic_social: 58, direct: 45, referral: 32 },
      journey: ['20%', '20%', '20%', '20%'],
      pie: { paid: 37.5, email: 30, social: 20, other: 12.5 }
    },
    first: {
      bars: { paid_search: 95, email: 40, organic_social: 35, direct: 20, referral: 10 },
      journey: ['100%', '0%', '0%', '0%'],
      pie: { paid: 55, email: 20, social: 15, other: 10 }
    },
    last: {
      bars: { paid_search: 30, email: 85, organic_social: 45, direct: 90, referral: 50 },
      journey: ['0%', '0%', '0%', '100%'],
      pie: { paid: 20, email: 35, social: 15, other: 30 }
    },
    time: {
      bars: { paid_search: 50, email: 75, organic_social: 55, direct: 80, referral: 40 },
      journey: ['10%', '15%', '25%', '50%'],
      pie: { paid: 28, email: 32, social: 18, other: 22 }
    },
    position: {
      bars: { paid_search: 90, email: 50, organic_social: 45, direct: 85, referral: 30 },
      journey: ['40%', '10%', '10%', '40%'],
      pie: { paid: 42, email: 25, social: 13, other: 20 }
    }
  };

  const modelSelect = document.getElementById('attribution-model');

  if (modelSelect) {
    modelSelect.addEventListener('change', function() {
      const model = this.value;
      const data = attributionData[model];

      // Update bar chart with animation
      const chartBars = document.querySelectorAll('#channel-chart [data-channel]');
      chartBars.forEach(bar => {
        const channel = bar.dataset.channel;
        if (data.bars[channel]) {
          bar.style.height = data.bars[channel] + '%';
        }
      });

      // Update journey credits
      const credits = document.querySelectorAll('[data-credit]');
      credits.forEach((credit, index) => {
        if (data.journey[index]) {
          credit.textContent = 'Credit: ' + data.journey[index];
        }
      });

      // Update dial angle on model selector
      const dial = modelSelect.closest('.card-retro').querySelector('.icon-dial');
      if (dial) {
        const angles = { linear: 45, first: 0, last: 90, time: 60, position: 30 };
        dial.style.setProperty('--dial-angle', angles[model] + 'deg');
      }
    });
  }

  // Animate counters on page load with tick effect
  const counters = document.querySelectorAll('[data-counter]');
  counters.forEach((counter, index) => {
    counter.style.opacity = '0';
    counter.style.transform = 'translateY(15px)';

    setTimeout(() => {
      counter.style.transition = 'all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)';
      counter.style.opacity = '1';
      counter.style.transform = 'translateY(0)';
    }, 150 * index);
  });

  // Animate chart bars on load
  const chartBars = document.querySelectorAll('#channel-chart [data-channel]');
  chartBars.forEach((bar, index) => {
    const targetHeight = bar.style.height;
    bar.style.height = '0%';

    setTimeout(() => {
      bar.style.height = targetHeight;
    }, 300 + (index * 100));
  });

  // Pulse effect on live badges
  const liveBadges = document.querySelectorAll('.badge-live');
  liveBadges.forEach(badge => {
    setInterval(() => {
      badge.style.transform = 'scale(1.05)';
      setTimeout(() => {
        badge.style.transform = 'scale(1)';
      }, 200);
    }, 3000);
  });
});
</script>
