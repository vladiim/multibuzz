<%# Stripe-style Test/Live mode toggle %>
<div class="flex items-center gap-1 p-1 bg-gray-100 rounded-lg">
  <%= button_to dashboard_view_mode_path,
    method: :patch,
    params: { mode: "test" },
    class: "px-3 py-1 text-xs font-medium rounded-md transition-colors #{test_mode? ? 'bg-amber-500 text-white' : 'text-gray-500 hover:text-gray-700'}",
    data: { turbo: false } do %>
    Test
  <% end %>
  <%= button_to dashboard_view_mode_path,
    method: :patch,
    params: { mode: "production" },
    class: "px-3 py-1 text-xs font-medium rounded-md transition-colors #{test_mode? ? 'text-gray-500 hover:text-gray-700' : 'bg-white text-gray-900 shadow-sm'}",
    data: { turbo: false } do %>
    Live
  <% end %>
</div>
