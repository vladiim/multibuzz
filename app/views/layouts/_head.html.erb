<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%# SEO Meta Tags %>
<meta name="description" content="<%= content_for(:meta_description) || "Server-side multi-touch attribution you own. Track customer journeys, measure marketing ROI, and understand what drives conversions—without black-box models or data lock-in." %>">
<meta name="robots" content="<%= content_for(:robots_meta).presence || "index, follow" %>">
<link rel="canonical" href="<%= content_for(:canonical_url) || request.original_url.split("?").first %>">

<%# Favicon Links %>
<link rel="icon" href="/favicon.ico" sizes="48x48">
<link rel="icon" href="/icon.svg" type="image/svg+xml">
<link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<link rel="manifest" href="/manifest.json">

<%# Open Graph Tags %>
<meta property="og:type" content="<%= content_for(:og_type) || "website" %>">
<meta property="og:site_name" content="mbuzz">
<meta property="og:title" content="<%= content_for(:og_title) || content_for(:title) || "mbuzz - Server-Side Multi-Touch Attribution" %>">
<meta property="og:description" content="<%= content_for(:og_description) || content_for(:meta_description) || "Server-side multi-touch attribution you own. Track customer journeys, measure marketing ROI, and understand what drives conversions." %>">
<meta property="og:image" content="<%= content_for(:og_image) || "https://mbuzz.co/og-image.png" %>">
<meta property="og:url" content="<%= content_for(:canonical_url) || request.original_url.split("?").first %>">

<%# Twitter Card Tags %>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= content_for(:og_title) || content_for(:title) || "mbuzz - Server-Side Multi-Touch Attribution" %>">
<meta name="twitter:description" content="<%= content_for(:og_description) || content_for(:meta_description) || "Server-side multi-touch attribution you own. Track customer journeys, measure marketing ROI, and understand what drives conversions." %>">
<meta name="twitter:image" content="<%= content_for(:og_image) || "https://mbuzz.co/og-image.png" %>">

<%# RSS / Atom feed discovery %>
<link rel="alternate" type="application/rss+xml" title="MTA Academy — mbuzz" href="https://mbuzz.co/academy.rss">

<%# Site-wide JSON-LD: Organization + WebSite. Page-specific schema is layered via content_for(:head). %>
<script type="application/ld+json">
  <%= {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://mbuzz.co/#organization",
        name: "mbuzz",
        url: "https://mbuzz.co",
        logo: "https://mbuzz.sfo3.digitaloceanspaces.com/brand-assets/directory-listings/logo-square-1024.png",
        description: "Multi-touch attribution that shows the model behind every number. Eight attribution models side-by-side, an Attribution DSL, open-source SDKs.",
        sameAs: [
          "https://github.com/mbuzzco",
          "https://www.linkedin.com/company/mbuzzco"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://mbuzz.co/#website",
        url: "https://mbuzz.co",
        name: "mbuzz",
        description: "Server-side multi-touch attribution for technical marketers.",
        publisher: { "@id": "https://mbuzz.co/#organization" },
        inLanguage: "en-US"
      }
    ]
  }.to_json.html_safe %>
</script>

<%= stylesheet_link_tag "tailwind", "inter-font",
  "components/cards", "components/features", "components/icons", "components/code", "components/leaderboard",
  "utilities/animations", "utilities/backgrounds", "utilities/scrollbar",
  "pages/home",
  "data-turbo-track": "reload" %>
<%= javascript_importmap_tags %>
