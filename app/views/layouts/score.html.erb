<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "Which Marketing Channels Are Actually Working? — Free Assessment | mbuzz" %></title>
    <meta name="description" content="<%= content_for(:meta_description) || "Free marketing measurement maturity assessment. Get a personalised report, a roadmap to fix what's broken, and a business case for your CFO. 10 questions. 3 minutes." %>">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= request.protocol %><%= request.host_with_port %>/measurement-maturity-assessment">
    <meta property="og:title" content="<%= content_for(:og_title) || "Which Marketing Channels Are Actually Working?" %>">
    <meta property="og:description" content="<%= content_for(:og_description) || "Free assessment with personalised report, business case, and roadmap. Get your team involved. 10 questions. 3 minutes." %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.protocol %><%= request.host_with_port %>/measurement-maturity-assessment">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Marketing Measurement Maturity Assessment — Free">
    <meta name="twitter:description" content="Could you prove your marketing budget is working? Free assessment. 10 questions. 3 minutes.">
    <%= csrf_meta_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "pages/score/landing", "pages/score/signup", "pages/score/dashboard", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
    <%= render "score/assessments/structured_data" if content_for?(:structured_data) || controller.action_name == "show" %>
  </head>
  <body>
    <%= render "shared/gtm_loader" %>
    <%= yield %>
    <%= render "shared/consent_banner" %>
  </body>
</html>
