<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "Measurement Maturity Score — Free Marketing Assessment | mbuzz" %></title>
    <meta name="description" content="<%= content_for(:meta_description) || "Could you prove your marketing budget is working? 10 questions. 3 minutes. A measurement maturity score based on peer-reviewed research." %>">
    <meta property="og:title" content="<%= content_for(:og_title) || "Could You Defend Your Marketing Budget Tomorrow?" %>">
    <meta property="og:description" content="<%= content_for(:og_description) || "Most marketing leaders can't prove their spend is working. Find out where you stand in 3 minutes — free, private, research-backed." %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url.split("?").first %>">
    <%= csrf_meta_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "pages/score/landing", "pages/score/signup", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
