<nav class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <%= link_to (current_user ? dashboard_path : root_path), class: "flex items-center gap-1" do %>
        <div class="p-1.5">
          <svg width="24" height="24" viewBox="0 0 963 963" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: block;">
            <path d="M60.2819 352C36.0202 352 14.0154 362.255 4.6117 378.033C-4.79205 393.811 0.474051 411.823 17.7769 423.788L361.202 664.001V814.809C361.202 825.984 367.596 836.634 378.881 844.523L499.249 928.67C516.552 940.766 542.318 944.316 564.887 937.742C587.456 931.168 601.938 915.917 601.938 898.956V664.001L945.363 423.919C962.666 411.823 967.744 393.811 958.34 378.033C948.936 362.255 927.12 352 902.858 352H60.2819Z" fill="#1F2937" />
            <rect x="57" y="120" width="199" height="210" rx="6" fill="#6366F1" />
            <rect x="290" y="49" width="177" height="153" rx="8" fill="#EC4899" />
            <rect x="501" y="3" width="175" height="273" rx="8" fill="#10B981" />
            <rect x="710" y="172" width="207" height="158" rx="6" fill="#F59E0B" />
          </svg>
        </div>
        <span class="text-2xl font-bold text-gray-900">mbuzz</span>
      <% end %>

      <% if current_user %>
        <!-- Signed In: Account & User Dropdowns -->
        <div class="flex items-center gap-3">
          <!-- Account Dropdown -->
          <div data-controller="toggle" data-toggle-close-on-click-outside-value="true" class="relative">
            <button type="button" data-action="click->toggle#toggle" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:text-gray-900 rounded-md hover:bg-gray-50">
              <span class="font-medium"><%= current_account.name %></span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div data-toggle-target="content" class="hidden absolute right-0 mt-1 w-56 bg-white border border-gray-200 rounded-md shadow-lg z-20">
              <!-- Account List -->
              <div class="py-1">
                <% current_user.active_memberships.each do |membership| %>
                  <%= link_to dashboard_path(account_id: membership.account.prefix_id),
                    class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 #{current_account?(membership.account) ? 'bg-gray-50' : ''}" do %>
                    <% if current_account?(membership.account) %>
                      <svg class="w-4 h-4 text-indigo-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                    <% else %>
                      <span class="w-4 flex-shrink-0"></span>
                    <% end %>
                    <span class="flex-1 truncate <%= current_account?(membership.account) ? 'font-medium text-gray-900' : '' %>"><%= membership.account.name %></span>
                    <%= render_compact_role_badge(membership.role) %>
                  <% end %>
                <% end %>
              </div>

              <% if current_user.pending_invitations.any? %>
                <div class="border-t border-gray-100"></div>

                <!-- Pending Invitations -->
                <div class="py-1">
                  <div class="px-4 py-1 text-xs font-medium text-gray-500 uppercase tracking-wider">Pending Invitations</div>
                  <% current_user.pending_invitations.each do |invitation| %>
                    <%= button_to accept_pending_invitation_path(invitation.prefix_id),
                      class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-yellow-50" do %>
                      <svg class="w-4 h-4 text-yellow-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                      <span class="flex-1 truncate text-left"><%= invitation.account.name %></span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-yellow-100 text-yellow-700">Accept</span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>

              <div class="border-t border-gray-100"></div>

              <!-- Create Account -->
              <div class="py-1">
                <%= link_to new_account_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                  Create Account
                <% end %>
              </div>

              <div class="border-t border-gray-100"></div>

              <!-- Account Settings -->
              <div class="py-1">
                <%= link_to account_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Account Settings
                <% end %>
              </div>
            </div>
          </div>

          <!-- User Dropdown -->
          <div data-controller="toggle" data-toggle-close-on-click-outside-value="true" class="relative">
            <button type="button" data-action="click->toggle#toggle" class="flex items-center justify-center w-8 h-8 rounded-full bg-gray-200 hover:bg-gray-300">
              <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </button>
            <div data-toggle-target="content" class="hidden absolute right-0 mt-1 w-48 bg-white border border-gray-200 rounded-md shadow-lg z-20">
              <div class="px-4 py-2 border-b border-gray-100">
                <p class="text-sm font-medium text-gray-900 truncate"><%= current_user.email %></p>
              </div>
              <%= button_to "Logout", logout_path, method: :delete, class: "w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            </div>
          </div>
        </div>
      <% else %>
        <!-- Signed Out: Public Links -->
        <div class="flex items-center gap-6">
          <%= link_to "Demo", demo_path, class: "hidden md:block text-sm text-gray-600 hover:text-gray-900 transition-colors" %>
          <%= link_to "Docs", docs_path('getting-started'), class: "hidden md:block text-sm text-gray-600 hover:text-gray-900 transition-colors" %>
          <%= link_to "Login", login_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" %>
          <%= link_to "Get Started", signup_path, class: "text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 px-4 py-2 rounded-md transition-all" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
