<!DOCTYPE html>
<html>
  <head>
    <title>mbuzz API Documentation</title>
    <%= render "layouts/head" %>
  </head>

  <body class="bg-gray-50">
    <div class="min-h-screen">
      <%= render "layouts/nav" %>

      <!-- Docs Navigation -->
      <nav class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex gap-6 py-3">
            <%= link_to "Getting Started", docs_path(page: "getting-started"), class: "text-sm #{params[:page] == 'getting-started' ? 'text-indigo-600 font-medium' : 'text-gray-600 hover:text-gray-900'}" %>
            <%= link_to "Authentication", docs_path(page: "authentication"), class: "text-sm #{params[:page] == 'authentication' ? 'text-indigo-600 font-medium' : 'text-gray-600 hover:text-gray-900'}" %>
            <%= link_to "API Reference", docs_path(page: "api-reference"), class: "text-sm #{params[:page] == 'api-reference' ? 'text-indigo-600 font-medium' : 'text-gray-600 hover:text-gray-900'}" %>
            <%= link_to "Examples", docs_path(page: "examples"), class: "text-sm #{params[:page] == 'examples' ? 'text-indigo-600 font-medium' : 'text-gray-600 hover:text-gray-900'}" %>
          </div>
        </div>
      </nav>

      <!-- Main Content -->
      <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <article class="prose prose-gray prose-lg max-w-none
                       prose-headings:font-bold prose-headings:text-gray-900
                       prose-h1:text-4xl prose-h1:mb-8 prose-h1:tracking-tight
                       prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:tracking-tight
                       prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3
                       prose-p:text-gray-600 prose-p:leading-relaxed prose-p:text-base
                       prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-a:font-medium
                       prose-code:text-sm prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none prose-code:text-gray-900 prose-code:font-mono
                       prose-pre:bg-gray-900 prose-pre:text-gray-100 prose-pre:rounded-lg prose-pre:shadow-lg
                       prose-ul:list-disc prose-ul:space-y-2 prose-ol:list-decimal prose-ol:space-y-2
                       prose-li:text-gray-600
                       prose-strong:text-gray-900 prose-strong:font-semibold
                       prose-table:border-collapse prose-th:border prose-th:border-gray-300 prose-th:bg-gray-50 prose-th:p-3 prose-th:text-left prose-th:font-semibold
                       prose-td:border prose-td:border-gray-300 prose-td:p-3">
          <%= yield %>
        </article>
      </main>

      <!-- Footer -->
      <footer class="border-t border-gray-200 mt-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <p class="text-center text-gray-500 text-sm">
            &copy; <%= Time.current.year %> mbuzz.
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
