<div class="min-h-screen bg-white">
  <!-- Navigation -->
  <nav class="bg-white border-b border-gray-200" data-controller="toggle">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo -->
        <div class="flex items-center gap-4">
          <div class="p-1.5">
            <svg width="24" height="24" viewBox="0 0 963 963" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: block;">
              <path d="M60.2819 352C36.0202 352 14.0154 362.255 4.6117 378.033C-4.79205 393.811 0.474051 411.823 17.7769 423.788L361.202 664.001V814.809C361.202 825.984 367.596 836.634 378.881 844.523L499.249 928.67C516.552 940.766 542.318 944.316 564.887 937.742C587.456 931.168 601.938 915.917 601.938 898.956V664.001L945.363 423.919C962.666 411.823 967.744 393.811 958.34 378.033C948.936 362.255 927.12 352 902.858 352H60.2819Z" fill="#1F2937"/>
              <rect x="57" y="120" width="199" height="210" rx="6" fill="#6366F1"/>
              <rect x="290" y="49" width="177" height="153" rx="8" fill="#EC4899"/>
              <rect x="501" y="3" width="175" height="273" rx="8" fill="#10B981"/>
              <rect x="710" y="172" width="207" height="158" rx="6" fill="#F59E0B"/>
            </svg>
          </div>
          <h1 class="text-2xl font-semibold text-gray-900">
            <%= t('pages.home.nav.brand') %>
          </h1>
        </div>

        <!-- Right-aligned Navigation -->
        <div class="flex items-center gap-4">
          <!-- Desktop-only links -->
          <a href="#features" class="hidden md:block text-sm text-gray-600 hover:text-gray-900 transition-colors">
            <%= t('pages.home.nav.features') %>
          </a>
          <%= link_to t('pages.home.nav.docs'), docs_path('getting-started'), class: "hidden md:block text-sm text-gray-600 hover:text-gray-900 transition-colors" %>

          <% if current_user %>
            <!-- Signed in: Show Dashboard button -->
            <%= link_to "Dashboard", dashboard_path, class: "text-sm font-medium text-white bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-md transition-all" %>
          <% else %>
            <!-- Signed out: Show Login and Start -->
            <%= link_to t('pages.home.nav.login'), login_path, class: "hidden md:block text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" %>
            <%= link_to "Start", new_waitlist_path, class: "text-sm font-medium text-white bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-md transition-all" %>
          <% end %>

          <!-- Mobile hamburger -->
          <button type="button" data-action="click->toggle#toggle" class="md:hidden text-gray-600 hover:text-gray-900 p-1">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu Dropdown -->
      <div data-toggle-target="content" class="hidden border-t border-gray-200 py-4 md:hidden">
        <div class="space-y-2">
          <a href="#features" class="block px-4 py-2 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md transition-colors">
            <%= t('pages.home.nav.features') %>
          </a>
          <%= link_to t('pages.home.nav.docs'), docs_path('getting-started'), class: "block px-4 py-2 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md transition-colors" %>
          <% if current_user %>
            <%= link_to "Dashboard", dashboard_path, class: "block px-4 py-2 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md transition-colors" %>
          <% else %>
            <%= link_to t('pages.home.nav.login'), login_path, class: "block px-4 py-2 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="py-24 px-6 bg-pattern-dots">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-sm font-medium text-blue-600 uppercase tracking-wide mb-4 scroll-animate" data-controller="scroll-reveal">
        Server-Side Multi-Touch Attribution
      </h1>
      <p class="text-5xl md:text-6xl font-bold text-gray-900 tracking-tight scroll-animate" data-controller="scroll-reveal">
        Stop renting your attribution.
        <span class="block mt-2">Own it.</span>
      </p>
      <p class="mt-8 text-xl text-gray-600 max-w-3xl mx-auto scroll-animate" data-controller="scroll-reveal">
        Black-box models. Inflated platform ROAS. Data you can't export.
        <span class="font-medium text-gray-900">Sound familiar?</span>
        mbuzz puts you back in control.
      </p>
      <div class="mt-10 flex justify-center gap-4 scroll-animate" data-controller="scroll-reveal">
        <%= link_to t('pages.home.hero.cta_primary'), new_waitlist_path, class: "px-6 py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all" %>
        <%= link_to t('pages.home.hero.cta_secondary'), docs_path('getting-started'), class: "px-6 py-3 text-sm font-semibold text-gray-900 bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 rounded-md transition-all" %>
      </div>
      <p class="mt-6 text-sm text-gray-500">
        Server-side SDKs for Ruby, Python, PHP & REST API
      </p>
    </div>
  </section>

  <!-- Dashboard Preview -->
  <section class="pb-24 px-6 -mt-8">
    <div class="max-w-6xl mx-auto">
      <div class="bg-white rounded-xl shadow-2xl border border-gray-200 overflow-hidden">
        <!-- Dashboard Header -->
        <div class="bg-gray-50 border-b border-gray-200 px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-6">
            <span class="text-sm font-medium text-indigo-600 border-b-2 border-indigo-600 pb-1">Conversions</span>
            <span class="text-sm text-gray-500">Funnel</span>
            <span class="text-sm text-gray-500">Events</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-500 bg-white px-3 py-1.5 rounded border border-gray-200">Last 30 days</span>
            <span class="text-xs text-gray-500 bg-white px-3 py-1.5 rounded border border-gray-200">First Touch</span>
          </div>
        </div>

        <!-- KPI Cards -->
        <div class="p-6">
          <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
            <div class="bg-white p-5 rounded-lg border-2 border-indigo-500 shadow-sm">
              <div class="text-sm font-medium text-gray-500">Conversions</div>
              <div class="mt-1 flex items-baseline gap-2">
                <span class="text-2xl font-semibold text-gray-900">2,847</span>
                <span class="text-sm text-green-600">+12.3%</span>
              </div>
              <div class="mt-1 text-xs text-gray-400">vs 2,534 prior</div>
            </div>
            <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm">
              <div class="text-sm font-medium text-gray-500">Revenue</div>
              <div class="mt-1 flex items-baseline gap-2">
                <span class="text-2xl font-semibold text-gray-900">$284,720</span>
                <span class="text-sm text-green-600">+18.7%</span>
              </div>
              <div class="mt-1 text-xs text-gray-400">vs $239,891 prior</div>
            </div>
            <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm">
              <div class="text-sm font-medium text-gray-500">Avg Order Value</div>
              <div class="mt-1 flex items-baseline gap-2">
                <span class="text-2xl font-semibold text-gray-900">$100</span>
                <span class="text-sm text-green-600">+5.6%</span>
              </div>
              <div class="mt-1 text-xs text-gray-400">vs $94.71 prior</div>
            </div>
            <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm">
              <div class="text-sm font-medium text-gray-500">Avg Days to Convert</div>
              <div class="mt-1">
                <span class="text-2xl font-semibold text-gray-900">4.2</span>
              </div>
              <div class="mt-1 text-xs text-gray-400">from first touch</div>
            </div>
            <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm">
              <div class="text-sm font-medium text-gray-500">Avg Channels</div>
              <div class="mt-1">
                <span class="text-2xl font-semibold text-gray-900">2.8</span>
              </div>
              <div class="mt-1 text-xs text-gray-400">per conversion</div>
            </div>
            <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm">
              <div class="text-sm font-medium text-gray-500">Avg Visits</div>
              <div class="mt-1">
                <span class="text-2xl font-semibold text-gray-900">5.3</span>
              </div>
              <div class="mt-1 text-xs text-gray-400">per conversion</div>
            </div>
          </div>

          <!-- Charts Row -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Time Series Chart -->
            <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-medium text-gray-900">Channel Performance Over Time</h3>
                <div class="flex items-center gap-3 text-xs">
                  <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-indigo-500"></span> Paid Search</span>
                  <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-pink-500"></span> Email</span>
                  <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-lime-500"></span> Organic</span>
                </div>
              </div>
              <!-- SVG Chart -->
              <svg viewBox="0 0 400 120" class="w-full h-32">
                <!-- Grid lines -->
                <line x1="0" y1="30" x2="400" y2="30" stroke="#f3f4f6" stroke-width="1"/>
                <line x1="0" y1="60" x2="400" y2="60" stroke="#f3f4f6" stroke-width="1"/>
                <line x1="0" y1="90" x2="400" y2="90" stroke="#f3f4f6" stroke-width="1"/>

                <!-- Paid Search line (indigo) -->
                <polyline fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  points="0,80 40,75 80,65 120,70 160,55 200,45 240,50 280,35 320,40 360,25 400,20"/>

                <!-- Email line (pink) -->
                <polyline fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  points="0,90 40,88 80,85 120,82 160,78 200,75 240,72 280,68 320,65 360,60 400,55"/>

                <!-- Organic line (lime) -->
                <polyline fill="none" stroke="#84cc16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                  points="0,95 40,93 80,90 120,92 160,88 200,85 240,87 280,82 320,80 360,78 400,75"/>

                <!-- X-axis labels -->
                <text x="0" y="115" font-size="10" fill="#9ca3af">Nov 6</text>
                <text x="95" y="115" font-size="10" fill="#9ca3af">Nov 13</text>
                <text x="195" y="115" font-size="10" fill="#9ca3af">Nov 20</text>
                <text x="295" y="115" font-size="10" fill="#9ca3af">Nov 27</text>
                <text x="370" y="115" font-size="10" fill="#9ca3af">Dec 4</text>
              </svg>
            </div>

            <!-- Bar Chart -->
            <div class="bg-white p-5 rounded-lg border border-gray-200 shadow-sm">
              <h3 class="text-sm font-medium text-gray-900 mb-4">Conversions by Channel</h3>
              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-600 w-20 text-right">Paid Search</span>
                  <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
                    <div class="bg-indigo-500 h-full rounded-full" style="width: 85%"></div>
                  </div>
                  <span class="text-xs font-medium text-gray-900 w-16">$142,360</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-600 w-20 text-right">Email</span>
                  <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
                    <div class="bg-pink-500 h-full rounded-full" style="width: 52%"></div>
                  </div>
                  <span class="text-xs font-medium text-gray-900 w-16">$71,180</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-600 w-20 text-right">Organic</span>
                  <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
                    <div class="bg-lime-500 h-full rounded-full" style="width: 35%"></div>
                  </div>
                  <span class="text-xs font-medium text-gray-900 w-16">$42,708</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-600 w-20 text-right">Direct</span>
                  <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
                    <div class="bg-gray-400 h-full rounded-full" style="width: 18%"></div>
                  </div>
                  <span class="text-xs font-medium text-gray-900 w-16">$21,354</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-600 w-20 text-right">Referral</span>
                  <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
                    <div class="bg-orange-500 h-full rounded-full" style="width: 8%"></div>
                  </div>
                  <span class="text-xs font-medium text-gray-900 w-16">$7,118</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Subtle caption -->
      <p class="text-center text-sm text-gray-400 mt-4">
        Real-time attribution dashboard • Compare models side-by-side • Export anytime
      </p>
    </div>
  </section>

  <!-- Why Attribution is Broken -->
  <section class="py-20 px-6 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">
        Why attribution is broken
      </h2>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto">
        The tools that should help you are working against you.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">GA4 killed your model choice</h3>
              <p class="mt-1 text-gray-600 text-sm">First-touch, linear, time-decay — all gone. Now you get last-click or a black-box "data-driven" model you can't inspect.</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Platforms grade their own homework</h3>
              <p class="mt-1 text-gray-600 text-sm">Facebook says Facebook works. Google says Google works. Shocking. Their inflated ROAS numbers don't match reality.</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Ad blockers eat 30% of your data</h3>
              <p class="mt-1 text-gray-600 text-sm">Client-side tracking misses nearly a third of visitors. You're making budget decisions on incomplete data.</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Enterprise pricing for basic features</h3>
              <p class="mt-1 text-gray-600 text-sm">Amplitude starts at $2,000/mo. Segment charges $120/mo just to collect events. Attribution shouldn't require a finance committee.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The mbuzz Way: Three Pillars -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">
        Accurate. Affordable. Yours.
      </h2>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto">
        Attribution that works for you, not against you.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Pillar 1: Accurate -->
        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Accurate</h3>
          <p class="text-gray-600">
            Server-side tracking that ad blockers can't touch. Capture 95%+ of events, not the 70% you get with client-side scripts.
          </p>
        </div>

        <!-- Pillar 2: Affordable -->
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Affordable</h3>
          <p class="text-gray-600">
            Free up to 10K events/month. Pro plans at 1/10th the price of Amplitude or Segment. No sales calls required.
          </p>
        </div>

        <!-- Pillar 3: Yours -->
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Yours</h3>
          <p class="text-gray-600">
            7 attribution models built-in. Write custom models with our simple editor. Export everything, anytime. No lock-in.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900">
          <%= t('pages.home.features.title') %>
        </h2>
        <p class="mt-4 text-xl text-gray-600">
          <%= t('pages.home.features.subtitle') %>
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Feature 1: 10-Minute Setup -->
        <div class="feature scroll-animate" data-controller="scroll-reveal">
          <div class="feature__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="feature__title">
            <%= t('pages.home.features.privacy_tracking.title') %>
          </h3>
          <p class="feature__description">
            <%= t('pages.home.features.privacy_tracking.description') %>
          </p>
        </div>

        <!-- Feature 2: 7 Attribution Models -->
        <div class="feature scroll-animate" data-controller="scroll-reveal">
          <div class="feature__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
            </svg>
          </div>
          <h3 class="feature__title">
            <%= t('pages.home.features.dark_funnel.title') %>
          </h3>
          <p class="feature__description">
            <%= t('pages.home.features.dark_funnel.description') %>
          </p>
        </div>

        <!-- Feature 3: Roll Your Own Custom Models -->
        <div class="feature scroll-animate" data-controller="scroll-reveal">
          <div class="feature__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="feature__title">
            <%= t('pages.home.features.quick_setup.title') %>
          </h3>
          <p class="feature__description">
            <%= t('pages.home.features.quick_setup.description') %>
          </p>
        </div>

        <!-- Feature 4: Server-Side All The Way -->
        <div class="feature scroll-animate" data-controller="scroll-reveal">
