<% content_for(:title) { "Cookie Policy" } %>
<% content_for(:meta_description) { "mbuzz Cookie Policy. Learn about the cookies we use to provide our multi-touch attribution service." } %>
<% content_for(:canonical_url) { cookies_url } %>

<%= render "layouts/nav" %>

<div class="min-h-screen bg-white">
  <!-- Header -->
  <section class="py-16 px-6 border-b border-gray-200">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold text-gray-900 tracking-tight">Cookie Policy</h1>
      <p class="mt-4 text-gray-600">Last updated: April 13, 2026</p>
      <div class="mt-6">
        <button type="button"
                data-action="click->consent-banner#openModal"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-500">
          Manage cookie preferences
        </button>
      </div>
    </div>
  </section>

  <!-- TL;DR Section -->
  <section class="py-12 px-6 bg-blue-50 border-b border-blue-100">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-xl font-bold text-gray-900 mb-4">TL;DR</h2>
      <ul class="space-y-2 text-gray-700">
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Essential cookies (login, security) are always on</span>
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Analytics and advertising cookies load only after you consent</span>
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Full list below — we tell you exactly what each cookie does</span>
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Manage your preferences anytime with the button above</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12 px-6">
    <div class="max-w-3xl mx-auto prose prose-gray">

      <!-- What Are Cookies -->
      <h2>What are cookies?</h2>
      <p>
        Cookies are small text files stored on your device when you visit a website. They help websites
        remember information about your visit, like keeping you logged in or remembering your preferences.
      </p>

      <!-- Our Approach -->
      <h2>Our approach to cookies</h2>
      <p>
        We believe in minimal, transparent data collection. Essential cookies are always on because
        they're required for the site to function. Analytics and advertising cookies are loaded only
        after you give consent via the cookie banner. You can change your mind at any time.
      </p>

      <!-- Cookies We Use -->
      <h2>Cookies we use</h2>
      <p>
        Here's a complete list of cookies we set:
      </p>

      <h3>Essential cookies (always on)</h3>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>Cookie</th>
              <th>Provider</th>
              <th>Purpose</th>
              <th>Duration</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>_mbuzz_session</code></td>
              <td>mbuzz</td>
              <td>Keeps you logged in to your account</td>
              <td>Session or 2 weeks</td>
            </tr>
            <tr>
              <td><code>_csrf_token</code></td>
              <td>mbuzz</td>
              <td>Security token to prevent cross-site request forgery</td>
              <td>Session</td>
            </tr>
            <tr>
              <td><code>_mbuzz_vid</code></td>
              <td>mbuzz</td>
              <td>Visitor identifier for server-side attribution (first-party, no cross-site tracking)</td>
              <td>2 years</td>
            </tr>
            <tr>
              <td><code>mbuzz_consent</code></td>
              <td>mbuzz</td>
              <td>Stores your cookie preference choices so we don't re-ask</td>
              <td>1 year</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3>Analytics cookies (consent required)</h3>
      <p>These load only after you accept analytics cookies via the cookie banner.</p>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>Cookie</th>
              <th>Provider</th>
              <th>Purpose</th>
              <th>Duration</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>_ga</code></td>
              <td>Google Analytics 4</td>
              <td>Distinguishes unique visitors</td>
              <td>2 years</td>
            </tr>
            <tr>
              <td><code>_ga_*</code></td>
              <td>Google Analytics 4</td>
              <td>Maintains session state</td>
              <td>2 years</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3>Advertising cookies (consent required)</h3>
      <p>These load only after you accept advertising cookies via the cookie banner.</p>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>Cookie</th>
              <th>Provider</th>
              <th>Purpose</th>
              <th>Duration</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>_gcl_au</code></td>
              <td>Google Ads</td>
              <td>Stores conversion information for Google Ads</td>
              <td>90 days</td>
            </tr>
            <tr>
              <td><code>_fbp</code></td>
              <td>Meta Pixel</td>
              <td>Identifies the browser for Meta ad delivery and measurement</td>
              <td>90 days</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Consent and control -->
      <h2>Your control</h2>
      <p>
        If you're in the EU, UK, Switzerland, or California, we show a cookie banner before loading
        any analytics or advertising cookies. You can accept all, reject all, or customise your
        preferences. Everyone else can manage preferences anytime using the button at the top of this
        page. Essential cookies cannot be disabled because the site doesn't work without them.
      </p>

      <!-- Third-Party Services -->
      <h2>Third-party services</h2>
      <p>
        Some pages may load content from third-party services that set their own cookies:
      </p>
      <ul>
        <li><strong>Google (Analytics 4 + Ads)</strong> — Sets <code>_ga</code>, <code>_ga_*</code>,
        and <code>_gcl_au</code> cookies for analytics and ad conversion measurement. Loaded only
        after consent. See
        <a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-500">Google's privacy policy</a></li>
        <li><strong>Meta (Pixel)</strong> — Sets the <code>_fbp</code> cookie for Meta ad measurement.
        Loaded only after consent. See
        <a href="https://www.facebook.com/privacy/policy" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-500">Meta's privacy policy</a></li>
        <li><strong>Stripe</strong> — For payment processing on the billing page. Stripe may set
        its own cookies for fraud prevention. See
        <a href="https://stripe.com/privacy" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-500">Stripe's privacy policy</a></li>
      </ul>
      <p>
        We don't control cookies set by third parties. Their use is governed by their own privacy policies.
      </p>

      <!-- Managing Cookies -->
      <h2>Managing cookies</h2>
      <p>
        You can control cookies through your browser settings. Most browsers let you:
      </p>
      <ul>
        <li>See what cookies are set</li>
        <li>Delete individual cookies or all cookies</li>
        <li>Block cookies from specific sites</li>
        <li>Block all cookies</li>
      </ul>
      <p>
        Here's how to manage cookies in common browsers:
      </p>
      <ul>
        <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-500">Google Chrome</a></li>
        <li><a href="https://support.mozilla.org/en-US/kb/cookies-information-websites-store-on-your-computer" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-500">Mozilla Firefox</a></li>
        <li><a href="https://support.apple.com/guide/safari/manage-cookies-sfri11471/mac" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-500">Safari</a></li>
        <li><a href="https://support.microsoft.com/en-us/microsoft-edge/delete-cookies-in-microsoft-edge-63947406-40ac-c3b8-57b9-2a946a29ae09" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-500">Microsoft Edge</a></li>
      </ul>
      <p>
        <strong>Note</strong>: If you block our essential cookies, you won't be able to log in to mbuzz.
        The public pages (like this one) will still work.
      </p>

      <!-- Do Not Track -->
      <h2>Do Not Track</h2>
      <p>
        Some browsers send a "Do Not Track" (DNT) signal. We respect DNT by defaulting all analytics
        and advertising cookies to disabled until you explicitly consent.
      </p>

      <!-- Changes -->
      <h2>Changes to this policy</h2>
      <p>
        If we start using additional cookies, we'll update this page and notify you. Any significant
        changes will be communicated via email to account holders.
      </p>

      <!-- Contact -->
      <h2>Questions?</h2>
      <p>
        If you have questions about our cookie practices,
        <%= link_to "get in touch", contact_path, class: "text-blue-600 hover:text-blue-500" %>.
      </p>
    </div>
  </section>
</div>

<%= render "layouts/footer" %>
