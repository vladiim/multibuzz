<section class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 text-center mb-4 scroll-animate" data-controller="scroll-reveal">
      From overview to individual conversion
    </h2>
    <p class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto scroll-animate" data-controller="scroll-reveal">
      Not just dashboards: the actual conversions, journeys, and spend behind your numbers.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden scroll-animate" data-controller="scroll-reveal">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm font-semibold text-gray-900">Spend & Experiments</span>
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Run spend scenarios before you commit</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Model "what if I shifted $10K from Meta to Google?" before you actually move the money. See the projected ROAS impact across every channel, side by side.
          </p>
          <p class="mt-3 text-xs text-gray-500">
            What-if modelling &bull; Cross-channel projections &bull; Reallocation suggestions
          </p>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden scroll-animate" data-controller="scroll-reveal">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            <span class="text-sm font-semibold text-gray-900">Explore Conversions</span>
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Browse every conversion</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            See every conversion in real-time: type, revenue, channels, and touchpoints. Click into any one to walk the full customer journey from first visit to purchase.
          </p>
          <p class="mt-3 text-xs text-gray-500">
            Journey visualization &bull; Touchpoint timeline &bull; Attribution credits
          </p>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden scroll-animate" data-controller="scroll-reveal">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="text-sm font-semibold text-gray-900">Identity Profiles</span>
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Know your customers</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Match anonymous sessions to real people as they identify themselves. See the complete cross-session journey, from first anonymous visit through every return to conversion.
          </p>
          <p class="mt-3 text-xs text-gray-500">
            Cross-session stitching &bull; Visitor profiles &bull; Revenue attribution
          </p>
        </div>
      </div>
    </div>

    <div class="text-center mt-10 scroll-animate" data-controller="scroll-reveal">
      <%= link_to demo_path, class: "inline-flex items-center px-5 py-2.5 text-sm font-medium text-blue-600 bg-white border border-blue-600 rounded-md hover:bg-blue-50 transition-all" do %>
        See it in the demo
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      <% end %>
    </div>
  </div>
</section>
