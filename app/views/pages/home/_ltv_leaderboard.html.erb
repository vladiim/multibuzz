<section class="py-24 px-6 bg-gray-900 overflow-hidden">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12 scroll-animate" data-controller="scroll-reveal">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Your worst channel might be your best.
      </h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">
        First-month revenue tells one story. Lifetime revenue tells another.
        Most attribution tools only show you the first chapter.
      </p>
    </div>

    <div class="scroll-animate" data-controller="scroll-reveal toggle" data-toggle-default-value="first-month">
      <!-- Toggle buttons -->
      <div class="flex justify-center gap-2 mb-8">
        <button
          type="button"
          data-toggle-target="trigger"
          data-value="first-month"
          data-action="toggle#select"
          class="leaderboard-tab"
        >
          First Month
        </button>
        <button
          type="button"
          data-toggle-target="trigger"
          data-value="lifetime"
          data-action="toggle#select"
          class="leaderboard-tab"
        >
          12-Month LTV
        </button>
      </div>

      <!-- First Month Leaderboard -->
      <div data-toggle-target="content" data-value="first-month" class="leaderboard-content">
        <div class="leaderboard-container">
          <div class="leaderboard-header">
            <span class="leaderboard-header__label">First Month Revenue</span>
            <span class="leaderboard-header__note">847 customers acquired</span>
          </div>

          <div class="leaderboard-rows">
            <div class="leaderboard-row">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank leaderboard-rank--gold">1</span>
                <div class="leaderboard-icon leaderboard-icon--facebook">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Facebook Ads</span>
              </div>
              <span class="leaderboard-revenue">$12,400</span>
            </div>

            <div class="leaderboard-row">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank leaderboard-rank--silver">2</span>
                <div class="leaderboard-icon leaderboard-icon--google">
                  <svg class="w-5 h-5" viewBox="0 0 24 24">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Google Ads</span>
              </div>
              <span class="leaderboard-revenue">$8,200</span>
            </div>

            <div class="leaderboard-row">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank leaderboard-rank--bronze">3</span>
                <div class="leaderboard-icon leaderboard-icon--linkedin">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">LinkedIn Ads</span>
              </div>
              <span class="leaderboard-revenue">$4,100</span>
            </div>

            <div class="leaderboard-row">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank">4</span>
                <div class="leaderboard-icon leaderboard-icon--organic">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Organic Search</span>
              </div>
              <span class="leaderboard-revenue">$2,800</span>
            </div>

            <div class="leaderboard-row">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank">5</span>
                <div class="leaderboard-icon leaderboard-icon--referral">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Referrals</span>
              </div>
              <span class="leaderboard-revenue">$1,900</span>
            </div>
          </div>

          <div class="leaderboard-footer">
            <span class="text-gray-500">Click "12-Month LTV" to see the real picture</span>
          </div>
        </div>
      </div>

      <!-- Lifetime Leaderboard -->
      <div data-toggle-target="content" data-value="lifetime" class="leaderboard-content hidden">
        <div class="leaderboard-container">
          <div class="leaderboard-header">
            <span class="leaderboard-header__label">12-Month Lifetime Revenue</span>
            <span class="leaderboard-header__note">Same 847 customers</span>
          </div>

          <div class="leaderboard-rows">
            <div class="leaderboard-row leaderboard-row--highlight">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank leaderboard-rank--gold">1</span>
                <div class="leaderboard-icon leaderboard-icon--referral">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Referrals</span>
              </div>
              <div class="leaderboard-row__right">
                <span class="leaderboard-revenue">$41,200</span>
                <span class="leaderboard-change leaderboard-change--up">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
                  </svg>
                  4
                </span>
              </div>
            </div>

            <div class="leaderboard-row leaderboard-row--highlight">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank leaderboard-rank--silver">2</span>
                <div class="leaderboard-icon leaderboard-icon--organic">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Organic Search</span>
              </div>
              <div class="leaderboard-row__right">
                <span class="leaderboard-revenue">$38,600</span>
                <span class="leaderboard-change leaderboard-change--up">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
                  </svg>
                  2
                </span>
              </div>
            </div>

            <div class="leaderboard-row">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank leaderboard-rank--bronze">3</span>
                <div class="leaderboard-icon leaderboard-icon--linkedin">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">LinkedIn Ads</span>
              </div>
              <div class="leaderboard-row__right">
                <span class="leaderboard-revenue">$31,400</span>
                <span class="leaderboard-change leaderboard-change--same">—</span>
              </div>
            </div>

            <div class="leaderboard-row leaderboard-row--dimmed">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank">4</span>
                <div class="leaderboard-icon leaderboard-icon--google">
                  <svg class="w-5 h-5" viewBox="0 0 24 24">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Google Ads</span>
              </div>
              <div class="leaderboard-row__right">
                <span class="leaderboard-revenue">$19,100</span>
                <span class="leaderboard-change leaderboard-change--down">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
                  2
                </span>
              </div>
            </div>

            <div class="leaderboard-row leaderboard-row--dimmed">
              <div class="leaderboard-row__left">
                <span class="leaderboard-rank">5</span>
                <div class="leaderboard-icon leaderboard-icon--facebook">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </div>
                <span class="leaderboard-channel">Facebook Ads</span>
              </div>
              <div class="leaderboard-row__right">
                <span class="leaderboard-revenue">$14,800</span>
                <span class="leaderboard-change leaderboard-change--down">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
                  4
                </span>
              </div>
            </div>
          </div>

          <div class="leaderboard-footer">
            <span class="text-emerald-400">Referrals delivered <strong>21x</strong> more revenue than first month suggested</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom copy -->
    <div class="mt-12 text-center scroll-animate" data-controller="scroll-reveal">
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">
        mbuzz tracks every recurring payment back to its original acquisition source.
        Stop optimizing for first-month vanity metrics.
      </p>
      <%= link_to "See LTV by Channel", signup_path, class: "inline-flex items-center gap-2 bg-white text-gray-900 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors" %>
    </div>
  </div>
</section>
