<section id="pricing" class="py-24 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 scroll-animate" data-controller="scroll-reveal">Start free. Scale affordably.</h2>
      <p class="mt-4 text-xl text-gray-600 scroll-animate" data-controller="scroll-reveal">
        Use all the features straight-away. No sales calls required.
      </p>
    </div>

    <div class="bg-white rounded-lg shadow-lg overflow-hidden scroll-animate" data-controller="scroll-reveal">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-900 text-white">
              <th class="px-6 py-4 text-left text-sm font-semibold">Tier</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Monthly Records</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Price/Month (USD)</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Effective $/1K Records</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="font-semibold text-gray-900">Free</div>
              </td>
              <td class="px-6 py-4 text-gray-600">&le;<%= free_event_limit_display %></td>
              <td class="px-6 py-4">
                <div class="text-xl font-bold text-gray-900">$0</div>
              </td>
              <td class="px-6 py-4 text-gray-500">&mdash;</td>
            </tr>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="font-semibold text-gray-900">Starter</div>
              </td>
              <td class="px-6 py-4 text-gray-600">&le;1M</td>
              <td class="px-6 py-4">
                <div class="text-xl font-bold text-gray-900">$29</div>
              </td>
              <td class="px-6 py-4 text-gray-600">$0.029</td>
            </tr>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="font-semibold text-gray-900">Growth</div>
              </td>
              <td class="px-6 py-4 text-gray-600">&le;5M</td>
              <td class="px-6 py-4">
                <div class="text-xl font-bold text-gray-900">$99</div>
              </td>
              <td class="px-6 py-4 text-gray-600">$0.020</td>
            </tr>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="font-semibold text-gray-900">Pro</div>
              </td>
              <td class="px-6 py-4 text-gray-600">&le;25M</td>
              <td class="px-6 py-4">
                <div class="text-xl font-bold text-gray-900">$299</div>
              </td>
              <td class="px-6 py-4 text-gray-600">$0.012</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-4 text-sm text-gray-500 text-center scroll-animate" data-controller="scroll-reveal">
      Records include visitors, sessions, events, and conversions.
    </p>
    <p class="mt-2 text-sm text-gray-500 text-center scroll-animate" data-controller="scroll-reveal">
      * Overages billed in blocks: Starter $5/250K, Growth $15/1M, Pro $50/5M records.
    </p>

    <div class="mt-12 text-center scroll-animate" data-controller="scroll-reveal">
      <%= link_to "Get Started Free", signup_path, class: "inline-block px-8 py-4 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-all shadow-sm" %>
      <p class="mt-4 text-sm text-gray-500">
        Not sure yet? <%= link_to "Try the demo first", demo_path, class: "text-blue-600 hover:text-blue-700" %>
      </p>
    </div>
  </div>
</section>
