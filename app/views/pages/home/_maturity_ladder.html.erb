<section class="py-24 px-6 bg-gradient-to-b from-white to-gray-50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12 scroll-animate" data-controller="scroll-reveal">
      <p class="text-sm font-medium text-blue-600 uppercase tracking-wide mb-3">
        Free, no signup
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
        Where does your team sit on the attribution maturity ladder?
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        We synthesised the
        <%= link_to "MAMM, IEEE, and LiveRamp maturity frameworks",
              article_path("measurement-maturity-map"),
              class: "underline decoration-dotted underline-offset-4 hover:text-blue-600" %>
        into a 3-minute self-score across six dimensions.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-10 scroll-animate" data-controller="scroll-reveal">
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Level 1</span>
        <h3 class="font-bold text-gray-900 mt-2 mb-2"><%= Score::LEVEL_NAMES[1] %></h3>
        <p class="text-sm text-gray-600">Spreadsheets and gut. Platform reports taken at face value.</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Level 2</span>
        <h3 class="font-bold text-gray-900 mt-2 mb-2"><%= Score::LEVEL_NAMES[2] %></h3>
        <p class="text-sm text-gray-600">A single dashboard exists. Numbers flow. Not yet questioned.</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Level 3</span>
        <h3 class="font-bold text-gray-900 mt-2 mb-2"><%= Score::LEVEL_NAMES[3] %></h3>
        <p class="text-sm text-gray-600">Multi-touch attribution. Models compared. Spend reallocated on evidence.</p>
      </div>
      <div class="bg-blue-600 text-white rounded-xl p-5 shadow-lg ring-2 ring-blue-400">
        <span class="text-xs font-semibold text-blue-200 uppercase tracking-wide">Level 4</span>
        <h3 class="font-bold mt-2 mb-2"><%= Score::LEVEL_NAMES[4] %></h3>
        <p class="text-sm text-blue-50">Triangulation: MTA + MMM + incrementality testing. Forecasting. Continuous experimentation.</p>
      </div>
    </div>

    <div class="text-center scroll-animate" data-controller="scroll-reveal">
      <%= link_to "Score yourself in 3 minutes &rarr;".html_safe, score_path,
            class: "inline-block px-8 py-4 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md shadow-lg transition-all" %>
      <p class="mt-3 text-sm text-gray-500">
        No signup. No email. Just your score across six dimensions and where the gaps are.
      </p>
    </div>
  </div>
</section>
