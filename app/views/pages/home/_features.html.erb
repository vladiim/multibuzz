<section id="features" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900">
        <%= t('pages.home.features.title') %>
      </h2>
      <p class="mt-4 text-xl text-gray-600">
        <%= t('pages.home.features.subtitle') %>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="feature scroll-animate" data-controller="scroll-reveal">
        <div class="feature__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="feature__title">
          <%= t('pages.home.features.privacy_tracking.title') %>
        </h3>
        <p class="feature__description">
          <%= t('pages.home.features.privacy_tracking.description') %>
        </p>
      </div>

      <div class="feature scroll-animate" data-controller="scroll-reveal">
        <div class="feature__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
          </svg>
        </div>
        <h3 class="feature__title">
          <%= t('pages.home.features.dark_funnel.title') %>
        </h3>
        <p class="feature__description">
          <%= t('pages.home.features.dark_funnel.description') %>
        </p>
      </div>

      <div class="feature scroll-animate" data-controller="scroll-reveal">
        <div class="feature__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h3 class="feature__title">
          <%= t('pages.home.features.quick_setup.title') %>
        </h3>
        <p class="feature__description">
          <%= t('pages.home.features.quick_setup.description') %>
        </p>
      </div>

      <div class="feature scroll-animate" data-controller="scroll-reveal">
        <div class="feature__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
        </div>
        <h3 class="feature__title">
          <%= t('pages.home.features.user_mapping.title') %>
        </h3>
        <p class="feature__description">
          <%= t('pages.home.features.user_mapping.description') %>
        </p>
      </div>

      <div class="feature scroll-animate" data-controller="scroll-reveal">
        <div class="feature__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <h3 class="feature__title">
          <%= t('pages.home.features.custom_models.title') %>
        </h3>
        <p class="feature__description">
          <%= t('pages.home.features.custom_models.description') %>
        </p>
      </div>

      <div class="feature scroll-animate" data-controller="scroll-reveal">
        <div class="feature__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V5a2 2 0 00-2-2H6a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="feature__title">
          <%= t('pages.home.features.etl_exports.title') %>
        </h3>
        <p class="feature__description">
          <%= t('pages.home.features.etl_exports.description') %>
        </p>
      </div>
    </div>

    <div class="text-center mt-12 scroll-animate" data-controller="scroll-reveal">
      <%= link_to demo_path, class: "text-blue-600 hover:text-blue-700 font-medium inline-flex items-center" do %>
        See these features in the demo
        <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      <% end %>
    </div>
  </div>
</section>
