<section class="py-24 px-6 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 text-center mb-12 scroll-animate" data-controller="scroll-reveal">
      How mbuzz compares
    </h2>

    <div class="bg-white rounded-lg shadow-lg overflow-hidden scroll-animate" data-controller="scroll-reveal">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-900 text-white">
              <th class="px-6 py-4 text-left text-sm font-semibold">Feature</th>
              <th class="px-6 py-4 text-center text-sm font-semibold">mbuzz</th>
              <th class="px-6 py-4 text-center text-sm font-semibold">GA4</th>
              <th class="px-6 py-4 text-center text-sm font-semibold">Segment</th>
              <th class="px-6 py-4 text-center text-sm font-semibold">Amplitude</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900">Server-side tracking</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check;</td>
              <td class="px-6 py-4 text-center text-red-400 font-semibold">&cross;</td>
              <td class="px-6 py-4 text-center text-yellow-600 font-semibold">~</td>
              <td class="px-6 py-4 text-center text-yellow-600 font-semibold">~</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-900">Custom attribution models</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check; DSL</td>
              <td class="px-6 py-4 text-center text-red-400 font-semibold">&cross;</td>
              <td class="px-6 py-4 text-center text-red-400 font-semibold">&cross;</td>
              <td class="px-6 py-4 text-center text-yellow-600">Limited</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900">Compare models side-by-side</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check;</td>
              <td class="px-6 py-4 text-center text-red-400 font-semibold">&cross;</td>
              <td class="px-6 py-4 text-center text-red-400 font-semibold">&cross;</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check;</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-900">Real-time event debugging</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check;</td>
              <td class="px-6 py-4 text-center text-yellow-600">Limited</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check;</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check;</td>
            </tr>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900">Export raw data</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check; Anytime</td>
              <td class="px-6 py-4 text-center text-yellow-600">Limited</td>
              <td class="px-6 py-4 text-center text-green-600 font-semibold">&check;</td>
              <td class="px-6 py-4 text-center text-yellow-600">Paid</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="text-center mt-10 scroll-animate" data-controller="scroll-reveal">
      <%= link_to "See mbuzz in Action", demo_path, class: "inline-block px-6 py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all" %>
    </div>
  </div>
</section>
