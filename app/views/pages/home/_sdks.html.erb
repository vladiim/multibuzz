<section id="sdks" class="py-20 px-6 bg-gray-50">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-gray-900 mb-4 scroll-animate" data-controller="scroll-reveal" style="transition-delay: 0ms">10 minutes from data. Server-side from the first event.</h2>
    <p class="text-lg text-gray-600 mb-12 scroll-animate" data-controller="scroll-reveal" style="transition-delay: 100ms">
      Native SDKs for Ruby, Node, Python, and PHP. GTM, Shopify, and REST also available. Server-side means ad blockers and iOS privacy stop costing you data.
    </p>

    <div class="flex flex-wrap justify-center gap-6">
      <% SdkRegistry.for_homepage.each_with_index do |sdk, i| %>
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm scroll-animate w-[calc(50%-0.75rem)] md:w-[calc(25%-1.125rem)]" data-controller="scroll-reveal" style="transition-delay: <%= 200 + (i * 100) %>ms">
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <%= sdk_icon_for(sdk) %>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2"><%= sdk.name %></h3>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= sdk_status_badge_class(sdk.status) %>">
            <%= sdk.status_badge %>
          </span>
        </div>
      <% end %>
    </div>

    <div class="mt-10">
      <%= link_to "Read the Docs", docs_path('getting-started'), class: "inline-block px-6 py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all" %>
    </div>

    <p class="mt-6 text-sm text-gray-500">
      Need a different language? <%= link_to "Let us know", contact_path, class: "text-blue-600 hover:text-blue-500" %> and we'll prioritize it.
    </p>
  </div>
</section>
