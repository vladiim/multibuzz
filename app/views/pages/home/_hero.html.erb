<section class="py-24 px-6 bg-pattern-dots">
  <div class="max-w-7xl mx-auto text-center">
    <p class="text-sm font-medium text-blue-600 uppercase tracking-wide mb-4 scroll-animate" data-controller="scroll-reveal">
      <%= t('pages.home.hero.eyebrow') %>
    </p>
    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 tracking-tight scroll-animate" data-controller="scroll-reveal">
      Attribution that matches
      <span class="block mt-2">your bank account.</span>
    </h1>
    <p class="mt-8 text-xl text-gray-600 max-w-3xl mx-auto scroll-animate" data-controller="scroll-reveal">
      Meta says you made $134K. Google says $98K. Your bank says $147K.
      <%= link_to "mbuzz reconciles all three",
            article_path("roas-inflation-platform-over-reporting"),
            class: "underline decoration-dotted underline-offset-4 text-gray-900 hover:text-blue-600" %>
      — so you stop guessing where the next dollar should go.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4 scroll-animate" data-controller="scroll-reveal">
      <%= link_to t('pages.home.hero.cta_primary'), score_path,
            class: "px-6 py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all" %>
      <%= link_to t('pages.home.hero.cta_secondary'), demo_path,
            class: "px-6 py-3 text-sm font-semibold text-gray-900 bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 rounded-md transition-all inline-flex items-center justify-center" %>
    </div>
    <p class="mt-6 text-sm text-gray-500">
      <%= t('pages.home.hero.no_signup') %>
    </p>
  </div>
</section>
