<section class="py-24 px-6 bg-pattern-dots">
  <div class="max-w-7xl mx-auto text-center">
    <h1 class="text-sm font-medium text-blue-600 uppercase tracking-wide mb-4 scroll-animate" data-controller="scroll-reveal">
      Server-Side Multi-Touch Attribution
    </h1>
    <p class="text-5xl md:text-6xl font-bold text-gray-900 tracking-tight scroll-animate" data-controller="scroll-reveal">
      Stop renting your attribution.
      <span class="block mt-2">Own it.</span>
    </p>
    <p class="mt-8 text-xl text-gray-600 max-w-3xl mx-auto scroll-animate" data-controller="scroll-reveal">
      Black-box models. Inflated platform ROAS. Data you can't export.
      <span class="font-medium text-gray-900">Sound familiar?</span>
      mbuzz puts you back in control.
    </p>
    <div class="mt-10 flex justify-center gap-4 scroll-animate" data-controller="scroll-reveal">
      <%= link_to t('pages.home.hero.cta_primary'), new_waitlist_path, class: "px-6 py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-md transition-all" %>
      <%= link_to t('pages.home.hero.cta_secondary'), docs_path('getting-started'), class: "px-6 py-3 text-sm font-semibold text-gray-900 bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 rounded-md transition-all" %>
    </div>
    <p class="mt-6 text-sm text-gray-500">
      <a href="#sdks" class="hover:text-gray-700 transition-colors">SDKs for your favourite stack &rarr;</a>
    </p>
  </div>
</section>
