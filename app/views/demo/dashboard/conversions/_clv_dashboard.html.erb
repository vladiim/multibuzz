<% totals = @clv_data[:totals] %>
<% coverage = @clv_data[:coverage] %>
<% @filter_params ||= { date_range: "30d" } %>

<%= render "dashboard/conversions/clv_kpi_cards", totals: totals, coverage: coverage %>

<div class="bg-white p-6 rounded-lg shadow mb-6">
  <h3 class="text-lg font-medium text-gray-900 mb-4">CLV by Acquisition Channel</h3>
  <div id="clv-by-channel-chart"
    data-controller="chart"
    data-chart-type-value="bar"
    data-chart-metric-value="clv"
    data-chart-data-value="<%= @clv_data[:by_channel].to_json %>"
    class="h-80">
  </div>
</div>

<% if @clv_data[:smiling_curve].present? %>
  <div class="bg-white p-6 rounded-lg shadow mb-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Revenue per Customer by Lifecycle Month</h3>
    <div id="smiling-curve-chart"
      data-controller="chart"
      data-chart-type-value="line"
      data-chart-data-value="<%= @clv_data[:smiling_curve].to_json %>"
      class="h-72">
    </div>
  </div>
<% end %>

<% if @clv_data[:cohort_analysis].present? %>
  <div class="bg-white p-6 rounded-lg shadow">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Cohort Analysis</h3>
    <%= render "demo/dashboard/conversions/cohort_table", cohorts: @clv_data[:cohort_analysis] %>
  </div>
<% end %>
