<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>
  <%= render "demo/dashboard/demo_badge" %>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-semibold text-gray-900">Conversions</h1>
        <p class="mt-1 text-sm text-gray-500"><%= @total_count %> total</p>
      </div>
      <%= link_to "\u2190 Dashboard", demo_dashboard_path, class: "text-sm text-indigo-600 hover:text-indigo-800" %>
    </div>

    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Revenue</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Channels</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Touchpoints</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Identity</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @conversions.each do |conversion| %>
            <tr class="hover:bg-gray-50 cursor-pointer transition-colors"
                onclick="Turbo.visit('<%= demo_dashboard_conversion_detail_path(conversion.prefix_id) %>')">
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                <%= conversion.converted_at.strftime("%b %-d, %Y %H:%M") %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">
                  <%= conversion.conversion_type %>
                </span>
                <% if conversion.is_acquisition %>
                  <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-700">ACQ</span>
                <% end %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                <% if conversion.revenue.present? %>
                  <%= number_to_currency(conversion.revenue) %>
                <% else %>
                  <span class="text-gray-400">&mdash;</span>
                <% end %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap">
                <span class="text-xs text-gray-500"><%= conversion.journey_session_ids.size %> sessions</span>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500">
                <%= conversion.journey_session_ids.size %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm">
                <% if conversion.identity.present? %>
                  <span class="text-indigo-600 font-medium"><%= conversion.identity.external_id %></span>
                <% else %>
                  <span class="text-gray-400">Anonymous</span>
                <% end %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-right">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "demo/dashboard/cta_banner" %>
  </div>
</div>
