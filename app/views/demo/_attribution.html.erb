<div class="bg-white rounded-lg shadow p-6 mb-8">
  <h3 class="text-lg font-medium text-gray-900 mb-4">Channel Attribution (<%= selected_model.titleize %>)</h3>

  <div class="space-y-4">
    <% demo_data[:channel_breakdown].each do |breakdown| %>
      <div class="flex items-center">
        <div class="w-32 text-sm font-medium text-gray-700">
          <%= breakdown[:channel].titleize %>
        </div>
        <div class="flex-1 mx-4">
          <div class="h-6 bg-gray-100 rounded-full overflow-hidden">
            <div
              class="h-full bg-indigo-600 rounded-full transition-all duration-500"
              style="width: <%= (breakdown[:credit] * 100).round %>%"></div>
          </div>
        </div>
        <div class="w-24 text-right">
          <span class="text-sm font-medium text-gray-900">
            $<%= number_with_delimiter(breakdown[:revenue_credit].round) %>
          </span>
          <span class="text-xs text-gray-500 ml-1">
            (<%= (breakdown[:credit] * 100).round %>%)
          </span>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-6 pt-4 border-t border-gray-200">
    <p class="text-sm text-gray-500">
      <strong><%= selected_model.titleize %>:</strong>
      <%= attribution_model_description(selected_model) %>
    </p>
  </div>
</div>
