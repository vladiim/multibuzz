<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center py-4">
        <div class="flex items-center space-x-4">
          <h1 class="text-xl font-semibold text-gray-900">mbuzz Demo Dashboard</h1>
          <span class="px-2 py-1 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">
            Sample Data
          </span>
        </div>
        <div class="flex items-center space-x-4">
          <span class="text-sm text-gray-500">Ready to track your own data?</span>
          <%= link_to "Sign Up Free", signup_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Model Switcher -->
    <div class="bg-white rounded-lg shadow p-6 mb-8" data-model-switcher>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium text-gray-900">Attribution Model</h2>
        <span class="text-sm text-gray-500">Click to see how credit changes</span>
      </div>
      <div class="flex flex-wrap gap-2">
        <% AttributionAlgorithms::IMPLEMENTED.reject { |a| a == AttributionAlgorithms::PARTICIPATION }.each do |model| %>
          <%= link_to demo_attribution_path(model: model),
              class: "px-4 py-2 rounded-md text-sm font-medium transition-colors #{@selected_model == model ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}",
              data: { turbo_frame: "attribution_frame" } do %>
            <%= model.titleize %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Attribution Panel -->
    <%= turbo_frame_tag "attribution_frame" do %>
      <%= render "demo/attribution", demo_data: @demo_data, selected_model: @selected_model %>
    <% end %>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow p-6">
        <div class="text-sm font-medium text-gray-500 uppercase tracking-wide">Total Conversions</div>
        <div class="mt-2 text-3xl font-semibold text-gray-900"><%= @demo_data[:summary][:total_conversions] %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-6">
        <div class="text-sm font-medium text-gray-500 uppercase tracking-wide">Total Revenue</div>
        <div class="mt-2 text-3xl font-semibold text-gray-900">$<%= number_with_delimiter(@demo_data[:summary][:total_revenue]) %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-6">
        <div class="text-sm font-medium text-gray-500 uppercase tracking-wide">Top Channel</div>
        <div class="mt-2 text-3xl font-semibold text-gray-900"><%= @demo_data[:summary][:top_channel]&.titleize %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-6">
        <div class="text-sm font-medium text-gray-500 uppercase tracking-wide">Avg Touchpoints</div>
        <div class="mt-2 text-3xl font-semibold text-gray-900"><%= @demo_data[:summary][:average_touchpoints] %></div>
      </div>
    </div>

    <!-- Sample Journey -->
    <% if @demo_data[:sample_journey][:touchpoints].any? %>
      <div class="bg-white rounded-lg shadow p-6 mb-8">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Sample Customer Journey</h3>
        <div class="flex items-center overflow-x-auto pb-4">
          <% @demo_data[:sample_journey][:touchpoints].each_with_index do |touchpoint, index| %>
            <div class="flex items-center">
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center">
                  <span class="text-indigo-600 font-medium"><%= index + 1 %></span>
                </div>
                <div class="mt-2 text-sm font-medium text-gray-900"><%= touchpoint[:channel].titleize %></div>
                <div class="text-xs text-gray-500"><%= touchpoint[:date] %></div>
              </div>
              <% unless index == @demo_data[:sample_journey][:touchpoints].size - 1 %>
                <div class="w-12 h-0.5 bg-gray-300 mx-2"></div>
              <% end %>
            </div>
          <% end %>
          <div class="w-12 h-0.5 bg-green-500 mx-2"></div>
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center">
              <span class="text-green-600 font-medium">$</span>
            </div>
            <div class="mt-2 text-sm font-medium text-gray-900">Conversion</div>
            <div class="text-xs text-green-600 font-medium">$<%= @demo_data[:sample_journey][:conversion][:revenue] %></div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- CTA Banner -->
    <div class="bg-indigo-600 rounded-lg shadow p-8 text-center" data-demo-attribution>
      <h3 class="text-2xl font-bold text-white mb-2">Ready to see your own attribution data?</h3>
      <p class="text-indigo-100 mb-6">Set up in under 5 minutes with our simple SDK.</p>
      <%= link_to "Start Free Trial", signup_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-indigo-600 bg-white hover:bg-indigo-50" %>
    </div>
  </div>
</div>
