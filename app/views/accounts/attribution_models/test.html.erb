<%= turbo_frame_tag "test-results" do %>
  <% if @test_result[:success] %>
    <div class="space-y-2">
      <% @test_result[:results].each do |result| %>
        <div class="flex items-center gap-3 py-2">
          <span class="w-6 text-center text-sm text-gray-500"><%= result[:position] %></span>
          <span class="w-32 text-sm font-medium text-gray-700"><%= result[:channel_label] %></span>
          <div class="flex-1 h-6 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-full bg-indigo-500 rounded-full" style="width: <%= result[:percentage] %>%"></div>
          </div>
          <span class="w-16 text-right text-sm font-semibold text-gray-900"><%= result[:percentage] %>%</span>
        </div>
      <% end %>

      <div class="mt-3 pt-3 border-t border-gray-200 flex justify-between text-sm">
        <span class="text-gray-500">Total</span>
        <span class="font-semibold <%= (@test_result[:total] - 1.0).abs < 0.001 ? 'text-green-600' : 'text-red-600' %>">
          <%= (@test_result[:total] * 100).round(1) %>%
        </span>
      </div>
    </div>
  <% else %>
    <div class="p-4 bg-red-50 rounded-md">
      <p class="text-sm text-red-700"><%= @test_result[:error] %></p>
    </div>
  <% end %>
<% end %>
