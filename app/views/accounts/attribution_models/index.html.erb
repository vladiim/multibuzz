<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>

  <div class="py-6 sm:py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row gap-4 md:gap-8">
        <%= render "layouts/account_nav" %>

        <div class="flex-1 space-y-4 md:space-y-6">
          <%= render "layouts/account_nav_tabs" %>
          <%# Header - stacks on mobile %>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
              <h1 class="text-lg sm:text-xl font-semibold text-gray-900">Attribution Models</h1>
              <p class="mt-1 text-sm text-gray-500">Configure how conversion credit is distributed across touchpoints</p>
            </div>
            <% if current_account.can_create_custom_model? %>
              <%= link_to new_account_attribution_model_path,
                class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 whitespace-nowrap" do %>
                <svg class="-ml-1 mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Create Model
              <% end %>
            <% elsif current_account.can_edit_full_aml? %>
              <span class="inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-500 bg-gray-100 cursor-not-allowed whitespace-nowrap">
                Limit Reached (<%= current_account.custom_models_count %>/<%= current_account.custom_model_limit %>)
              </span>
            <% else %>
              <%= link_to account_billing_path,
                class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 whitespace-nowrap" do %>
                Upgrade for Custom Models
              <% end %>
            <% end %>
          </div>

          <%# Plan Limit Info %>
          <% if current_account.can_edit_full_aml? && current_account.custom_model_limit.positive? %>
            <div class="bg-indigo-50 rounded-lg px-4 py-3">
              <div class="flex items-center justify-between">
                <span class="text-sm text-indigo-700">
                  Custom models: <strong><%= current_account.custom_models_count %></strong> of <strong><%= current_account.custom_model_limit %></strong> used
                </span>
                <div class="w-32 bg-indigo-200 rounded-full h-2">
                  <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= [(current_account.custom_models_count.to_f / current_account.custom_model_limit * 100), 100].min %>%"></div>
                </div>
              </div>
            </div>
          <% end %>

          <%# Preset Models Section %>
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200">
              <h2 class="text-lg font-medium text-gray-900">Default Models</h2>
              <p class="mt-1 text-sm text-gray-500">Industry-standard attribution models included with all plans</p>
            </div>
            <ul class="divide-y divide-gray-200">
              <% @templates.each do |template| %>
                <% model = @preset_models.find { |m| m.algorithm == template[:key].to_s } %>
                <li class="px-4 sm:px-6 py-4 hover:bg-gray-50">
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <h3 class="text-sm font-medium text-gray-900"><%= template[:name] %></h3>
                        <% if model&.is_default? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">
                            <svg class="mr-1 h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            Default
                          </span>
                        <% end %>
                        <% if model&.dsl_code.present? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                            Customized
                          </span>
                        <% end %>
                      </div>
                      <p class="mt-1 text-sm text-gray-500"><%= template[:description] %></p>
                    </div>
                    <div class="flex items-center gap-2 flex-wrap">
                      <% if model %>
                        <% unless model.is_default? %>
                          <%= button_to set_default_account_attribution_model_path(model),
                            method: :post,
                            class: "inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50",
                            title: "Set as default" do %>
                            Set Default
                          <% end %>
                        <% end %>
                        <% if model.dsl_code.present? %>
                          <%= button_to reset_account_attribution_model_path(model),
                            method: :post,
                            class: "inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50",
                            form: { data: { turbo_confirm: "Reset to default template? Your customizations will be lost." } } do %>
                            Reset
                          <% end %>
                        <% end %>
                        <% if model.needs_rerun? %>
                          <%= button_to rerun_account_attribution_model_path(model),
                            method: :post,
                            class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-emerald-600 hover:bg-emerald-700",
                            title: "Run attribution" do %>
                            <svg class="-ml-0.5 mr-1 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Run
                          <% end %>
                        <% end %>
                        <%= link_to edit_account_attribution_model_path(model),
                          class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-indigo-600 hover:bg-indigo-700" do %>
                          Edit
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>

          <%# Custom Models Section %>
          <% if @custom_models.any? || current_account.can_create_custom_model? %>
            <div class="bg-white shadow rounded-lg overflow-hidden">
              <div class="px-6 py-4 border-b border-gray-200">
                <h2 class="text-lg font-medium text-gray-900">Custom Models</h2>
                <p class="mt-1 text-sm text-gray-500">Your custom attribution models using AML</p>
              </div>
              <% if @custom_models.any? %>
                <ul class="divide-y divide-gray-200">
                  <% @custom_models.each do |model| %>
                    <li class="px-4 sm:px-6 py-4 hover:bg-gray-50">
                      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2 flex-wrap">
                            <h3 class="text-sm font-medium text-gray-900"><%= model.name %></h3>
                            <% if model.is_default? %>
                              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">
                                <svg class="mr-1 h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                                Default
                              </span>
                            <% end %>
                          </div>
                          <p class="mt-1 text-sm text-gray-500">
                            Lookback: <%= model.lookback_days %> days
                            <span class="mx-2 text-gray-300">·</span>
                            Created <%= time_ago_in_words(model.created_at) %> ago
                          </p>
                        </div>
                        <div class="flex items-center gap-2 flex-wrap">
                          <% unless model.is_default? %>
                            <%= button_to set_default_account_attribution_model_path(model),
                              method: :post,
                              class: "inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50" do %>
                              Set Default
                            <% end %>
                          <% end %>
                          <% if model.needs_rerun? %>
                            <%= button_to rerun_account_attribution_model_path(model),
                              method: :post,
                              class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-emerald-600 hover:bg-emerald-700",
                              title: "Run attribution" do %>
                              <svg class="-ml-0.5 mr-1 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              Run
                            <% end %>
                          <% end %>
                          <%= link_to edit_account_attribution_model_path(model),
                            class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-white bg-indigo-600 hover:bg-indigo-700" do %>
                            Edit
                          <% end %>
                          <%= button_to account_attribution_model_path(model),
                            method: :delete,
                            class: "inline-flex items-center px-3 py-1.5 border border-red-300 text-xs font-medium rounded text-red-700 bg-white hover:bg-red-50",
                            form: { data: { turbo_confirm: "Delete this model? This cannot be undone." } } do %>
                            Delete
                          <% end %>
                        </div>
                      </div>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <div class="px-6 py-12 text-center">
                  <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  <h3 class="mt-2 text-sm font-medium text-gray-900">No custom models</h3>
                  <p class="mt-1 text-sm text-gray-500">Create your first custom attribution model using AML.</p>
                  <div class="mt-6">
                    <%= link_to new_account_attribution_model_path,
                      class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
                      <svg class="-ml-1 mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                      </svg>
                      Create Custom Model
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <%# Free Plan Upgrade Prompt %>
          <% unless current_account.can_edit_full_aml? %>
            <div class="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-lg shadow-lg overflow-hidden">
              <div class="px-6 py-8 sm:px-10">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="text-lg font-semibold text-white">Unlock Full AML Editing</h3>
                    <p class="mt-2 text-sm text-indigo-100">
                      Upgrade to a paid plan to fully customize attribution models and create your own custom models.
                    </p>
                    <ul class="mt-4 space-y-2 text-sm text-indigo-100">
                      <li class="flex items-center">
                        <svg class="mr-2 h-4 w-4 text-indigo-200" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        Full code editor with AML syntax
                      </li>
                      <li class="flex items-center">
                        <svg class="mr-2 h-4 w-4 text-indigo-200" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        Create up to 10 custom models
                      </li>
                      <li class="flex items-center">
                        <svg class="mr-2 h-4 w-4 text-indigo-200" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        Real-time validation and testing
                      </li>
                    </ul>
                  </div>
                  <%= link_to account_billing_path,
                    class: "flex-shrink-0 inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-indigo-600 bg-white hover:bg-indigo-50 shadow-sm" do %>
                    View Plans
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
