<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>

  <div class="py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-8">
        <%= render "layouts/account_nav" %>

        <div class="flex-1">
          <div class="mb-6">
            <%= link_to account_attribution_models_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
              <svg class="mr-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
              Back to Attribution Models
            <% end %>
          </div>

          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200">
              <h1 class="text-xl font-semibold text-gray-900">Create Custom Attribution Model</h1>
              <p class="mt-1 text-sm text-gray-500">Define your own attribution logic using AML</p>
            </div>

            <%= form_with model: @attribution_model, url: account_attribution_models_path, class: "divide-y divide-gray-200" do |f| %>
              <% if @attribution_model.errors.any? %>
                <div class="px-6 py-4 bg-red-50">
                  <div class="flex">
                    <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    <div class="ml-3">
                      <h3 class="text-sm font-medium text-red-800">There were errors with your submission</h3>
                      <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                        <% @attribution_model.errors.full_messages.each do |error| %>
                          <li><%= error %></li>
                        <% end %>
                      </ul>
                    </div>
                  </div>
                </div>
              <% end %>

              <div class="px-6 py-4 space-y-4">
                <div>
                  <label for="attribution_model_name" class="block text-sm font-medium text-gray-700">Model Name</label>
                  <%= f.text_field :name,
                    class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                    placeholder: "e.g., Custom Time Decay" %>
                </div>

                <div>
                  <label for="attribution_model_lookback_days" class="block text-sm font-medium text-gray-700">Lookback Window</label>
                  <div class="mt-1 flex items-center gap-2">
                    <%= f.number_field :lookback_days,
                      value: @attribution_model.lookback_days || 30,
                      min: 1,
                      max: 365,
                      class: "block w-24 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                    <span class="text-sm text-gray-500">days</span>
                  </div>
                </div>
              </div>

              <div class="px-6 py-4">
                <label for="attribution_model_dsl_code" class="block text-sm font-medium text-gray-700 mb-2">AML Code</label>
                <%= f.text_area :dsl_code,
                  rows: 12,
                  class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 font-mono text-sm bg-gray-900 text-gray-100 p-4",
                  placeholder: "# Write your AML code here\nwithin_window 30.days do\n  apply 1.0, to: touchpoints.first\nend",
                  spellcheck: false %>
                <p class="mt-2 text-xs text-gray-500">
                  Write your attribution logic using AML (Attribution Modeling Language).
                </p>
              </div>

              <div class="px-6 py-4 bg-gray-50 flex items-center justify-end gap-3">
                <%= link_to "Cancel", account_attribution_models_path,
                  class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900" %>
                <%= f.submit "Create Model",
                  class: "px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
