<div class="bg-white shadow rounded-lg border border-red-200">
  <div class="px-6 py-5 border-b border-red-200">
    <h2 class="text-lg font-medium text-red-900">Transfer Ownership</h2>
  </div>
  <div class="px-6 py-4">
    <p class="text-sm text-gray-600 mb-4">
      Transfer account ownership to another team member. You will be demoted to Admin and lose the ability to transfer ownership or delete the account.
    </p>
    <%= form_with url: transfer_account_team_ownership_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <label for="new_owner_id" class="block text-sm font-medium text-gray-700">New Owner</label>
        <select name="new_owner_id" id="new_owner_id" required
          class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm">
          <option value="">Select a team member...</option>
          <% @memberships.accepted.reject(&:owner?).each do |membership| %>
            <option value="<%= membership.prefix_id %>"><%= membership.user.email %> (<%= membership.role.capitalize %>)</option>
          <% end %>
        </select>
      </div>
      <div>
        <label for="confirmation" class="block text-sm font-medium text-gray-700">
          Type "<%= current_account.name %>" to confirm
        </label>
        <input type="text" name="confirmation" id="confirmation" required
          class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm"
          placeholder="<%= current_account.name %>">
      </div>
      <button type="submit"
        class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
        Transfer Ownership
      </button>
    <% end %>
  </div>
</div>
