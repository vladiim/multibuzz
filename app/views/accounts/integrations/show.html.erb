<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>

  <div class="py-6 sm:py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row gap-4 md:gap-8">
        <%= render "layouts/account_nav" %>

        <div class="flex-1 space-y-4 md:space-y-6">
          <%= render "layouts/account_nav_tabs" %>

          <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200 flex items-start justify-between gap-4">
              <div>
                <h1 class="text-xl font-semibold text-gray-900">Integrations</h1>
                <p class="mt-1 text-sm text-gray-500">Connect ad platforms to unlock spend intelligence and ROAS reporting.</p>
              </div>
              <% if current_account.can_connect_ad_platform? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 whitespace-nowrap">
                  <%= current_account.ad_platform_connections_unlimited? ? "Unlimited integrations" : "#{current_account.ad_platform_connections_used} of #{current_account.ad_platform_connection_limit} integrations used" %>
                </span>
              <% end %>
            </div>

            <div class="divide-y divide-gray-200">
              <% if Rails.env.production? %>
                <%= render "coming_soon_card",
                  platform: "Google Ads",
                  notified: @notified_platforms.include?("Google Ads") %>
              <% else %>
                <%= render "google_ads_card" %>
              <% end %>

              <% if current_account.feature_enabled?(FeatureFlags::META_ADS_INTEGRATION) %>
                <%= render "meta_ads_card" %>
              <% end %>

              <% IntegrationRequestSubmission::COMING_SOON_PLATFORMS.each do |platform| %>
                <% next if platform == "Meta Ads" && current_account.feature_enabled?(FeatureFlags::META_ADS_INTEGRATION) %>
                <%= render "coming_soon_card",
                  platform: platform,
                  notified: @notified_platforms.include?(platform) %>
              <% end %>
            </div>
          </div>

          <%= render "request_integration" %>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render "shared/upgrade_modal",
  modal_id: "subscription-required-modal",
  title: "Subscription Required",
  body: "Ad platform integrations are available on paid plans. Connect Google Ads to unlock:",
  features: [
    "Attributed ROAS across all channels",
    "Customer acquisition cost (CAC)",
    "Budget recommendations",
    "Automated daily spend sync"
  ] %>
