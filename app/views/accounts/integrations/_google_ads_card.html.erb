<% google_connections = @connections.select { |c| c.google_ads? && !c.disconnected? } %>
<% google_connection = google_connections.min_by { |c| c.connected? ? 0 : 1 } %>

<div class="px-6 py-5" data-platform="google-ads" data-connection-id="<%= google_connection&.prefix_id %>">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <div class="flex-shrink-0 w-10 h-10 bg-white border border-gray-200 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
        </svg>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-900">Google Ads</p>
        <% if google_connection %>
          <p class="text-xs text-gray-500">
            <%= google_connection.platform_account_name || google_connection.platform_account_id %>
            <% if google_connection.last_synced_at %>
              &middot; Last synced <%= time_ago_in_words(google_connection.last_synced_at) %> ago
            <% end %>
          </p>
        <% else %>
          <p class="text-xs text-gray-500">Connect to track ad spend and ROAS</p>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <% if google_connection %>
        <%= render "connection_status", connection: google_connection %>

        <%= button_to "Refresh",
          refresh_account_integrations_path(google_connection),
          method: :post,
          class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>

        <%= link_to "Disconnect",
          oauth_google_ads_disconnect_path(google_connection),
          data: { turbo_method: :delete, turbo_confirm: "Disconnect Google Ads? Historical data will be kept." },
          class: "text-sm text-red-600 hover:text-red-800" %>
      <% elsif @can_connect %>
        <%= link_to "Connect", oauth_google_ads_connect_path,
          class: "inline-flex items-center px-3 py-1.5 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
      <% else %>
        <span class="text-sm text-gray-500">
          <%= link_to "Upgrade", account_billing_path, class: "text-indigo-600 hover:text-indigo-800 font-medium" %> to connect
        </span>
      <% end %>
    </div>
  </div>

  <% if google_connection&.error? && google_connection.last_sync_error.present? %>
    <div class="mt-3 rounded-md bg-red-50 p-3">
      <p class="text-sm text-red-700"><%= google_connection.last_sync_error %></p>
    </div>
  <% end %>
</div>
