<div class="px-6 py-5 opacity-50" data-platform="<%= platform.parameterize %>">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <div class="flex-shrink-0 w-10 h-10 bg-gray-100 border border-gray-200 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>

      <div>
        <p class="text-sm font-medium text-gray-900"><%= platform %></p>
        <p class="text-xs text-gray-500">Coming soon</p>
      </div>
    </div>

    <% if notified %>
      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Notified
      </span>
    <% else %>
      <%= button_to "Notify Me",
        notify_account_integrations_path,
        params: { platform_name: platform },
        method: :post,
        class: "inline-flex items-center px-2.5 py-1 border border-gray-300 text-xs font-medium rounded-full text-gray-700 bg-white hover:bg-gray-50" %>
    <% end %>
  </div>
</div>
