<% status_config = {
  "connected" => { color: "green", label: "Connected" },
  "syncing" => { color: "blue", label: "Syncing", pulse: true },
  "error" => { color: "red", label: "Error" },
  "disconnected" => { color: "gray", label: "Disconnected" },
  "needs_reauth" => { color: "amber", label: "Re-auth Required" }
}.fetch(connection.status, { color: "gray", label: connection.status.humanize }) %>

<span class="inline-flex items-center gap-1.5 text-sm text-gray-600">
  <span class="h-2 w-2 rounded-full bg-<%= status_config[:color] %>-500 <%= 'animate-pulse' if status_config[:pulse] %>"></span>
  <%= status_config[:label] %>
</span>
