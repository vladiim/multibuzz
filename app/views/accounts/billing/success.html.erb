<div class="min-h-screen bg-gray-100">
  <%= render "layouts/nav" %>

  <div class="py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-8">
        <%= render "layouts/account_nav" %>

        <div class="flex-1">
          <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-12 text-center">
              <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-green-100">
                <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <h2 class="mt-4 text-2xl font-bold text-gray-900">Payment Successful!</h2>
              <p class="mt-2 text-gray-500">Thank you for subscribing. Your account has been upgraded.</p>
              <%= link_to "Go to Dashboard", dashboard_path, class: "mt-6 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
