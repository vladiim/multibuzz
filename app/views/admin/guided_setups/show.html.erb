<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-start justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Guided Setup · <%= @guided_setup.account.name %></h1>
      <% owner = @guided_setup.account.owner_user %>
      <% if owner %>
        <p class="mt-1 text-sm text-gray-600" data-testid="guided-setup-owner">
          Signed up by
          <%= mail_to owner.email, owner.email, class: "text-indigo-600 hover:text-indigo-800" %>
        </p>
      <% end %>
    </div>
    <%= link_to "Back", admin_guided_setups_path, class: "text-sm text-indigo-600 hover:text-indigo-800 flex-shrink-0" %>
  </div>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <dl class="grid grid-cols-2 gap-4 text-sm">
      <div>
        <dt class="text-gray-500">Status</dt>
        <dd data-testid="guided-setup-status" class="text-gray-900 font-medium"><%= @guided_setup.status.humanize %></dd>
      </div>
      <div>
        <dt class="text-gray-500">Integration target</dt>
        <dd class="text-gray-900"><%= @guided_setup.integration_target.humanize %></dd>
      </div>
      <div class="col-span-2">
        <dt class="text-gray-500">Time zone</dt>
        <dd class="text-gray-900"><%= @scheduling_form.timezone.presence || "—" %></dd>
      </div>
      <div class="col-span-2">
        <dt class="text-gray-500">Preferred days</dt>
        <dd class="text-gray-900"><%= @scheduling_form.any_days? ? @scheduling_form.day_labels : "any" %></dd>
      </div>
      <div class="col-span-2">
        <dt class="text-gray-500">Preferred times</dt>
        <dd class="text-gray-900"><%= @scheduling_form.any_time_blocks? ? @scheduling_form.time_block_labels_with_hours : "any" %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-white shadow rounded-lg p-6 mb-6" data-testid="payment-link-card">
    <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-3">Payment link</h2>
    <% if @payment_url.present? %>
      <div class="text-xs text-gray-500 mb-2">
        48h single-use link. Expires <%= @guided_setup.payment_token_expires_at.to_fs(:short) %>.
      </div>
      <div class="flex items-stretch gap-2" data-controller="clipboard">
        <code data-clipboard-target="source"
          data-testid="payment-link-url"
          class="flex-1 border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm font-mono bg-gray-50 text-gray-700 overflow-x-auto whitespace-nowrap"><%= @payment_url %></code>
        <button type="button"
          data-action="click->clipboard#copy"
          data-clipboard-target="button"
          class="px-3 py-2 text-sm border border-gray-300 rounded-md shadow-sm bg-white text-gray-700 hover:bg-gray-50">
          <span data-clipboard-target="label">Copy</span>
        </button>
      </div>
      <%= button_to "Regenerate link",
        generate_payment_link_admin_guided_setup_path(@guided_setup),
        method: :post,
        class: "mt-3 px-3 py-2 text-sm bg-white border border-gray-300 rounded-md shadow-sm text-gray-700 hover:bg-gray-50" %>
    <% elsif @guided_setup.kickoff_booked_at.present? && @guided_setup.pending? %>
      <p class="text-sm text-gray-600 mb-3">After the kickoff call, generate a 48-hour single-use payment link to send the customer.</p>
      <%= button_to "Generate payment link",
        generate_payment_link_admin_guided_setup_path(@guided_setup),
        method: :post,
        class: "px-4 py-2 text-sm bg-indigo-600 text-white rounded-md shadow-sm hover:bg-indigo-700",
        data: { testid: "generate-payment-link" } %>
    <% elsif @guided_setup.in_progress? %>
      <p class="text-sm text-gray-600">Payment received. The engagement is in progress.</p>
    <% else %>
      <p class="text-sm text-gray-600">A payment link can be generated once the customer has booked the kickoff.</p>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4">Milestones</h2>
    <ul class="divide-y divide-gray-100">
      <li class="flex items-center justify-between py-2 text-sm">
        <span class="text-gray-700">Accepted</span>
        <span class="text-gray-500"><%= @guided_setup.accepted_at&.to_fs(:short) || "—" %></span>
      </li>
      <% GuidedSetup::Milestones::MILESTONES.each do |key| %>
        <li class="flex items-center justify-between py-2 text-sm" data-testid="milestone-<%= key %>">
          <span class="text-gray-700"><%= key.humanize %></span>
          <% stamped_at = @guided_setup.public_send("#{key}_at") %>
          <% if stamped_at %>
            <span class="text-gray-500"><%= stamped_at.to_fs(:short) %></span>
          <% else %>
            <%= button_to "Mark done",
              record_milestone_admin_guided_setup_path(@guided_setup),
              params: { milestone: key },
              class: "px-3 py-1 text-xs bg-indigo-600 text-white rounded shadow-sm hover:bg-indigo-700" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <%= form_with model: [ :admin, @guided_setup ] do |f| %>
    <div class="bg-white shadow rounded-lg p-6">
      <div class="mb-4">
        <%= f.label :specialist_name, "Specialist", class: "block text-xs font-medium text-gray-600 mb-1" %>
        <%= f.text_field :specialist_name, class: "w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
      </div>
      <div class="mb-4">
        <%= f.label :notes, class: "block text-xs font-medium text-gray-600 mb-1" %>
        <%= f.text_area :notes, rows: 4, class: "w-full border border-gray-300 rounded-md shadow-sm px-3 py-2 text-sm min-h-24 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
      </div>
      <%= f.submit "Save", class: "px-4 py-2 text-sm bg-indigo-600 text-white rounded-md shadow-sm hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
