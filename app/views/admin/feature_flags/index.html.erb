<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Billing Admin", admin_billing_path, class: "text-indigo-600 hover:text-indigo-900" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-2">Feature Flags</h1>
  <p class="text-sm text-gray-500 mb-8">Per-account allowlist for beta features. Toggling here is immediate.</p>

  <% if notice %>
    <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-6"><p class="text-sm text-green-700"><%= notice %></p></div>
  <% end %>
  <% if alert %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6"><p class="text-sm text-red-700"><%= alert %></p></div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Flag Summary</h2>
    <table class="min-w-full divide-y divide-gray-200">
      <thead>
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Flag</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Accounts enabled</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @flag_summaries.each do |flag, count| %>
          <tr>
            <td class="px-4 py-2 text-sm font-mono text-gray-900"><%= flag %></td>
            <td class="px-4 py-2 text-sm text-gray-700"><%= count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Enable a flag for an account</h2>
    <%= form_with url: admin_feature_flags_path, method: :post, local: true, class: "flex gap-3 items-end" do |f| %>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Account ID</label>
        <%= f.number_field :account_id, required: true, class: "block w-full rounded border-gray-300" %>
      </div>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">Flag</label>
        <%= f.select :flag_name, FeatureFlags::ALL, {}, class: "block w-full rounded border-gray-300" %>
      </div>
      <%= f.submit "Enable", class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700" %>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Accounts with flags enabled</h2>
    <% if @accounts_with_flags.empty? %>
      <p class="text-sm text-gray-500">No accounts have any flags enabled.</p>
    <% else %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Account</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Flags</th>
            <th></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @accounts_with_flags.each do |account| %>
            <% account.feature_flags.each do |flag| %>
              <tr>
                <td class="px-4 py-2 text-sm text-gray-900">
                  <%= account.name %>
                  <span class="text-xs text-gray-500">(<%= account.prefix_id %>)</span>
                </td>
                <td class="px-4 py-2 text-sm font-mono text-gray-700"><%= flag.flag_name %></td>
                <td class="px-4 py-2 text-right">
                  <%= form_with url: admin_feature_flags_path, method: :delete, local: true, class: "inline" do |f| %>
                    <%= f.hidden_field :account_id, value: account.id %>
                    <%= f.hidden_field :flag_name, value: flag.flag_name %>
                    <%= f.submit "Disable", class: "text-sm text-red-600 hover:text-red-800 bg-transparent border-0 cursor-pointer" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
