<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Admin</h1>
  <p class="text-sm text-gray-600 mb-8">Every internal-operator tool, one click away.</p>

  <% @grouped_tools.each do |category, tools| %>
    <section class="mb-10">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= category %></h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% tools.each do |tool| %>
          <%= link_to tool.path, class: "block bg-white border border-gray-200 rounded-lg p-4 hover:border-indigo-400 hover:shadow-sm transition", data: { testid: "admin-tool-card" } do %>
            <div class="font-medium text-gray-900"><%= tool.name %></div>
            <div class="text-sm text-gray-600 mt-1"><%= tool.description %></div>
            <div class="text-xs text-gray-400 mt-2 font-mono"><%= tool.path %></div>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
