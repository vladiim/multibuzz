<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Billing Admin</h1>
    <nav class="flex gap-4 text-sm">
      <%= link_to "Customer Metrics", admin_customer_metrics_path, class: "text-indigo-600 hover:text-indigo-800" %>
      <%= link_to "Data Integrity", admin_data_integrity_index_path, class: "text-indigo-600 hover:text-indigo-800" %>
      <%= link_to "Submissions", admin_submissions_path, class: "text-indigo-600 hover:text-indigo-800" %>
      <%= link_to "Feature Flags", admin_feature_flags_path, class: "text-indigo-600 hover:text-indigo-800" %>
    </nav>
  </div>

  <!-- MRR Card -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white shadow rounded-lg p-6" data-testid="mrr">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Monthly Recurring Revenue</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900">$<%= number_with_delimiter(@metrics[:mrr].to_i) %></p>
    </div>

    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Total Accounts</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900"><%= number_with_delimiter(@metrics[:total_accounts]) %></p>
    </div>

    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Active Subscriptions</h3>
      <p class="mt-2 text-3xl font-bold text-green-600"><%= @metrics[:account_counts][:active] || 0 %></p>
    </div>

    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Past Due</h3>
      <p class="mt-2 text-3xl font-bold text-red-600"><%= @metrics[:account_counts][:past_due] || 0 %></p>
    </div>
  </div>

  <!-- Account Counts by Status -->
  <div class="bg-white shadow rounded-lg p-6 mb-8" data-testid="account-counts">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Accounts by Status</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
      <% Billing::ALL_STATUSES.each do |status| %>
        <div class="text-center">
          <p class="text-2xl font-bold text-gray-900"><%= @metrics[:account_counts][status.to_sym] || 0 %></p>
          <p class="text-sm text-gray-500"><%= status.to_s.humanize %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Accounts Table -->
  <div class="bg-white shadow rounded-lg overflow-hidden" data-testid="accounts-table">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">All Accounts</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Account</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plan</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Free Until</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @accounts.each do |account| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= account.name %></div>
                <div class="text-sm text-gray-500"><%= account.slug %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= render "admin/billing/status_badge", status: account.billing_status %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= account.plan&.name || "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if account.free_until.present? %>
                  <%= account.free_until.strftime("%b %d, %Y") %>
                <% else %>
                  —
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= account.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= link_to "Manage", admin_account_path(account), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
