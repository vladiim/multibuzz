<%
  classes = case status
            when ConversionDispatch::Statuses::DELIVERED          then "bg-green-100 text-green-800"
            when ConversionDispatch::Statuses::PENDING            then "bg-gray-100 text-gray-700"
            when ConversionDispatch::Statuses::FAILED_PERMANENT,
                 ConversionDispatch::Statuses::TOKEN_FAILED       then "bg-red-100 text-red-800"
            when ConversionDispatch::Statuses::FAILED_TRANSIENT   then "bg-amber-100 text-amber-800"
            else "bg-blue-50 text-blue-700"
            end
%>
<span class="inline-block px-2 py-0.5 text-xs rounded <%= classes %>"><%= status.humanize %></span>
