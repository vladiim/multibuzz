<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Form Submissions</h1>
    <nav class="flex gap-4 text-sm">
      <%= link_to "Billing", admin_billing_path, class: "text-indigo-600 hover:text-indigo-800" %>
      <%= link_to "Accounts", admin_billing_path, class: "text-indigo-600 hover:text-indigo-800" %>
    </nav>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Details</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @submissions.each do |submission| %>
            <tr class="submission-row hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= submission_type_badge(submission) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= submission.email %></div>
              </td>
              <td class="px-6 py-4">
                <div class="text-sm text-gray-600 max-w-xs truncate">
                  <%= submission_details_preview(submission) %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= submission_status_badge(submission.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= submission.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= link_to "View", admin_submission_path(submission), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @submissions.empty? %>
      <div class="px-6 py-12 text-center text-gray-500">
        <p>No submissions yet.</p>
      </div>
    <% end %>
  </div>
</div>
