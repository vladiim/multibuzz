        apply 0.4 to touchpoints[0]
        apply 0.4 to touchpoints[-1]
        apply 0.2 to touchpoints[1..-2], distribute: :equal
      end
      # Sum: 0.4 + 0.4 + 0.2 = 1.0 ✅
    CODE
  },
  invalid: {
    label: 'Invalid ❌',
    syntax: 'ruby',
    code: <<~CODE
      within_window 30.days
        apply 0.5 to touchpoints[0]
        apply 0.4 to touchpoints[-1]
        apply 0.2 to touchpoints[1..-2], distribute: :equal
