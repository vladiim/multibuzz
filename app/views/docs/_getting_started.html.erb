      Mbuzz.init(api_key: ENV['MBUZZ_API_KEY'], debug: true)

      # Check return values
      result = Mbuzz.event("test_event", foo: "bar")
      if result
        puts "Tracking succeeded"
      else
        puts "Tracking failed (check logs)"
      end
    CODE
  },
  nodejs: {
    label: 'Node.js',
