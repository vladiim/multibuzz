<%
  link = onboarding_pip_link(pip)
  text_class = pip.state == :locked ? "text-gray-400" : "text-gray-700"
%>
<li class="<%= text_class %>" data-testid="onboarding-pip-<%= pip.key %>" data-state="<%= pip.state %>">
  <% if link %>
    <%= button_to link[:path],
          method: link[:method],
          form: { class: "contents" },
          class: "inline-flex items-center gap-1.5 #{text_class} hover:text-gray-900 cursor-pointer" do %>
      <span class="inline-block w-2.5 h-2.5 rounded-full <%= onboarding_pip_dot_classes(pip.state) %>"></span>
      <span class="hidden sm:inline"><%= pip.label %></span>
    <% end %>
  <% else %>
    <div class="inline-flex items-center gap-1.5">
      <span class="inline-block w-2.5 h-2.5 rounded-full <%= onboarding_pip_dot_classes(pip.state) %>"></span>
      <span class="hidden sm:inline"><%= pip.label %></span>
    </div>
  <% end %>
</li>
