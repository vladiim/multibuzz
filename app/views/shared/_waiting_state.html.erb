<%#
  Shared waiting state. Used by verify event, payment_complete processing,
  and any other "we're working on it" surface. Per DESIGN_SYSTEM §7.1.

  Locals:
    heading - required, the headline text
    body    - required, the helper sentence beneath

  Optional yield block (use `render layout:` to pass) renders below the
  copy as extra detail (e.g. a "to trigger a test event" code block).
%>
<% extras = capture { yield } if block_given? %>
<div class="bg-white rounded-lg border border-gray-200 shadow-sm p-6 sm:p-8 text-center" data-testid="waiting-state">
  <div class="mx-auto w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mb-5">
    <svg class="w-8 h-8 text-indigo-600 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
  </div>
  <h2 class="text-2xl sm:text-3xl font-bold text-gray-900"><%= heading %></h2>
  <p class="mt-2 text-base text-gray-600"><%= body %></p>
  <% if extras.present? %>
    <div class="mt-6 text-left"><%= extras %></div>
  <% end %>
</div>
