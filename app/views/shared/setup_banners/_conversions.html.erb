<div data-testid="setup-banner-conversions" class="bg-indigo-50 border-b border-indigo-200">
  <div class="max-w-7xl mx-auto py-3 px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <div>
          <p class="text-sm font-medium text-indigo-900">Track conversions to measure attribution</p>
          <p class="text-sm text-indigo-700">Track conversion events like purchases or signups to see which channels drive results.</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button type="button"
          data-controller="modal"
          data-action="click->modal#open"
          data-modal-target-value="setup-conversions-modal"
          class="inline-flex items-center px-3 py-1.5 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
          Show me how
        </button>
        <%= link_to "View docs", docs_path(page: "getting-started"),
          class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" %>
      </div>
    </div>
  </div>
</div>

<%= render "shared/setup_modals/conversions", account: account %>
