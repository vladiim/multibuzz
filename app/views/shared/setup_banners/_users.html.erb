<div data-testid="setup-banner-users" class="bg-indigo-50 border-b border-indigo-200">
  <div class="max-w-7xl mx-auto py-3 px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <div>
          <p class="text-sm font-medium text-indigo-900">Identify users to link sessions</p>
          <p class="text-sm text-indigo-700">Connect anonymous visitors to known users for cross-device attribution.</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button type="button"
          data-controller="modal"
          data-action="click->modal#open"
          data-modal-target-value="setup-users-modal"
          class="inline-flex items-center px-3 py-1.5 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
          Show me how
        </button>
        <%= link_to "View docs", "https://docs.mbuzz.co/tracking/identify",
          target: "_blank",
          class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" %>
      </div>
    </div>
  </div>
</div>

<%= render "shared/setup_modals/users", account: account %>
