<% health_status = DataIntegrity::AccountHealthService.new(account).call %>

<% case health_status %>
<% when "critical" %>
  <div data-testid="data-quality-banner" class="bg-red-50 border-l-4 border-red-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <div class="flex items-center">
        <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
        <p class="ml-3 text-sm font-medium text-red-800">
          Data quality issues detected. Recent data may be unreliable. Our team has been notified.
        </p>
      </div>
    </div>
  </div>
<% when "warning" %>
  <div data-testid="data-quality-banner" class="bg-amber-50 border-l-4 border-amber-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <div class="flex items-center">
        <svg class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        <p class="ml-3 text-sm font-medium text-amber-800">
          Some data quality metrics are outside normal ranges. Recent data may be less reliable.
        </p>
      </div>
    </div>
  </div>
<% end %>
