<% if flash[:notice].present? %>
  <div data-testid="flash-notice"
    data-controller="flash-dismiss"
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
    <div class="rounded-md bg-green-50 border border-green-200 p-3 flex items-start gap-3">
      <svg class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      <p class="text-sm text-green-800 flex-1"><%= flash[:notice] %></p>
      <button type="button" data-action="flash-dismiss#dismiss" class="text-green-600 hover:text-green-800 text-sm" aria-label="Dismiss">×</button>
    </div>
  </div>
<% end %>

<% if flash[:alert].present? %>
  <div data-testid="flash-alert"
    data-controller="flash-dismiss"
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
    <div class="rounded-md bg-red-50 border border-red-200 p-3 flex items-start gap-3">
      <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-sm text-red-800 flex-1"><%= flash[:alert] %></p>
      <button type="button" data-action="flash-dismiss#dismiss" class="text-red-600 hover:text-red-800 text-sm" aria-label="Dismiss">×</button>
    </div>
  </div>
<% end %>
