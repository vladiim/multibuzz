<% if test_mode? %>
  <div data-testid="test-mode-banner" class="bg-amber-50 border-b border-amber-200">
    <div class="max-w-7xl mx-auto py-2 px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          <span class="text-sm font-medium text-amber-800">
            You're viewing test data
          </span>
          <span class="text-sm text-amber-700">
            Use <code class="px-1 py-0.5 bg-amber-100 rounded text-xs font-mono">sk_test_*</code> keys for testing
          </span>
        </div>
        <%= button_to dashboard_view_mode_path,
          method: :patch,
          params: { mode: "production" },
          class: "text-sm font-medium text-amber-700 hover:text-amber-900 underline",
          data: { turbo: false } do %>
          Switch to live data
        <% end %>
      </div>
    </div>
  </div>
<% end %>
