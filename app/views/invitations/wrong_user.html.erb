<div class="min-h-screen bg-gray-100 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10 text-center">
      <svg class="mx-auto h-12 w-12 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <h1 class="mt-4 text-xl font-semibold text-gray-900">Wrong Account</h1>
      <p class="mt-2 text-gray-600">
        This invitation was sent to a different account.
        Please log out and try again with the correct account, or ask the person who invited you for a new invitation.
      </p>
      <div class="mt-6 space-x-4">
        <%= link_to "Log Out", logout_path, method: :delete, class: "text-indigo-600 hover:text-indigo-500" %>
      </div>
    </div>
  </div>
</div>
