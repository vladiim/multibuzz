{
    "name": "mbuzz/php-testapp",
    "description": "Test app for Mbuzz PHP SDK integration tests",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "mbuzz/mbuzz-php": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../../mbuzz-php"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
