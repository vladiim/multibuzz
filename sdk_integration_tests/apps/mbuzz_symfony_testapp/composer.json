{
    "name": "mbuzz/symfony-testapp",
    "description": "Test app for Mbuzz Symfony SDK integration tests",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "symfony/http-kernel": "^7.0",
        "symfony/http-foundation": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "mbuzz/mbuzz-php": "dev-master"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../../mbuzz-php"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
